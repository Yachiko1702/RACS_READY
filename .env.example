# Copy this file to `.env` and fill in values before running the app.
# Keep real secrets out of version control.

# App & DB
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/appointment_scheduler

# JWT (use a long random secret in production)
JWT_SECRET=please_change_this_to_a_long_random_string

# Google / ReCAPTCHA (optional)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
GOOGLE_MAPS_API_KEY=

# SMTP (for sending reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@example.com

# Seed script convenience (optional)
SEED_TEST_EMAIL=test@example.com
SEED_TEST_PASSWORD=Password123!
