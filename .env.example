# Example .env for local development — copy to .env and edit values
# Rename to .env in your project root (do NOT commit real secrets).

# Database
MONGODB_URI=mongodb://localhost:27017/appointment_scheduler

# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=dev-secret
SESSION_SECRET=dev-session-secret
SESSION_TTL_MS=1800000          # session TTL (ms)
SESSION_MAX_AGE_MS=1800000      # cookie max-age (ms)

# Mailer (used for OTP / notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@example.com

# Optional 3rd-party keys
GOOGLE_MAPS_API_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Admin account used by server/scripts/createAdmin.js
# - Required for first-run admin provisioning (set ADMIN_EMAIL and ADMIN_PASSWORD)
# - ADMIN_FIRSTNAME / ADMIN_LASTNAME / ADMIN_PHONE are optional and will be used
#   to populate required profile fields if the user record lacks them.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=User
ADMIN_PHONE=09171234567

# Misc (tunable)
RESET_PASSWORD_TOKEN_EXPIRES_MS=3600000
SESSION_ROTATE_THRESHOLD_MS=600000

# Public holiday provider configuration (used by /api/holidays and
# /api/services/:id/calendar).  Provider may be "google" or "nager".
# The X-Provider header or "provider" query parameter can override for a
# single request.
PUBLIC_HOLIDAYS_ENABLED=1
PUBLIC_HOLIDAYS_PROVIDER=google
PUBLIC_HOLIDAYS_CALENDAR_ID=       # google calendar id for holidays (en.ph#holiday@group.v.calendar.google.com)
# Nager.Date options
NAGER_COUNTRY=PH

# Note: this file is an example. Never commit real secrets to source control.
