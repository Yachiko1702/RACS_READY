<!-- Featured Aircons Partial -->
<section class="products-aircons py-5">
  <div class="container" data-aos="fade-up">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h2 class="section-title text-primary">Featured Aircons</h2>
        <p class="section-subtitle text-muted">Handpicked units — clear specs, competitive prices, and quick view.</p>
      </div>

      <!-- Filter Pills -->
      <div class="btn-group" role="tablist" aria-label="Product filters">
        <button class="btn btn-outline-primary active" data-filter="all">All</button>
        <button class="btn btn-outline-primary" data-filter="split">Split</button>
        <button class="btn btn-outline-primary" data-filter="window">Window</button>
        <button class="btn btn-outline-primary" data-filter="inverter">Inverter</button>
      </div>
    </div>

    <% const aircons = [
      { id: 'ac-1001', name: 'Calidro Split 1.5HP', type: 'split', capacity: '1.5 HP', btu: '12,000 BTU', inverter: true, price: 17500, img: '/images/products/aircon-split-1.webp', badge: 'Featured', rating: 4.6, desc: 'Energy efficient inverter split AC with quiet operation.' },
      { id: 'ac-1002', name: 'Calidro Window 1HP', type: 'window', capacity: '1 HP', btu: '9,000 BTU', inverter: false, price: 8500, img: '/images/products/aircon-window-1.webp', badge: 'Best value', rating: 4.3, desc: 'Compact window unit for small rooms, easy install.' },
      { id: 'ac-1003', name: 'Calidro Inverter 2HP', type: 'inverter', capacity: '2 HP', btu: '18,000 BTU', inverter: true, price: 26500, img: '/images/products/aircon-inverter-2.webp', badge: 'New', rating: 4.8, desc: 'High-capacity inverter unit for larger spaces.' },
      { id: 'ac-1004', name: 'Calidro Split 1.0HP', type: 'split', capacity: '1.0 HP', btu: '9,000 BTU', inverter: false, price: 12000, img: '/images/products/aircon-split-2.webp', rating: 4.1, desc: 'Reliable, budget-friendly split system.' }
    ]; %>

    <div class="row g-3">
      <% aircons.forEach((p) => { %>
        <div class="col-6 col-md-4 col-lg-3 product-card-wrap" data-type="<%= p.type %>">
          <div class="card product-card h-100 border-0 shadow-sm">
            <div class="position-relative">
              <img src="<%= p.img %>" class="card-img-top product-img" alt="<%= p.name %>">
              <% if (p.badge) { %>
                <span class="badge bg-primary position-absolute top-0 start-0 m-2"><%= p.badge %></span>
              <% } %>
              <span class="badge bg-light text-dark position-absolute top-0 end-0 m-2"><%= p.capacity %></span>
            </div>
            <div class="card-body p-3 d-flex flex-column">
              <h6 class="card-title mb-1"><%= p.name %></h6>
              <div class="text-muted small mb-2"><%= p.btu %> · <%= p.inverter ? 'Inverter' : 'Non-inverter' %></div>
              <div class="mt-auto d-flex align-items-center justify-content-between gap-2">
                <div>
                  <div class="product-price fw-bold">₱<%= p.price.toLocaleString() %></div>
                  <div class="text-muted small">Rating: <span class="text-warning"><%= p.rating %>★</span></div>
                </div>
                <div class="d-flex flex-column align-items-end">
                  <button class="btn btn-sm btn-outline-primary quick-view" 
                          type="button"
                          data-id="<%= p.id %>"
                          data-name="<%= p.name %>"
                          data-price="<%= p.price %>"
                          data-img="<%= p.img %>"
                          data-desc="<%= p.desc %>"
                          data-btu="<%= p.btu %>"
                          data-capacity="<%= p.capacity %>"
                          data-inverter="<%= p.inverter %>">
                    Quick View
                  </button>
                  <a href="/products/<%= p.id %>" class="btn btn-sm btn-primary mt-2">View Details</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Quick View Modal (Bootstrap) -->
    <div class="modal fade" id="productQuickViewModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-body p-4">
            <div class="row g-3">
              <div class="col-md-6">
                <img id="modalProductImg" src="" alt="" class="img-fluid rounded">
              </div>
              <div class="col-md-6">
                <h5 id="modalProductName" class="mb-1"></h5>
                <div class="text-muted small mb-2" id="modalProductSpecs"></div>
                <p id="modalProductDesc" class="text-muted"></p>
                <div class="d-flex align-items-center justify-content-between mt-4">
                  <div class="h5 mb-0" id="modalProductPrice"></div>
                  <div>
                    <button class="btn btn-outline-secondary me-2" type="button" id="modalAddQtyMinus">-</button>
                    <input type="text" id="modalAddQty" value="1" class="form-control d-inline-block text-center" style="width:64px;" aria-label="Quantity">
                    <button class="btn btn-outline-secondary ms-2" type="button" id="modalAddQtyPlus">+</button>
                  </div>
                </div>
                <div class="mt-3">
                  <button class="btn btn-primary" id="modalAddToCart">Add to Cart</button>
                  <button class="btn btn-outline-primary" data-bs-dismiss="modal">Close</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div> 
    </div>

  </div>

  <style>
    /* Section visual polish */
    .products-aircons { background: linear-gradient(180deg, rgba(232,246,255,0.6), rgba(243,250,255,0.6)); border-radius: 12px; padding: 2.5rem; }
    .product-card { transition: transform .15s ease, box-shadow .15s ease; overflow: hidden; border-radius: .75rem; }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 8px 28px rgba(30, 60, 90, 0.08); }
    .product-img { height: 160px; object-fit: cover; width: 100%; display: block; }
    .product-price { color: #0d6efd; }
    .btn-group .btn.active { background: linear-gradient(90deg,#d8f0ff,#bbe9ff); border-color: #9ddfff; }
    @media (max-width: 576px) { .product-img { height: 140px; } }
  </style>

  <script>
    (function () {
      // Filter logic
      const filterBtns = document.querySelectorAll('.products-aircons [data-filter]');
      const cards = document.querySelectorAll('.product-card-wrap');
      filterBtns.forEach(btn => btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        cards.forEach(c => {
          const type = c.dataset.type;
          c.classList.toggle('d-none', filter !== 'all' && type !== filter);
        });
      }));

      // Quick view
      document.addEventListener('click', (e) => {
        if (e.target.matches('.quick-view')) {
          const b = e.target;
          document.getElementById('modalProductImg').src = b.dataset.img || '';
          document.getElementById('modalProductName').textContent = b.dataset.name || '';
          document.getElementById('modalProductDesc').textContent = b.dataset.desc || '';
          document.getElementById('modalProductSpecs').textContent = [b.dataset.btu, b.dataset.capacity, b.dataset.inverter === 'true' ? 'Inverter' : 'Non-inverter'].filter(Boolean).join(' · ');
          document.getElementById('modalProductPrice').textContent = '₱' + Number(b.dataset.price || 0).toLocaleString();
          document.getElementById('modalAddQty').value = 1;
          const modal = new bootstrap.Modal(document.getElementById('productQuickViewModal'));
          modal.show();
        }
      });

      // Modal qty controls
      document.getElementById('modalAddQtyPlus').addEventListener('click', () => {
        const el = document.getElementById('modalAddQty'); el.value = Number(el.value || 1) + 1;
      });
      document.getElementById('modalAddQtyMinus').addEventListener('click', () => {
        const el = document.getElementById('modalAddQty'); el.value = Math.max(1, Number(el.value || 1) - 1);
      });

      // Stub add to cart (replace with real implementation)
      document.getElementById('modalAddToCart').addEventListener('click', () => {
        const qty = Number(document.getElementById('modalAddQty').value || 1);
        const name = document.getElementById('modalProductName').textContent;
        alert(`${qty} × ${name} added to cart (stub).`);
        const modalEl = document.getElementById('productQuickViewModal');
        bootstrap.Modal.getInstance(modalEl).hide();
      });
    })();
  </script>
</section>