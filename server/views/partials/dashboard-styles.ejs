<style>
  /* shared dashboard page styles (from admin-dashboard.ejs) */
  @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap");
  :root {
    --dash-primary: #4361ee;
    --dash-primary-light: rgba(67, 97, 238, 0.1);
    --dash-success: #2ec4b6;
    --dash-warning: #ff9f1c;
    --dash-danger: #e63946;
    --dash-purple: #7b2d8b;
    --dash-dark: #212529;
    --dash-card-radius: 14px;
    --dash-card-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    --dash-hover-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    --dash-section-title: 0.8rem;
    /* darker, less bright hero gradient */
    --dash-hero-bg: linear-gradient(120deg, #4361ee 0%, #3a0ca3 100%);
  }
  .admin-dashboard {
    font-family: "Poppins", "Inter", "Segoe UI", sans-serif;
    color: #212529;
    background: #f5f6fa;
  }

  /* ---- HERO HEADER ---- */
  .admin-dashboard .dashboard-hero {
    background: var(--dash-hero-bg);
    border-radius: var(--dash-card-radius);
    padding: 28px 32px;
    box-shadow: 0 8px 32px rgba(67, 97, 238, 0.18);
    position: relative;
    overflow: hidden;
    color: #fff;
  }
  .admin-dashboard .dashboard-hero::before {
    content: "";
    position: absolute;
    width: 260px;
    height: 260px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    top: -60px;
    right: -60px;
    pointer-events: none;
  }
  .admin-dashboard .dashboard-hero::after {
    content: "";
    position: absolute;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    bottom: -40px;
    left: 40px;
    pointer-events: none;
  }
  .admin-dashboard .page-title {
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: -0.3px;
    margin: 0;
    color: #fff;
  }
  .admin-dashboard .hero-email {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.82);
    margin: 2px 0 0;
  }
  .admin-dashboard .hero-sub {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.58);
    margin: 2px 0 0;
  }
  .admin-dashboard .hero-avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: 2px solid rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    flex-shrink: 0;
  }
  .admin-dashboard .hero-status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2ec4b6;
    border: 2px solid #fff;
    display: inline-block;
    margin-right: 5px;
  }
  .admin-dashboard .hero-status {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.75);
    display: flex;
    align-items: center;
    margin-top: 8px;
  }
  .admin-dashboard .hero-btn {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    border-radius: 8px;
    padding: 0.35rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    backdrop-filter: blur(4px);
    transition: background 0.2s;
  }
  .admin-dashboard .hero-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    color: #fff;
  }
  .admin-dashboard .hero-btn-primary {
    /* purple so button stands out against dark hero backgrounds */
    background: var(--dash-primary);
    color: #fff;
  }

  /* smaller hero for profile pages */
  .profile-secretary-page .dashboard-hero {
    padding: 16px 24px;
  }
  .profile-secretary-page .dashboard-hero .page-title {
    font-size: 1.3rem;
  }
  .profile-secretary-page .dashboard-hero .hero-avatar,
  .profile-secretary-page .dashboard-hero .avatar {
    width: 64px;
    height: 64px;
    font-size: 22px;
  }
    color: var(--dash-primary) !important;
    border: none;
  }
  .admin-dashboard .hero-btn-primary:hover {
    /* maintain same color on hover */
    background: var(--dash-primary);
    color: #fff !important;
  }

  /* ---- SECTION LABEL ---- */
  .admin-dashboard .section-label {
    font-size: var(--dash-section-title);
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #9ba3af;
    margin-bottom: 10px;
  }

  /* ---- KPI CARDS ---- */
  /* make parent columns stretch so all cards are same height */
  .admin-dashboard .kpi-row > [class*="col-"] {
    display: flex;
  }
  .admin-dashboard .kpi-row .kpi-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .admin-dashboard .kpi-card {
    border: 0;
    border-radius: var(--dash-card-radius);
    box-shadow: var(--dash-card-shadow);
    background: #fff;
    padding: 18px 20px;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
    position: relative;
    overflow: hidden;
  }
  .admin-dashboard .kpi-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--dash-hover-shadow);
  }
  .admin-dashboard .kpi-card .kpi-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
    color: #fff;
  }
  .admin-dashboard .kpi-card .kpi-label {
    font-size: 0.74rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #9ba3af;
    line-height: 1.2;
    white-space: nowrap;
  }
  .admin-dashboard .kpi-card .kpi-value {
    font-size: 1.65rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1.1;
    margin-top: 2px;
  }
  .admin-dashboard .kpi-card .kpi-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 0 0 var(--dash-card-radius) var(--dash-card-radius);
  }

  /* ---- GENERIC CONTENT CARD ---- */
  .admin-dashboard .dash-card {
    border: 0;
    border-radius: var(--dash-card-radius);
    box-shadow: var(--dash-card-shadow);
    background: #fff;
    overflow: hidden;
    transition: box-shadow 0.18s;
  }
  .admin-dashboard .dash-card:hover {
    box-shadow: var(--dash-hover-shadow);
  }
  .admin-dashboard .dash-card .card-header-custom {
    padding: 16px 20px 12px;
    border-bottom: 1px solid #f1f3f7;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .admin-dashboard .dash-card .card-header-custom h5,
  .admin-dashboard .dash-card .card-header-custom h6 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0;
    color: #212529;
  }
  .admin-dashboard .dash-card .card-header-custom .card-meta {
    font-size: 0.72rem;
    color: #9ba3af;
    font-weight: 500;
  }

  /* ---- LIST ITEMS ---- */
  .admin-dashboard .dash-list-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #f1f3f7;
  }
  .admin-dashboard .dash-list-item:last-child {
    border-bottom: none;
  }
  .admin-dashboard .dash-list-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
  }
  .admin-dashboard .dash-list-item .item-title {
    font-size: 0.83rem;
    font-weight: 600;
    color: #212529;
    line-height: 1.3;
  }
  .admin-dashboard .dash-list-item .item-sub {
    font-size: 0.72rem;
    color: #9ba3af;
    margin-top: 1px;
  }
  .admin-dashboard .dash-empty {
    text-align: center;
    padding: 24px 0;
    color: #c4c9d4;
    font-size: 0.82rem;
  }
  .admin-dashboard .dash-empty i {
    font-size: 1.6rem;
    display: block;
    margin-bottom: 6px;
  }

  /* ---- ACTIVITY FEED ---- */
  .admin-dashboard .activity-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dash-primary);
    flex-shrink: 0;
    margin-top: 5px;
  }

  /* ---- QUICK ACTIONS ---- */
  .admin-dashboard .quick-action-btn {
    border-radius: 10px;
    padding: 0.38rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1.5px solid #e5e7eb;
    background: #fff;
    color: #374151;
    transition: all 0.17s;
  }
  .admin-dashboard .quick-action-btn:hover {
    border-color: var(--dash-primary);
    color: var(--dash-primary);
    background: var(--dash-primary-light);
  }
  .admin-dashboard .quick-action-btn-primary {
    background: var(--dash-primary);
    border-color: var(--dash-primary);
    color: #fff;
  }
  .admin-dashboard .quick-action-btn-primary:hover {
    background: #3451d1;
    border-color: #3451d1;
    color: #fff;
  }

  /* ---- BADGE PILL ---- */
  .admin-dashboard .status-pill {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.03em;
  }

  /* ---- CALENDAR ---- */
  .admin-dashboard #mini-calendar .cal-day {
    text-align: center;
    font-size: 12px;
    padding: 5px 2px;
    border-radius: 8px;
    color: #374151;
    font-weight: 500;
  }
  .admin-dashboard #mini-calendar .cal-day.today {
    background: var(--dash-primary);
    color: #fff;
    font-weight: 700;
  }
  .admin-dashboard .cal-legend span {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    display: inline-block;
    margin-right: 4px;
  }
  .admin-dashboard .cal-legend {
    font-size: 0.72rem;
    color: #6b7280;
    font-weight: 500;
  }

  @media (max-width: 767px) {
    .admin-dashboard .dashboard-hero {
      padding: 20px 18px;
    }
    .admin-dashboard .page-title {
      font-size: 1.25rem;
    }
    .admin-dashboard .kpi-card .kpi-value {
      font-size: 1.3rem;
    }
  }

  /* smaller profile header */
  .profile-secretary-page .dashboard-hero {
    padding: 16px 24px;
  }
  .profile-secretary-page .dashboard-hero .page-title {
    font-size: 1.3rem;
  }
  .profile-secretary-page .dashboard-hero .avatar {
    width: 64px;
    height: 64px;
    font-size: 22px;
  }

  /* ensure profile input icons match auth panel color */
  .admin-dashboard .input-group-text,
  .secretary-dashboard .input-group-text,
  .profile-page .input-group-text,
  .profile-admin-page .input-group-text,
  .profile-secretary-page .input-group-text {
    color: rgba(13,110,253,0.95);
  }
  .admin-dashboard .input-group-text i,
  .secretary-dashboard .input-group-text i,
  .profile-page .input-group-text i,
  .profile-admin-page .input-group-text i,
  .profile-secretary-page .input-group-text i {
    color: inherit;
  }
</style>
