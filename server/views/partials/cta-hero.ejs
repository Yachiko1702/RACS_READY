<div class="cta-hero mt-4" role="region" aria-label="Primary call to action">
  <div class="d-flex gap-3 align-items-center flex-wrap">
    <a href="<%= primaryHref || '/services' %>" class="btn btn-primary btn-lg btn-cta" data-cta="primary" data-label="<%= primaryLabel || 'Book a Service' %>" aria-label="<%= primaryLabel || 'Book a Service' %>">
      <i class="bi bi-calendar-check me-2" aria-hidden="true"></i>
      <span><%= primaryLabel || 'Book a Service' %></span>
    </a>

    <a href="<%= secondaryHref || '/products' %>" class="btn btn-outline-primary btn-lg btn-cta text-black" data-cta="secondary" data-label="<%= secondaryLabel || 'View Products' %>" aria-label="<%= secondaryLabel || 'View Products' %>">
      <i class="bi bi-box-seam me-2" aria-hidden="true"></i>
      <span><%= secondaryLabel || 'View Products' %></span>
    </a>
  </div>

  <div class="cta-meta mt-2 text-muted small" aria-hidden="true">
    <span class="me-3"><i class="bi bi-clock me-1"></i> Fast scheduling</span>
    <span class="me-3"><i class="bi bi-shield-check me-1"></i> Quality guarantee</span>
    <span class="me-3"><i class="bi bi-people me-1"></i> Trusted by local customers</span>
  </div>
</div>