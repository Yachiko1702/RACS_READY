<!-- Section 1 : Blob Hero -->
<section class="hero-blob py-5">
  <div class="container">
    <div class="row align-items-stretch">
      <!-- Text Column -->
      <div class="col-lg-6 d-flex align-items-center" data-aos="fade-up">
        <div>
          <span class="badge hero-badge mb-3">
            <i class="bi bi-snow me-1"></i> Smart Cooling Solutions
          </span>
          <h1 class="fw-bold display-5 mt-3">
            Smart Appointment Scheduling<br>
            for <span class="text-primary">Aircon & Home Services</span>
          </h1>
          <p class="lead text-muted mt-4">
            CALIDRO RACS delivers reliable air conditioning, CCTV installation,
            and appliance repair services powered by intelligent scheduling
            and inventory-backed operations.
          </p>
          <%- include('../partials/cta-hero', { primaryHref: '/services', primaryLabel: 'Book a Service', secondaryHref: '/products', secondaryLabel: 'View Products' }) %>
        </div>
      </div>
      <!-- Blob Column -->
      <div class="col-lg-6 blob-wrapper position-relative" data-aos="fade-left">
        <div class="blob-image"></div>
      </div>
    </div>
  </div>
</section>


<br>
<div class="section-divider my-4 text-center">
  <span><i class="bi bi-snow2"></i></span>
</div>

<!-- Section 2 Technician details -->
<section class="py-5">
  <div class="container">
    <div class="row align-items-center g-5">

      <!-- Carousel Column -->
      <div class="col-12 col-md-6">
        <div data-aos="fade-right" data-aos-duration="800" data-aos-delay="150">
          <div id="section2Carousel"
              class="carousel slide rounded shadow-sm overflow-hidden"
              data-bs-ride="carousel"
              data-bs-interval="3500"
              data-bs-pause="false">

            <!-- Indicators -->
            <div class="carousel-indicators">
              <button type="button" data-bs-target="#section2Carousel" data-bs-slide-to="0" class="active"></button>
              <button type="button" data-bs-target="#section2Carousel" data-bs-slide-to="1"></button>
              <button type="button" data-bs-target="#section2Carousel" data-bs-slide-to="2"></button>
            </div>

            <!-- Slides -->
            <div class="carousel-inner">
              <div class="carousel-item active">
                <img src="/images/technicianWork/tech1.jpg" class="d-block w-100" alt="Technician working">
              </div>
              <div class="carousel-item">
                <img src="/images/technicianWork/tech2.jpg" class="d-block w-100" alt="Aircon service">
              </div>
              <div class="carousel-item">
                <img src="/images/technicianWork/tech3.jpg" class="d-block w-100" alt="Repair service">
              </div>
            </div>

            <!-- Controls -->
            <button class="carousel-control-prev" type="button" data-bs-target="#section2Carousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#section2Carousel" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>

          </div>
        </div>
      </div>

      <!-- Text Column -->
      <div class="col-12 col-md-6 d-flex">
        <div class="my-auto"
             data-aos="fade-left"
             data-aos-duration="800"
             data-aos-delay="150">

          <h2 class="fw-bold">Professional Technicians You Can Trust</h2>
          <p class="text-muted mt-3">
            CALIDRO RACS technicians are trained ...
          </p>

          <ul class="list-unstyled mt-4">
            <li class="mb-2">
              <i class="bi bi-check-circle-fill text-primary me-2"></i>
              Verified and experienced technicians
            </li>
            <li class="mb-2">
              <i class="bi bi-check-circle-fill text-primary me-2"></i>
              Real-time service tracking and updates
            </li>
            <li class="mb-2">
              <i class="bi bi-check-circle-fill text-primary me-2"></i>
              Transparent pricing
            </li>
            <li class="mb-2">
              <i class="bi bi-check-circle-fill text-primary me-2"></i>
              Organized inventory and service workflow
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>


<br>
<!-- Section Divider -->
<div class="section-divider">
  <span><i class="bi bi-snow2"></i></span>
</div>

<!-- ===== Section 4: Services ===== -->
<section class="services-poster">
  <div class="poster-panel"
       data-aos="fade-right"
       data-aos-duration="800"
       data-aos-delay="150">

    <h2 class="poster-title text-primary">OUR SERVICES</h2>
    <p class="poster-subtitle">Professional Aircon & Technical Solutions</p>

    <p class="poster-desc">
      Reliable, efficient, and high-quality services designed to keep your
      home and business comfortable all year round.
    </p>

    <ul class="poster-services">
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="200">Aircon Installation</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="250">Aircon Cleaning</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="300">Freon Recharging</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="350">Aircon Relocation</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="400">Dismantling & Reinstall</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="450">System Reprocess</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="500">Pump Down</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="550">Leak Testing</li>
      <li data-aos="fade-up" data-aos-duration="600" data-aos-delay="600">CCTV Installation</li>
    </ul>
  </div>
</section>




<br>
<div class="section-divider my-4 text-center">
  <span><i class="bi bi-snow2"></i></span>
</div>
<br>


<!-- ===== Section 4: Repair Services ===== -->
<section class="repair-services position-relative py-5">
  <!-- Background Image Overlay -->
  <div class="repair-bg"></div>

  <!-- Section Header -->
  <div class="text-center mb-5 position-relative z-2" data-aos="fade-up" data-aos-duration="800">
    <h2 class="section-title text-primary">We Also Repair</h2>
    <p class="section-subtitle text-primary">
      Trusted repair services for common household appliances
    </p>
  </div>

  <!-- Repair Cards Grid -->
  <div class="container position-relative z-2">
    <div class="row g-4 justify-content-center">
      <% const repairs = [
        { icon: 'bi-snow2', title: 'Refrigerator' },
        { icon: 'bi-droplet', title: 'Washing Machine' },
        { icon: 'bi-lightning-charge', title: 'Microwave Oven' },
        { icon: 'bi-box', title: 'Freezer' },
        { icon: 'bi-wind', title: 'Dryer' },
        { icon: 'bi-cup-hot', title: 'Rice Cooker' },
        { icon: 'bi-fan', title: 'Electric Fan' },
        { icon: 'bi-water', title: 'Water Dispenser' },
        { icon: 'bi-thermometer', title: 'Electric Kettle' }
      ]; %>

      <% repairs.forEach((item, index) => { %>
        <div class="col-6 col-md-4 col-lg-3" 
             data-aos="fade-up" 
             data-aos-duration="800" 
             data-aos-delay="<%= index * 100 %>">
          <div class="repair-card text-center p-4 h-100">
            <div class="repair-icon mx-auto mb-3">
              <i class="bi <%= item.icon %> fs-3"></i>
            </div>
            <h6 class="fw-semibold text-white"><%= item.title %></h6>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>


<br>
<div class="section-divider my-4 text-center">
  <span><i class="bi bi-snow2"></i></span>
</div>
<br>

<!-- Section 5 Staff Carousel -->
<section class="container py-5 rounded-4">
  <div class="text-center mb-5" data-aos="fade-up" data-aos-duration="1000">
    <h2 class="section-title text-primary">Meet Our Team</h2>
    <p class="section-subtitle text-secondary">
      Dedicated professionals ensuring quality service for our clients
    </p>
  </div>

  <div class="staff-carousel">
    <% const staff = [
      { name: 'Edmon Calidro', role: 'Proprietor / Technician / Owner', img: 'images/staff/staff.webp' },
      { name: 'Loida Calidro', role: 'Owner', img: 'images/staff/staff.webp' },
      { name: 'Kyla de Guzman', role: 'Secretary', img: 'images/staff/staff.webp' },
      { name: 'Myles Capinpin', role: 'Secretary / Marketing', img: 'images/staff/staff.webp' },
      { name: 'Darius Santos', role: 'Helper', img: 'images/staff/staff.webp' },
      { name: 'Darrel Santos', role: 'Helper', img: 'images/staff/staff.webp' },
      { name: 'Raymark Lopez', role: 'Multi-skilled Worker', img: 'images/staff/staff.webp' }
    ]; %>

    <% staff.forEach((member, index) => { %>
      <div class="staff-card" data-aos="fade-up" data-aos-duration="1000" data-aos-delay="<%= index * 150 %>">
        <div class="staff-avatar" style="background-image: url('<%= member.img || 'https://via.placeholder.com/150' %>');"></div>
        <div class="staff-content">
          <h6><%= member.name %></h6>
          <span><%= member.role %></span>
        </div>
      </div>
    <% }) %>
  </div>
</section>


