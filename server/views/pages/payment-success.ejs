<section class="py-5" style="min-height:80vh;background:linear-gradient(135deg,#f0fdf4 0%,#dcfce7 50%,#f0fdf4 100%);">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
          <!-- Green gradient header -->
          <div class="py-5 px-4" style="background:linear-gradient(135deg,#16a34a,#15803d);">
            <div style="font-size:3.5rem;margin-bottom:.5rem;">&#9989;</div>
            <h2 class="text-white fw-bold mb-1" style="letter-spacing:.3px;">Payment Successful!</h2>
            <p class="text-white mb-0" style="opacity:.85;font-size:.95rem;">Your GCash payment was processed.</p>
          </div>

          <div class="card-body px-4 py-4">
            <!-- Booking reference badge -->
            <% if (bookingRef) { %>
            <div class="mb-4">
              <div class="text-muted small mb-1">Booking Reference</div>
              <div class="d-inline-block px-4 py-2 rounded-3 fw-bold"
                   style="background:#f0fdf4;border:1.5px solid #86efac;color:#15803d;font-size:1.1rem;letter-spacing:2px;">
                <%= bookingRef %>
              </div>
            </div>
            <% } %>

            <!-- Status info -->
            <div class="rounded-3 p-3 mb-4" style="background:#f8f9fa;">
              <div class="d-flex align-items-center gap-3 mb-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:40px;height:40px;background:#dcfce7;flex-shrink:0;">
                  <i class="bi bi-shield-check text-success fs-5"></i>
                </div>
                <div class="text-start">
                  <div class="fw-semibold small">Secured by PayMongo</div>
                  <div class="text-muted" style="font-size:.8rem;">BSP-licensed payment processor</div>
                </div>
              </div>
              <hr class="my-2" />
              <p class="mb-0 small text-muted">
                Your booking is now <strong class="text-success">confirmed</strong>. A confirmation email has been sent to your registered address.
              </p>
            </div>

            <!-- Next steps -->
            <div class="text-start mb-4">
              <div class="fw-semibold mb-2 small text-muted text-uppercase" style="letter-spacing:.5px;">What happens next</div>
              <ol class="ps-3 mb-0 small text-muted" style="line-height:2;">
                <li>Our team will review your booking request.</li>
                <li>A technician will be assigned and you'll be notified.</li>
                <li>On the scheduled day, our technician will arrive at your location.</li>
              </ol>
            </div>

            <!-- CTA buttons -->
            <div class="d-grid gap-2">
              <a href="/book-history" class="btn btn-success btn-lg fw-semibold">
                <i class="bi bi-calendar-check me-2"></i>View My Bookings
              </a>
              <a href="/services" class="btn btn-outline-secondary">
                <i class="bi bi-plus-circle me-2"></i>Book Another Service
              </a>
            </div>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="text-center mt-4">
          <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-3"
               style="background:rgba(255,255,255,.7);backdrop-filter:blur(6px);font-size:.8rem;color:#6c757d;">
            <i class="bi bi-lock-fill text-success"></i>
            <span>256-bit SSL encrypted &bull; Powered by PayMongo</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
