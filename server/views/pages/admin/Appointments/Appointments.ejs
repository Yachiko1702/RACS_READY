  <script>
    (function () {
      const qs = (s) => document.querySelector(s);
      const qsa = (s) => Array.from(document.querySelectorAll(s));

      // normalize proof image string into a usable src/href
      function normalizeProofSrc(raw) {
        if (!raw) return null;
        let imgSrc = String(raw);
        // common case: raw base64 payload without data: prefix
        if (/^[A-Za-z0-9+/]+={0,2}$/.test(imgSrc)) {
          imgSrc = "data:image/jpeg;base64," + imgSrc; // fallback to jpeg
        }
        // if still not a data URL or absolute/http(s) path, decide what to do
        if (!/^data:|^https?:\/\//i.test(imgSrc)) {
          if (imgSrc.startsWith("/")) {
            // treat as server-relative URL; leave it alone
          } else {
            imgSrc = "/api/appointments/proof/" + encodeURIComponent(imgSrc);
          }
        }
        return imgSrc;
      }

      // Tab switching
      qsa("#apptsTabs [data-tab]").forEach((btn) =>
        btn.addEventListener("click", function () {
          qsa("#apptsTabs .nav-link").forEach((n) =>
            n.classList.remove("active"),
          );
          this.classList.add("active");
          const allTabs = qsa(".tab-pane");
          allTabs.forEach((t) => t.classList.add("d-none"));
          const sel = this.getAttribute("data-tab");
          document.getElementById(sel).classList.remove("d-none");
        }),
      );

      // relocate modal element to body
      document.addEventListener("DOMContentLoaded", () => {
        const m = document.getElementById("apptsSharedModal");
        if (m && m.parentElement !== document.body) {
          document.body.appendChild(m);
        }
      });

      // Shared data stores
      // if the server sent us some bookings, use them as initial state
      let combinedAppointments = <%- JSON.stringify(initialBookings || []) %> || [];
      // move shared modal into <body> to avoid stacking context/z-index issues
      document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("apptsSharedModal");
        if (modal && modal.parentElement !== document.body) {
          document.body.appendChild(modal);
        }
        // inject high-z styles for modal/backdrop
        const css = document.createElement("style");
        css.textContent =
          ".modal { z-index: 2000 !important; } .modal-backdrop { z-index: 1500 !important; backdrop-filter: none !important; }";
        document.head.appendChild(css);
      });

      // draw what we already have so the page isn't blank while the API loads
      if (combinedAppointments && combinedAppointments.length) {
        renderAppointmentsTable(combinedAppointments);
        // also seed the reschedule selector
        const sel = document.getElementById("rescheduleSelect");
        if (sel) {
          sel.innerHTML = "";
          combinedAppointments.slice(0, 200).forEach((a) => {
            const opt = document.createElement("option");
            opt.value =
              a._id || a.id || a.bookingId || a.start || JSON.stringify(a);
            opt.textContent =
              `${a.bookingDate || a.date || ""} — ${
                a.customerName ||
                (a.customer && a.customer.name) ||
                a.customer ||
                a.title ||
                "Booking"
              }`;
            sel.appendChild(opt);
          });
        }
      }
      let combinedStaff = [];
      let bookingRequests = [];

      // Load initial overview (list KPIs + table + trend)
      async function loadCombinedOverview() {
        try {
          const sRes = await fetch("/api/admin/analytics/summary");
          const s = sRes.ok ? await sRes.json() : {};
          // KPI metrics should reflect real status buckets, especially cancelled.
          let metricAppointments = [];
          try {
            const mRes = await fetch("/api/appointments?upcoming=1");
            if (mRes.ok) {
              const mj = await mRes.json();
              metricAppointments = mj.items || mj.appointments || [];
            }
          } catch (_) {}

          const pendingCount = metricAppointments.filter((a) => statusLabel(a.status) === "pending").length;
          const confirmedCount = metricAppointments.filter((a) => statusLabel(a.status) === "confirmed").length;
          const cancelledCount = metricAppointments.filter((a) => statusLabel(a.status) === "cancelled").length;

          const hasMetricList = Array.isArray(metricAppointments) && metricAppointments.length > 0;

          // Use appointment list metrics as primary source so these KPIs are consistent with
          // what the Appointments module is currently handling (not only today's summary).
          // "Appointments" KPI should mirror confirmed jobs per user request
          // use confirmedCount regardless of metric list size so the two cards always match
          document.getElementById("kpi-today-combined").innerText =
            hasMetricList ? confirmedCount : (s.activeJobsInProgress ?? "—");
          document.getElementById("kpi-pending-combined").innerText =
            hasMetricList ? pendingCount : (s.pendingBookingRequests ?? "—");
          document.getElementById("kpi-confirmed-combined").innerText =
            hasMetricList ? confirmedCount : (s.activeJobsInProgress ?? "—");
          document.getElementById("kpi-cancelled-combined").innerText =
            hasMetricList ? cancelledCount : "0";

          // load appointments (try network, but fall back to server-provided data)
          let appts = [];
          try {
            // only fetch confirmed/upcoming slots – pending bookings are handled in the requests tab
            const r = await fetch("/api/appointments?upcoming=1&status=confirmed");
            if (r.ok) {
              const j = await r.json();
              // server returns { items, count }
              appts = j.items || j.appointments || [];
            }
          } catch (e) {
            console.warn("appointment fetch failed, using seed data", e);
          }
          if (!appts.length) {
            // use page-rendered bookings if available
            appts = combinedAppointments || [];
          }
          combinedAppointments = appts;
          renderAppointmentsTable(appts);

          // populate reschedule select
          const sel = document.getElementById("rescheduleSelect");
          sel.innerHTML = "";
          (appts || []).slice(0, 200).forEach((a) => {
            const opt = document.createElement("option");
            opt.value =
              a._id || a.id || a.bookingId || a.start || JSON.stringify(a);
            opt.textContent = `${a.bookingDate || a.date || ""} — ${a.customerName || (a.customer && a.customer.name) || a.customer || a.title || "Booking"}`;
            sel.appendChild(opt);
          });

          // staff list
          try {
            const r = await fetch("/api/admin/staff", {
              credentials: "same-origin",
            });
            if (r.ok) {
              const j = await r.json();
              combinedStaff = j.staff || [];
              const techSelect = document.getElementById("filterTechCombined");
              techSelect.innerHTML =
                '<option value="all">All technicians</option>';
              combinedStaff.forEach((s) => {
                const o = document.createElement("option");
                o.value = s._id;
                o.textContent =
                  (s.firstName || "") + " " + (s.lastName || s.email || "");
                techSelect.appendChild(o);
              });
            } else {
              console.warn("Failed to load staff", r.status);
            }
          } catch (e) {
            console.warn("load staff error", e);
          }

          // requests list (best-effort)
          loadBookingRequests();
        } catch (err) {
          console.error("loadCombinedOverview failed", err);
        }
      }

      function renderAppointmentsTable(list) {
        const tbody = document.getElementById("appointmentsBodyCombined");
        tbody.innerHTML = "";
        if (!list || !list.length) {
          tbody.innerHTML =
            '<tr><td colspan="9" class="text-center text-muted py-4">No appointments found.</td></tr>';
          document.getElementById("appointmentsCountCombined").innerText =
            "0 appointments";
          return;
        }
        list.slice(0, 200).forEach((a) => {
          const tr = document.createElement("tr");
          const date = a.bookingDate || a.date || a.start || new Date();
          tr.innerHTML = `<td>${new Date(date).toLocaleDateString()}</td><td>${a.startTime || a.time || ""}</td><td><strong>${a.customerName || (a.customer && a.customer.name) || a.customer || "Customer"}</strong><div class='small text-muted'>${a.customerEmail || ""}</div></td><td>${a.service || a.serviceType || (a.serviceId && (a.serviceId.name || a.serviceId.title)) || ""}</td><td>${a.technicianName || (a.technician && a.technician.name) || a.technician || (a.technician && a.technician._id) || "TBD"}</td><td>${(() => {
            if (a.location && a.location.address) return a.location.address;
            if (
              a.location &&
              a.location.coordinates &&
              Array.isArray(a.location.coordinates.coordinates)
            ) {
              const [lng, lat] = a.location.coordinates.coordinates;
              return lat + ", " + lng;
            }
            return a.address || "";
          })()}</td><td><span class='badge bg-${a.status === "confirmed" ? "success" : a.status === "pending" ? "warning" : "secondary"}'>${a.status || "n/a"}</span></td><td><div class='d-flex gap-2'><button class='btn btn-sm btn-outline-secondary view-appt' data-id='${a._id || a.id || ""}' title='View'><i class='bi bi-eye'></i></button><button class='btn btn-sm btn-outline-secondary edit-appt' data-id='${a._id || a.id || ""}' title='Edit'><i class='bi bi-pencil'></i></button></div></td>`;
          tbody.appendChild(tr);
        });
        document.getElementById("appointmentsCountCombined").innerText =
          `${list.length} shown`; // wire buttons
        qsa(".view-appt").forEach((b) =>
          b.addEventListener("click", onViewAppt),
        );
        qsa(".edit-appt").forEach((b) =>
          b.addEventListener("click", onEditAppt),
        );


      }

      async function onViewAppt(e) {
        // ensure Leaflet assets are available (only once)
        if (!window.L) {
          const css = document.createElement('link');
          css.rel = 'stylesheet';
          css.href = 'https://cdn.jsdelivr.net/npm/leaflet/dist/leaflet.css';
          document.head.appendChild(css);
          const s = document.createElement('script');
          s.src = 'https://cdn.jsdelivr.net/npm/leaflet/dist/leaflet.js';
          document.head.appendChild(s);
          await new Promise((r) => { s.onload = r; });
        }
        const modalTitle = document.querySelector(
          "#apptsSharedModal .modal-title",
        );
        if (modalTitle) modalTitle.textContent = "Appointment";
        document.getElementById("apptsModalEdit").style.display =
          "inline-block";
        const id = e.currentTarget.getAttribute("data-id");
        let appt =
          combinedAppointments.find((x) => (x._id || x.id || "") == id) || {};
        // attempt to load fresh user profile if we have customerId
        if (appt.customerId) {
          try {
            const r = await fetch(`/api/users/${encodeURIComponent(
              appt.customerId,
            )}`, { credentials: "same-origin" });
            if (r.ok) {
              const info = await r.json();
              appt.customer = info; // merge into appointment for display
              const cname = info.name || info.fullName || ((info.firstName || "") + " " + (info.lastName || "")).trim();
              if (cname) appt.customerName = cname;
            }
          } catch (err) {
            console.warn("failed to fetch user profile", err);
          }
        }
        // fill technician name from snapshot if available
        if (!appt.technicianName) {
          if (appt.technician && appt.technician.name) {
            appt.technicianName = appt.technician.name;
          } else if (appt.technician && appt.technician._id) {
            // we'll try fetch below using this id
          }
        }
        // attempt to populate technician name by looking up the user record
        const techLookupId = appt.technicianId || (appt.technician && appt.technician._id);
        if (techLookupId && !appt.technicianName) {
          try {
            const r = await fetch(`/api/users/${encodeURIComponent(techLookupId)}`, { credentials: "same-origin" });
            if (r.ok) {
              const info = await r.json();
              const tname = info.name || info.fullName || ((info.firstName || "") + " " + (info.lastName || "")).trim();
              if (tname) appt.technicianName = tname;
            }
          } catch (err) {
            console.warn("failed to fetch technician user", err);
          }
        }
        // if we have an assigned technician but no name snapshot, fetch list and fill
        if (appt.technicianId && !appt.technicianName) {
          try {
            const r = await fetch("/api/admin/technicians", {
              credentials: "same-origin",
            });
            if (r.ok) {
              const j = await r.json();
              const techs = j.technicians || [];
              const found = techs.find((t) => String(t._id) === String(appt.technicianId));
              if (found && found.name) {
                appt.technicianName = found.name;
              }
            }
          } catch (err) {
            console.warn("failed to fetch technician list", err);
          }
        }
        // helper for distance
        function haversine(lat1, lon1, lat2, lon2) {
          function toRad(v) { return (v * Math.PI) / 180; }
          const R = 6371; // km
          const dLat = toRad(lat2 - lat1);
          const dLon = toRad(lon2 - lon1);
          const a =
            Math.sin(dLat/2) * Math.sin(dLat/2) +
            Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
            Math.sin(dLon/2) * Math.sin(dLon/2);
          const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
          return R * c;
        }
        if (window.hideBackdrop) hideBackdrop();
        const serviceName =
          (appt.service && typeof appt.service === "object"
            ? (appt.service.name || appt.service.title || appt.service.serviceName)
            : appt.service) ||
          (appt.serviceId && typeof appt.serviceId === "object"
            ? (appt.serviceId.name || appt.serviceId.title)
            : "") ||
          appt.serviceType ||
          appt.title ||
          "Booking";
        const serviceDescription =
          (appt.serviceId && typeof appt.serviceId === "object" && appt.serviceId.description) ||
          (appt.service && typeof appt.service === "object" && appt.service.description) ||
          appt.issueDescription ||
          "";
        const bookingDateText = formatDate(appt.bookingDate || appt.date || "") || "—";
        const startTimeText = formatTime(appt.startTime || appt.time || "") || "—";
        const startMinNum = Number(appt.startTime ?? appt.time);
        const endMinNumRaw = Number(appt.endTime);
        const fallbackDuration =
          (Number(appt.serviceDurationMinutes) || 0) +
          Math.max(0, Number(appt.travelTime) || 0);
        const endMinNum =
          Number.isFinite(endMinNumRaw) && endMinNumRaw > startMinNum
            ? endMinNumRaw
            : Number.isFinite(startMinNum) && fallbackDuration > 0
              ? startMinNum + fallbackDuration
              : NaN;
        const timeRangeText =
          Number.isFinite(startMinNum) && Number.isFinite(endMinNum)
            ? `${formatTime(startMinNum)} – ${formatTime(endMinNum)}`
            : startTimeText;
        const serviceFeeVal = Number(
          appt.servicePrice ?? appt.service?.basePrice ?? appt.serviceId?.basePrice,
        );
        const distanceFareVal = Number(appt.travelFare);
        const estimatedFeeVal = computeTotalEstimatedFee(appt);
        const serviceFeeText = Number.isFinite(serviceFeeVal)
          ? "₱" + serviceFeeVal.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
          : "—";
        const distanceFareText = Number.isFinite(distanceFareVal)
          ? "₱" + distanceFareVal.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
          : "—";
        const estimatedFeeText = Number.isFinite(estimatedFeeVal)
          ? "₱" + Number(estimatedFeeVal).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })
          : "—";

        let locationAddressText = (() => {
          const source = appt?.location?.address ?? appt?.location ?? appt?.address;
          if (!source) return "—";
          if (typeof source === "string") return source.trim() || "—";
          if (typeof source === "object") {
            const parts = Object.values(source)
              .filter((v) => v !== null && v !== undefined && String(v).trim() !== "")
              .map((v) => String(v).trim());
            return parts.length ? parts.join(", ") : "—";
          }
          return "—";
        })();
        const _clng = Number(appt?.location?.coordinates?.coordinates?.[0]);
        const _clat = Number(appt?.location?.coordinates?.coordinates?.[1]);
        // if address text is just "lat,lng", fetch display_name so users see real address
        if (
          typeof locationAddressText === "string" &&
          /^\s*-?\d+(?:\.\d+)?\s*,\s*-?\d+(?:\.\d+)?\s*$/.test(locationAddressText) &&
          Number.isFinite(_clat) && Number.isFinite(_clng)
        ) {
          try {
            const rg = await fetch(
              `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${_clat}&lon=${_clng}`,
            );
            if (rg.ok) {
              const data = await rg.json();
              if (data && data.display_name) {
                locationAddressText = data.display_name;
              }
            }
          } catch (e) {
            // keep fallback text if reverse geocode fails
          }
        }
        // build a structured display with sections
        let html = `<div class="appt-detail-grid">
            <div class="section-header" style="grid-column:1/-1;font-weight:600;">Service Information</div>
            <span class="appt-detail-label">Service</span><span class="appt-detail-val">${serviceName}</span>
        `;
        if (serviceDescription) {
          html += `<span class="appt-detail-label">Description</span><span class="appt-detail-val">${serviceDescription}</span>`;
        }
        html += `<span class="appt-detail-label">Service fee</span><span class="appt-detail-val">${serviceFeeText}</span>`;
        html += `<span class="appt-detail-label">Distance fare</span><span class="appt-detail-val">${distanceFareText}</span>`;
        html += `<span class="appt-detail-label">Estimated fee</span><span class="appt-detail-val">${estimatedFeeText}</span>`;
        html += `<div class="section-header" style="grid-column:1/-1;font-weight:600;">Schedule</div>
            <span class="appt-detail-label">Date</span><span class="appt-detail-val">${bookingDateText}</span>
          <span class="appt-detail-label">Time</span><span class="appt-detail-val">${timeRangeText}</span>
