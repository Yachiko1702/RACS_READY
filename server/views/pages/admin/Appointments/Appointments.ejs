        }
        if (raw.technicianId && !raw.technicianName) {
          try {
            const r = await fetch(`/api/users/${encodeURIComponent(raw.technicianId)}`, { credentials: "same-origin" });
            if (r.ok) {
              const info = await r.json();
              const tname = info.name || info.fullName || ((info.firstName || "") + " " + (info.lastName || "")).trim();
              if (tname) raw.technicianName = tname;
