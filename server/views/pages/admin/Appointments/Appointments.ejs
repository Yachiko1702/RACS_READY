      // format a value into a human-readable date (and optionally time)
      function formatDate(value, includeTime = false) {
        if (!value) return "";
        const d = new Date(value);
        if (Number.isNaN(d.getTime())) return String(value);
        // use locale settings for a polished look
        try {
          if (includeTime) {
            return d.toLocaleString(undefined, { dateStyle: "long", timeStyle: "short" });
          }
          return d.toLocaleDateString(undefined, { dateStyle: "long" });
        } catch (e) {
          return d.toISOString().slice(0, includeTime ? 16 : 10);
        }
      }
      // convert minute-of-day or time string into human-friendly time
      function formatTime(value) {
        if (value === null || value === undefined || value === "") return "";
        let mins = parseInt(value, 10);
        if (isNaN(mins)) {
          // maybe already a string like "14:30"
          const d = new Date("1970-01-01T" + value);
          if (!isNaN(d.getTime())) return d.toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" });
          return String(value);
        }
        const h = Math.floor(mins / 60) % 24;
        const m = mins % 60;
        const d = new Date();
        d.setHours(h, m, 0, 0);
        return d.toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" });
      }

      function formatDurationMinutes(value) {
        const mins = Number(value);
        if (!Number.isFinite(mins) || mins <= 0) return "—";
        if (mins < 60) return `${mins} min`;
        const h = Math.floor(mins / 60);
        const m = mins % 60;
        return m ? `${h}h ${m}m` : `${h}h`;
      }

      function computeTotalEstimatedFee(record) {
        const serviceFee = Number(
          record?.servicePrice ?? record?.service?.basePrice ?? record?.serviceId?.basePrice,
        );
        const distanceFare = Number(record?.travelFare);
        const storedEstimated = Number(record?.estimatedFee);

        if (Number.isFinite(serviceFee) && Number.isFinite(distanceFare)) {
          return serviceFee + distanceFare;
        }
        if (Number.isFinite(storedEstimated)) {
          return storedEstimated;
        }
        if (Number.isFinite(serviceFee)) {
          return serviceFee;
        }
        return null;
      }

      function normalizeRequest(rq, index = 0) {
        const id = rq._id || rq.id || rq.bookingId || `req-${index + 1}`;
        const date =
          rq.bookingDate || rq.date || rq.preferredDate || rq.createdAt;
        const time = rq.startTime || rq.time || rq.preferredTime || "";
        // derive service name from whatever is available
        let serviceName = "";
        if (rq.service) {
          if (typeof rq.service === "string") {
            serviceName = rq.service;
          } else if (rq.service.name) {
            serviceName = rq.service.name;
          } else if (rq.service.title) {
            serviceName = rq.service.title;
          } else {
            serviceName = JSON.stringify(rq.service);
          }
        }
        if (!serviceName && rq.serviceType) serviceName = rq.serviceType;
        if (!serviceName && rq.serviceId) {
          if (typeof rq.serviceId === "string") serviceName = rq.serviceId;
          else if (rq.serviceId.name) serviceName = rq.serviceId.name;
          else if (rq.serviceId.title) serviceName = rq.serviceId.title;
        }
        if (!serviceName) serviceName = "General Service";
        // prepare a human-friendly location string
        let loc = "";
        if (rq.location) {
          if (typeof rq.location === "string") {
            loc = rq.location;
          } else if (rq.location.address) {
            if (typeof rq.location.address === "object") {
              loc = Object.values(rq.location.address)
                .filter((v) => v != null && v !== "")
                .join(", ");
            } else {
              loc = rq.location.address;
            }
          }
        }
        if ((!loc || loc === "") && rq.address) {
          if (typeof rq.address === "object") {
            loc = Object.values(rq.address)
              .filter((v) => v != null && v !== "")
              .join(", ");
          } else {
            loc = rq.address;
          }
        }
        const feeVal = computeTotalEstimatedFee(rq);
        const etaVal = rq.travelTime != null && rq.travelTime !== "" ? Number(rq.travelTime) : null;
        const techName = rq.technicianName || (rq.technician && rq.technician.name) || "";
        const techId = rq.technicianId || (rq.technician && rq.technician._id) || "";
        // customer name may be object
        let custName = "";
        if (rq.customerName) {
          custName = rq.customerName;
        } else if (rq.customer) {
          if (typeof rq.customer === "string") {
            custName = rq.customer;
          } else if (rq.customer.name) {
            custName = rq.customer.name;
          } else if (rq.customer.firstName || rq.customer.lastName) {
            custName = `${rq.customer.firstName || ""} ${rq.customer.lastName || ""}`.trim();
          } else {
            custName = JSON.stringify(rq.customer);
          }
        } else if (rq.name) {
          custName = rq.name;
        } else {
          custName = "Customer";
        }
        return {
          id,
          raw: rq,
          customerName: custName,
          customerEmail: rq.customerEmail || rq.email || "",
          service: serviceName,
          date,
          time,
          location: loc,
          estimatedFee: feeVal,
          travelTime: Number.isFinite(etaVal) ? etaVal : "",
          serviceDurationMinutes: rq.serviceDurationMinutes || rq.durationMinutes || rq.duration || "",
          bookingReference: rq.bookingReference || rq.reference || "",
          technicianName: techName,
          technicianId: techId,
          status: statusLabel(rq.status),
          paymentMethod: rq.paymentMethod || "",
          gcashNumber: rq.gcashNumber || "",
          paymentReference: rq.paymentReference || "",
          downpaymentAmount: rq.downpaymentAmount || "",
          createdAt: rq.createdAt || rq.updatedAt || date,
        };
      }

      function renderBookingRequests() {
        const body = document.getElementById("requestsTableBodyCombined");
        if (!body) return;

        const search = (
          document.getElementById("requestSearchCombined")?.value || ""
        )
          .trim()
          .toLowerCase();
        const statusFilter = (
          document.getElementById("requestStatusCombined")?.value || "all"
        )
          .trim()
          .toLowerCase();

        const filtered = bookingRequests.filter((rq) => {
          const hay =
            `${rq.id} ${rq.customerName} ${rq.customerEmail} ${rq.service}`.toLowerCase();
          const matchSearch = !search || hay.includes(search);
          const matchStatus =
            statusFilter === "all" || rq.status === statusFilter;
          return matchSearch && matchStatus;
        });

        body.innerHTML = "";
        if (!filtered.length) {
          body.innerHTML =
            '<tr><td colspan="7" class="text-center text-muted py-4">No requests matched your current filters.</td></tr>';
        } else {
          filtered.forEach((rq) => {
            const tr = document.createElement("tr");
            const canValidate = rq.status === "pending";
            tr.innerHTML = `
              <td class="text-nowrap">${rq.bookingReference || rq.id}</td>
              <td class="text-start">
                <button type="button" class="request-customer-btn view-req-details" data-id="${rq.id}">${rq.customerName}</button>
                <div class="small text-muted">${rq.customerEmail || "—"}</div>
              </td>
              <td class="text-start text-truncate" style="max-width:160px;">${rq.service}</td>
              <td class="text-end">${rq.estimatedFee != null ? '₱' + Number(rq.estimatedFee).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) : "—"}</td>
              <td class="text-end">${rq.travelTime ? rq.travelTime + ' min' : '—'}</td>
              <td class="text-start">${formatDate(rq.date) || "—"} ${formatTime(rq.time)}</td>
              <td class="text-start">${rq.paymentMethod || ""}${rq.paymentReference ? ` (${rq.paymentReference})` : ""}</td>
              <td class="text-center"><span class="badge req-status bg-${statusBadgeClass(rq.status)}">${rq.status}</span></td>
              <td class="text-start">
                <div class="d-flex gap-2 flex-wrap">
                  <button class="btn btn-sm btn-outline-secondary view-req-details" data-id="${rq.id}">Details</button>
                  <button class="btn btn-sm btn-outline-success approve-req" data-id="${rq.id}" ${canValidate ? "" : "disabled"}>Approve</button>
                  <button class="btn btn-sm btn-outline-danger reject-req" data-id="${rq.id}" ${canValidate ? "" : "disabled"}>Cancel</button>
                </div>
              </td>
            `;
            body.appendChild(tr);
          });
        }

        document.getElementById("requestsCountCombined").innerText =
          `${filtered.length} request${filtered.length === 1 ? "" : "s"} shown`;

        qsa(".view-req-details").forEach((b) =>
          b.addEventListener("click", function () {
            const id = this.getAttribute("data-id");
            const rq = bookingRequests.find((x) => x.id === id);
            openBookingRequestDetails(rq);
          }),
        );

        qsa(".approve-req").forEach((b) =>
          b.addEventListener("click", async function () {
            const id = this.getAttribute("data-id");
            await processBookingRequest(id, "approve");
          }),
        );

        qsa(".reject-req").forEach((b) =>
          b.addEventListener("click", async function () {
            const id = this.getAttribute("data-id");
            await processBookingRequest(id, "cancel");
          }),
        );
      }

      async function processBookingRequest(id, action) {
        if (!id) return;
        const isCancel = action === "cancel";
        if (isCancel && !confirm("Cancel this booking request?")) return;
        try {
          const res = await fetch(
            `/appointments/${encodeURIComponent(id)}/${action}`,
            { method: "POST", credentials: "same-origin" },
          );
          if (res.ok) {
            window.notify?.success(
              isCancel ? "Request cancelled" : "Request approved",
            );
            await loadBookingRequests();
            await loadCombinedOverview();
          } else {
            const t = await res.text();
            window.notify?.error(
              `Failed to ${isCancel ? "cancel" : "approve"}: ${t}`,
            );
          }
        } catch (e) {
          window.notify?.error(`Failed to ${isCancel ? "cancel" : "approve"}`);
        }
      }

      // Booking requests validation queue
      async function loadBookingRequests() {
        try {
          const r = await fetch("/api/appointments?requests=1&limit=200", {
            credentials: "same-origin",
          });
          let reqs = [];
          if (r.ok) {
            const j = await r.json();
            reqs = j.items || j.requests || [];
          }
          bookingRequests = (reqs || []).map((rq, idx) =>
            normalizeRequest(rq, idx),
          );
          renderBookingRequests();
        } catch (e) {
          console.warn(e);
          bookingRequests = [];
          renderBookingRequests();
        }
      }

      // Reschedule submission
      document
        .getElementById("rescheduleSubmit")
        .addEventListener("click", async function (e) {
          e.preventDefault();
          const select = document.getElementById("rescheduleSelect");
          const val = select.value;
          if (!val) {
            window.notify.warn("Select an appointment first");
            return;
          }
          const date = document.getElementById("rescheduleDate").value;
          const time = document.getElementById("rescheduleTime").value;
          if (!date || !time) {
            alert("Select date and time");
            return;
          }
          const payload = {
            bookingDate: date,
            startTime: time,
            reason: document.getElementById("rescheduleReason").value || "",
          };
          // attempt to extract id
          const id = val.startsWith("{")
            ? JSON.parse(val)._id || JSON.parse(val).id
            : val;
          try {
            const r = await fetch("/appointments/" + encodeURIComponent(id), {
              method: "PUT",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
              credentials: "same-origin",
            });
            if (r.ok) {
              window.notify.success("Appointment rescheduled");
              loadCombinedOverview();
            } else {
              const t = await r.text();
              window.notify.error("Failed: " + t);
            }
          } catch (err) {
            window.notify.error("Failed");
          }
        });

      // wire controls
      const refreshBtn = document.getElementById("btn-refresh-combined");
      if (refreshBtn) {
        refreshBtn.addEventListener("click", () => {
          loadCombinedOverview();
          loadBookingRequests();
        });
      }
      const refreshAllBtn = document.getElementById("apptsRefreshAll");
      if (refreshAllBtn) {
        refreshAllBtn.addEventListener("click", () => {
          loadCombinedOverview();
          loadBookingRequests();
        });
      }
      ["requestSearchCombined", "requestStatusCombined"].forEach((id) => {
        const node = document.getElementById(id);
        if (!node) return;
        const evt = id === "requestStatusCombined" ? "change" : "input";
        node.addEventListener(evt, renderBookingRequests);
      });
      document
        .getElementById("requestRefreshCombined")
        ?.addEventListener("click", loadBookingRequests);

      // initial load
      loadCombinedOverview();

      // if URL contains ?sel=<id> open Reschedule tab and preselect the appointment
      (function preselectFromQuery() {
        try {
          const params = new URLSearchParams(location.search);
          const sel = params.get("sel") || params.get("id");
          if (!sel) return;
          let tries = 0;
          const trySelect = () => {
            tries++;
            if (
              typeof combinedAppointments !== "undefined" &&
              combinedAppointments.length
            ) {
              // reuse existing onEditAppt logic by simulating a click-event object
              try {
                onEditAppt({ currentTarget: { getAttribute: () => sel } });
              } catch (e) {
                /* ignore */
              }
              const tabBtn = document.querySelector(
                '#apptsTabs [data-tab="tab-reschedule"]',
              );
              if (tabBtn) tabBtn.click();
            } else if (tries < 20) {
              setTimeout(trySelect, 150);
            }
          };
          setTimeout(trySelect, 200);
        } catch (e) {
          /* ignore */
        }
      })();
    })();
  </script>
</div>
