            .filter((n) => !isNaN(n));
          if (nums.length >= 2) {
            // assume location string is lat,lon
            coordsArray = [nums[1], nums[0]];
          }
        }
        const hasCoords = coordsArray && coordsArray.length >= 2;
        const coordinates = hasCoords ? coordsArray.join(", ") : "—";

        const feeVal = computeTotalEstimatedFee(raw);
        const serviceFeeVal = Number(raw.servicePrice ?? raw.service?.basePrice ?? raw.serviceId?.basePrice);
        const distanceFareVal = Number(raw.travelFare);
        // travelTime may be stored as undefined when it was 0 at booking time
        // fallback: compute from coordinates using same 40 km/h assumption
        let travelMins = Number(raw.travelTime);
        if (!Number.isFinite(travelMins) || travelMins <= 0) {
          const custCoords = raw?.location?.coordinates?.coordinates;
          const techCoords = raw?.technicianLocation?.coordinates?.coordinates;
          if (
            Array.isArray(custCoords) && custCoords.length >= 2 &&
            Array.isArray(techCoords) && techCoords.length >= 2
          ) {
            const [clng, clat] = custCoords;
            const [tlng, tlat] = techCoords;
            if (Number.isFinite(clat) && Number.isFinite(clng) && Number.isFinite(tlat) && Number.isFinite(tlng)) {
              const toRad = v => (v * Math.PI) / 180;
              const R = 6371;
              const dLat = toRad(tlat - clat), dLon = toRad(tlng - clng);
              const a = Math.sin(dLat/2)**2 + Math.cos(toRad(clat))*Math.cos(toRad(tlat))*Math.sin(dLon/2)**2;
              const km = R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
              const eta = Math.round((km / 40) * 60);
