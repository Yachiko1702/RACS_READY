<div class="admin-dashboard container-fluid py-4 appointments-combined">
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap");
    /* =============================================
       Admin Dashboard – Professional Redesign
       ============================================= */
    :root {
      --dash-primary: #4361ee;
      --dash-primary-light: rgba(67, 97, 238, 0.1);
      --dash-success: #2ec4b6;
      --dash-warning: #ff9f1c;
      --dash-danger: #e63946;
      --dash-purple: #7b2d8b;
      --dash-dark: #212529;
      --dash-card-radius: 14px;
      --dash-card-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
      --dash-hover-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
      --dash-section-title: 0.8rem;
      --dash-hero-bg: linear-gradient(120deg, #2f49a1 0%, #2d0482 100%);
    }
    .admin-dashboard {
      font-family: "Poppins", "Inter", "Segoe UI", sans-serif;
      color: #212529;
      background: #f5f6fa;
    }

    /* ---- HERO HEADER ---- */
    .admin-dashboard .dashboard-hero {
      background: var(--dash-hero-bg);
      border-radius: var(--dash-card-radius);
      padding: 28px 32px;
      box-shadow: 0 8px 32px rgba(67, 97, 238, 0.18);
      position: relative;
      overflow: hidden;
      color: #fff;
    }
    .admin-dashboard .dashboard-hero::before {
      content: "";
      position: absolute;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.06);
      top: -60px;
      right: -60px;
      pointer-events: none;
    }
    .admin-dashboard .dashboard-hero::after {
      content: "";
      position: absolute;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.04);
      bottom: -40px;
      left: 40px;
      pointer-events: none;
    }
    .admin-dashboard .page-title {
      font-size: 1.55rem;
      font-weight: 800;
      letter-spacing: -0.3px;
      margin: 0;
      color: #fff;
    }
    .admin-dashboard .hero-email {
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.82);
      margin: 2px 0 0;
    }
    .admin-dashboard .hero-sub {
      font-size: 0.78rem;
      color: rgba(255, 255, 255, 0.58);
      margin: 2px 0 0;
    }
    .admin-dashboard .hero-avatar {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
      border: 2px solid rgba(255, 255, 255, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.1rem;
      color: #fff;
      flex-shrink: 0;
    }
    .admin-dashboard .hero-status-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #2ec4b6;
      border: 2px solid #fff;
      display: inline-block;
      margin-right: 5px;
    }
    .admin-dashboard .hero-status {
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.75);
      display: flex;
      align-items: center;
      margin-top: 8px;
    }
    /* hero action buttons */
    .admin-dashboard .hero-btn {
      background: rgba(255, 255, 255, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.3);
      color: #fff;
      border-radius: 8px;
      padding: 0.35rem 0.9rem;
      font-size: 0.8rem;
      font-weight: 600;
      backdrop-filter: blur(4px);
      transition: background 0.2s;
    }
    .admin-dashboard .hero-btn:hover {
      background: rgba(255, 255, 255, 0.25);
      color: #fff;
    }
    .admin-dashboard .hero-btn-primary {
      background: rgba(255, 255, 255, 0.95);
      color: var(--dash-primary) !important;
      border: none;
    }
    .admin-dashboard .hero-btn-primary:hover {
      background: #fff;
      color: var(--dash-primary) !important;
    }

    /* ---- SECTION LABEL ---- */
    .admin-dashboard .section-label {
      font-size: var(--dash-section-title);
      font-weight: 800;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #9ba3af;
      margin-bottom: 10px;
    }

    /* ---- KPI CARDS ---- */
    .admin-dashboard .kpi-card {
      border: 0;
      border-radius: var(--dash-card-radius);
      box-shadow: var(--dash-card-shadow);
      background: #fff;
      padding: 18px 20px;
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease;
      position: relative;
      overflow: hidden;
    }
    .admin-dashboard .kpi-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--dash-hover-shadow);
    }
    .admin-dashboard .kpi-card .kpi-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      flex-shrink: 0;
      color: #fff;
    }
    .admin-dashboard .kpi-card .kpi-label {
      font-size: 0.74rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #9ba3af;
      line-height: 1.2;
    }
    .admin-dashboard .kpi-card .kpi-value {
      font-size: 1.65rem;
      font-weight: 800;
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-top: 2px;
    }
    .admin-dashboard .kpi-card .kpi-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: 0 0 var(--dash-card-radius) var(--dash-card-radius);
    }

    /* ---- GENERIC CONTENT CARD ---- */
    .admin-dashboard .dash-card {
      border: 0;
      border-radius: var(--dash-card-radius);
      box-shadow: var(--dash-card-shadow);
      background: #fff;
      overflow: hidden;
      transition: box-shadow 0.18s;
    }
    .admin-dashboard .dash-card:hover {
      box-shadow: var(--dash-hover-shadow);
    }
    .admin-dashboard .dash-card .card-header-custom {
      padding: 16px 20px 12px;
      border-bottom: 1px solid #f1f3f7;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .admin-dashboard .dash-card .card-header-custom h5,
    .admin-dashboard .dash-card .card-header-custom h6 {
      font-size: 0.95rem;
      font-weight: 700;
      margin: 0;
      color: #212529;
    }
    .admin-dashboard .dash-card .card-header-custom .card-meta {
      font-size: 0.72rem;
      color: #9ba3af;
      font-weight: 500;
    }
    .admin-dashboard .dash-card .card-body-custom {
      padding: 16px 20px;
    }

    /* ---- LIST ITEMS ---- */
    .admin-dashboard .dash-list-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 0;
      border-bottom: 1px solid #f1f3f7;
    }
    .admin-dashboard .dash-list-item:last-child {
      border-bottom: none;
    }
    .admin-dashboard .dash-list-icon {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      flex-shrink: 0;
    }
    .admin-dashboard .dash-list-item .item-title {
      font-size: 0.83rem;
      font-weight: 600;
      color: #212529;
      line-height: 1.3;
    }
    .admin-dashboard .dash-list-item .item-sub {
      font-size: 0.72rem;
      color: #9ba3af;
      margin-top: 1px;
    }
    .admin-dashboard .dash-empty {
      text-align: center;
      padding: 24px 0;
      color: #c4c9d4;
      font-size: 0.82rem;
    }
    .admin-dashboard .dash-empty i {
      font-size: 1.6rem;
      display: block;
      margin-bottom: 6px;
    }

    /* ---- ACTIVITY FEED ---- */
    .admin-dashboard .activity-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--dash-primary);
      flex-shrink: 0;
      margin-top: 5px;
    }

    /* ---- QUICK ACTIONS ---- */
    .admin-dashboard .quick-action-btn {
      border-radius: 10px;
      padding: 0.38rem 0.85rem;
      font-size: 0.8rem;
      font-weight: 600;
      border: 1.5px solid #e5e7eb;
      background: #fff;
      color: #374151;
      transition: all 0.17s;
    }
    .admin-dashboard .quick-action-btn:hover {
      border-color: var(--dash-primary);
      color: var(--dash-primary);
      background: var(--dash-primary-light);
    }
    .admin-dashboard .quick-action-btn-primary {
      background: var(--dash-primary);
      border-color: var(--dash-primary);
      color: #fff;
    }
    .admin-dashboard .quick-action-btn-primary:hover {
      background: #3451d1;
      border-color: #3451d1;
      color: #fff;
    }

    /* ---- BADGE PILL ---- */
    .admin-dashboard .status-pill {
      font-size: 0.68rem;
      font-weight: 700;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      letter-spacing: 0.03em;
    }

    /* ---- CALENDAR ---- */
    .admin-dashboard #mini-calendar .cal-day {
      text-align: center;
      font-size: 12px;
      padding: 5px 2px;
      border-radius: 8px;
      color: #374151;
      font-weight: 500;
    }
    .admin-dashboard #mini-calendar .cal-day.today {
      background: var(--dash-primary);
      color: #fff;
      font-weight: 700;
    }

    @media (max-width: 767px) {
      .admin-dashboard .dashboard-hero {
        padding: 20px 18px;
      }
      .admin-dashboard .page-title {
        font-size: 1.25rem;
      }
      .admin-dashboard .kpi-card .kpi-value {
        font-size: 1.3rem;
      }
    }

    /* Unified Appointments UI */
    .appointments-combined .tabs {
      margin-bottom: 16px;
      background: #fff;
      border: 1px solid rgba(2, 6, 23, 0.08);
      border-radius: 12px;
      padding: 8px;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
    }
    .appointments-combined .tabs .nav-link {
      border: 0;
      color: var(--dash-dark);
      font-weight: 600;
      border-radius: 8px;
      padding: 8px 12px;
      transition: background 0.2s;
    }
    .appointments-combined .tabs .nav-link.active {
      background: var(--dash-primary);
      color: #fff;
      box-shadow: 0 8px 18px rgba(67, 97, 238, 0.28);
    }

    /* always-show colored backgrounds for each tab; full saturation and white text */
    .appointments-combined .tabs .nav-link[data-tab="tab-list"] {
      background: #4361ee;
      color: #fff;
      border: 1px solid #4361ee;
    }
    .appointments-combined .tabs .nav-link[data-tab="tab-requests"] {
      background: #ff9f1c;
      color: #fff;
      border: 1px solid #ff9f1c;
    }
    .appointments-combined .tabs .nav-link[data-tab="tab-reschedule"] {
      background: #2ec4b6;
      color: #fff;
      border: 1px solid #2ec4b6;
    }

    /* maintain tint on hover */
    .appointments-combined .tabs .nav-link:hover {
      filter: brightness(0.9);
    }

    .appts-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 16px;
    }
    .appointments-combined .appts-grid > section {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .panel-card {
      background: #fff;
      border-radius: 14px;
      padding: 14px;
      box-shadow: 0 10px 26px rgba(2, 6, 23, 0.05);
      border: 1px solid rgba(2, 6, 23, 0.08);
    }

    /* KPI strip inside list tab */
    .appts-kpis {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 12px;
    }
    .appts-kpi {
      background: linear-gradient(180deg, #fff, #fbfdff);
      padding: 12px;
      border-radius: 10px;
      display: flex;
      gap: 12px;
      align-items: center;
    }
    .appts-kpi .icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .appts-kpi .meta {
      font-size: 12px;
      color: #6b7280;
    }
    .appts-kpi .value {
      font-weight: 700;
      font-size: 1.1rem;
    }

    /* compact table / controls */
    .appts-controls {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
      padding: 8px;
      background: #f8fafc;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 10px;
    }
    .appts-controls .form-control,
    .appts-controls .form-select {
      min-width: 160px;
      border-radius: 10px;
      border-color: rgba(100, 116, 139, 0.35);
    }

    /* booking requests */
    .requests-controls {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .requests-controls .form-control,
    .requests-controls .form-select {
      min-width: 150px;
      border-radius: 10px;
      border-color: rgba(100, 116, 139, 0.35);
    }
    .req-status {
      text-transform: capitalize;
      font-weight: 600;
      letter-spacing: 0.2px;
    }
    .request-customer-btn {
      padding: 0;
      border: 0;
      background: transparent;
      color: #0d6efd;
      font-weight: 700;
      text-decoration: none;
      text-align: left;
    }
    .request-customer-btn:hover {
      text-decoration: underline;
    }
    .requests-controls {
      padding: 8px;
      background: #f8fafc;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 10px;
    }
    .requests-filter-card .form-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      color: #64748b;
      letter-spacing: 0.3px;
      margin-bottom: 6px;
    }
    .appointments-combined .table thead th {
      background: #f8fafc;
      color: #334155;
      font-size: 12px;
      letter-spacing: 0.25px;
      text-transform: uppercase;
      border-bottom-width: 1px;
    }
    .appointments-combined .table tbody tr:hover {
      background: rgba(13, 110, 253, 0.04);
    }
    .request-detail-grid {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 8px 12px;
      font-size: 0.9rem;
    }
    .request-detail-grid .label {
      color: #64748b;
      font-weight: 600;
    }
    .request-detail-grid .value {
      color: #0f172a;
      word-break: break-word;
    }

    /* reschedule form */
    .reschedule-form .form-group {
      margin-bottom: 10px;
    }

    /* small helpers */
    .muted-small {
      font-size: 0.85rem;
      color: #6b7280;
    }
  </style>

