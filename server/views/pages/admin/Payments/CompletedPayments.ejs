<div class="admin-dashboard container-fluid py-4 payments-page">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-check-circle-fill me-2"></i>Completed Payments
        </h1>
        <p class="hero-sub">
          View settled transactions, receipts, and reconciliation-ready records
        </p>
      </div>
    </div>
  </div>

  <!-- original header removed -->

  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-4 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #2ec4b6, #1a8f85)"
          >
            <i class="bi bi-check-circle-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Completed Today</div>
            <div class="kpi-value" id="statCompletedToday">67</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #2ec4b6, #1a8f85)"
        ></div>
      </div>
    </div>
    <div class="col-md-4 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-cash-stack"></i>
          </div>
          <div>
            <div class="kpi-label">Settled Amount Today</div>
            <div class="kpi-value" id="statSettledAmount">₱ 412k</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
    <div class="col-md-4 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #ff7422)"
          >
            <i class="bi bi-clock-history"></i>
          </div>
          <div>
            <div class="kpi-label">Avg Settlement Time</div>
            <div class="kpi-value" id="statAvgTime">6.4h</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #ff7422)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Search</label
          >
          <input
            type="text"
            class="form-control bg-light"
            placeholder="Transaction ID, customer, invoice"
          />
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Payment Method</label
          >
          <select class="form-select">
            <option>All Methods</option>
            <option>GCash</option>
            <option>Cash</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Date Range</label
          >
          <input type="date" class="form-control" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-light border w-100">
            <i class="bi bi-funnel me-2"></i>Apply
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div
      class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center"
    >
      <h6 class="mb-0 fw-bold">Settled Transactions</h6>
      <span class="text-muted small">Last sync: just now</span>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Transaction</th>
            <th>Customer</th>
            <th>Invoice</th>
            <th>Method</th>
            <th>Amount</th>
            <th>Settled On</th>
            <th>Receipt</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">TXN-240218-901</div>
              <div class="small text-muted">Verified by Finance</div>
            </td>
            <td>
              <div class="fw-semibold">Alice Gomez</div>
              <div class="small text-muted">alice.gomez@gmail.com</div>
            </td>
            <td class="small text-muted">INV-99255</td>
            <td>
              <span
                class="badge bg-info-subtle text-info border border-info-subtle"
                >GCash</span
              >
            </td>
            <td class="fw-bold text-dark">₱ 5,800.00</td>
            <td class="small text-muted">Feb 18, 2026 03:26 PM</td>
            <td class="small text-success">
              <i class="bi bi-check-circle me-1"></i>Issued
            </td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-light border">
                <i class="bi bi-download"></i>
              </button>
            </td>
          </tr>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">TXN-240218-915</div>
              <div class="small text-muted">Auto-reconciled</div>
            </td>
            <td>
              <div class="fw-semibold">Corporate One Holdings</div>
              <div class="small text-muted">finance@corpone.ph</div>
            </td>
            <td class="small text-muted">INV-99273</td>
            <td>
              <span
                class="badge bg-primary-subtle text-primary border border-primary-subtle"
                >Bank</span
              >
            </td>
            <td class="fw-bold text-dark">₱ 46,200.00</td>
            <td class="small text-muted">Feb 18, 2026 04:50 PM</td>
            <td class="small text-success">
              <i class="bi bi-check-circle me-1"></i>Issued
            </td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-light border">
                <i class="bi bi-download"></i>
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white py-3 border-top">
      <ul class="pagination justify-content-end mb-0">
        <li class="page-item disabled">
          <a class="page-link" href="#">Previous</a>
        </li>
        <li class="page-item active"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">Next</a></li>
      </ul>
    </div>
  </div>
</div>
