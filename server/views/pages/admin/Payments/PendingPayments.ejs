<div class="admin-dashboard container-fluid py-4 payments-page">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-hourglass-split me-2"></i>Pending Payments
        </h1>
        <p class="hero-sub">
          Review unsettled or unverified transactions requiring admin action
        </p>
      </div>
    </div>
  </div>

  <!-- original header removed -->

  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-4 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #ff7422)"
          >
            <i class="bi bi-hourglass-split"></i>
          </div>
          <div>
            <div class="kpi-label">Awaiting Verification</div>
            <div class="kpi-value" id="statVerify">52</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #ff7422)"
        ></div>
      </div>
    </div>
    <div class="col-md-4 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #e63946, #b91c2a)"
          >
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Overdue &gt; 24h</div>
            <div class="kpi-value" id="statOverdue">11</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #e63946, #b91c2a)"
        ></div>
      </div>
    </div>
    <div class="col-md-4 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-person-badge"></i>
          </div>
          <div>
            <div class="kpi-label">Manual Review</div>
            <div class="kpi-value" id="statManual">23</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Search</label
          >
          <input
            type="text"
            class="form-control bg-light"
            placeholder="Customer, invoice, or transaction ID"
          />
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Queue Type</label
          >
          <select class="form-select">
            <option>All</option>
            <option>Verification Pending</option>
            <option>Proof Required</option>
            <option>Disputed</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Method</label
          >
          <select class="form-select">
            <option>All</option>
            <option>GCash</option>
            <option>Cash on Site</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-light border w-100">
            <i class="bi bi-funnel me-2"></i>Filter
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 border-bottom">
      <h6 class="mb-0 fw-bold">Verification Queue</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Transaction</th>
            <th>Customer</th>
            <th>Invoice</th>
            <th>Amount</th>
            <th>Method</th>
            <th>Submitted</th>
            <th>Priority</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">TXN-240219-023</div>
              <div class="small text-muted">Proof uploaded</div>
            </td>
            <td>
              <div class="fw-semibold">Robert Lim</div>
              <div class="small text-muted">robert.lim@gmail.com</div>
            </td>
            <td class="small text-muted">INV-99371</td>
            <td class="fw-bold">₱ 8,900.00</td>
            <td>
              <span
                class="badge bg-info-subtle text-info border border-info-subtle"
                >GCash</span
              >
            </td>
            <td class="small text-muted">Feb 19, 2026 09:11 AM</td>
            <td>
              <span
                class="badge bg-danger-subtle text-danger border border-danger-subtle"
                >High</span
              >
            </td>
            <td class="text-end pe-4">
              <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-success">Approve</button>
                <button class="btn btn-outline-danger">Reject</button>
              </div>
            </td>
          </tr>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">TXN-240219-028</div>
              <div class="small text-muted">Awaiting reference check</div>
            </td>
            <td>
              <div class="fw-semibold">Summit Tower Office</div>
              <div class="small text-muted">finance@summittower.ph</div>
            </td>
            <td class="small text-muted">INV-99385</td>
            <td class="fw-bold">₱ 24,500.00</td>
            <td>
              <span
                class="badge bg-primary-subtle text-primary border border-primary-subtle"
                >Bank</span
              >
            </td>
            <td class="small text-muted">Feb 19, 2026 11:33 AM</td>
            <td>
              <span
                class="badge bg-warning-subtle text-warning border border-warning-subtle"
                >Medium</span
              >
            </td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-outline-primary">
                Open Review
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
