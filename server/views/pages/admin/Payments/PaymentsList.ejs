<div class="admin-dashboard container-fluid py-4 payments-page">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-credit-card-2-front-fill me-2"></i>Payments Overview
        </h1>
        <p class="hero-sub">
          Monitor transactions, reconciliation status, and collection
          performance
        </p>
      </div>
      <!-- right side blank for future controls -->
    </div>
  </div>

  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-credit-card-2-front-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Total Transactions</div>
            <div class="kpi-value" id="statTotalTx">1,876</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #2ec4b6, #1a8f85)"
          >
            <i class="bi bi-cash-stack"></i>
          </div>
          <div>
            <div class="kpi-label">Collected (MTD)</div>
            <div class="kpi-value" id="statCollected">₱ 2.34M</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #2ec4b6, #1a8f85)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #ff7422)"
          >
            <i class="bi bi-hourglass-split"></i>
          </div>
          <div>
            <div class="kpi-label">Pending Verification</div>
            <div class="kpi-value" id="statPending">86</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #ff7422)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #e63946, #b91c2a)"
          >
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Failed Payments</div>
            <div class="kpi-value" id="statFailed">21</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #e63946, #b91c2a)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Search</label
          >
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"
              ><i class="bi bi-search text-muted"></i
            ></span>
            <input
              type="text"
              class="form-control border-start-0 bg-light"
              placeholder="Transaction ID, customer, or invoice #"
            />
          </div>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Status</label
          >
          <select class="form-select">
            <option>All</option>
            <option>Completed</option>
            <option>Pending</option>
            <option>Failed</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Method</label
          >
          <select class="form-select">
            <option>All</option>
            <option>GCash</option>
            <option>Bank Transfer</option>
            <option>Cash</option>
            <option>PayMongo</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Gateway</label
          >
          <select class="form-select">
            <option>All</option>
            <option>PayMongo</option>
            <option>Other</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Gateway status</label
          >
          <select class="form-select">
            <option>All</option>
            <option>succeeded</option>
            <option>processing</option>
            <option>failed</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Date</label
          >
          <input type="date" class="form-control" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-light border w-100">
            <i class="bi bi-funnel me-2"></i>Filter
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div
      class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center"
    >
      <h6 class="mb-0 fw-bold">Payment Transactions</h6>
      <span class="text-muted small">Realtime sync enabled</span>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Transaction</th>
            <th>Customer</th>
            <th>Invoice</th>
            <th>Method</th>
            <th>Gateway</th>
            <th>Gateway status</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Date</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">TXN-240219-001</div>
              <div class="small text-muted">Reference: 8473-2109</div>
            </td>
            <td>
              <div class="fw-semibold">Maria Santos</div>
              <div class="small text-muted">maria.santos@gmail.com</div>
            </td>
            <td class="small text-muted">INV-99314</td>
            <td>
              <span
                class="badge bg-info-subtle text-info border border-info-subtle"
                >GCash</span
              >
            </td>
            <td>PayMongo</td>
            <td>approved</td>
            <td class="fw-bold text-dark">₱ 6,500.00</td>
            <td>
              <span
                class="badge bg-success-subtle text-success border border-success-subtle"
                >Completed</span
              >
            </td>
            <td class="small text-muted">Feb 19, 2026 10:42 AM</td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-light border">
                <i class="bi bi-receipt"></i>
              </button>
            </td>
          </tr>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">TXN-240219-002</div>
              <div class="small text-muted">Reference: 9401-7812</div>
            </td>
            <td>
              <div class="fw-semibold">John Dela Cruz</div>
              <div class="small text-muted">john.delacruz@gmail.com</div>
            </td>
            <td class="small text-muted">INV-99315</td>
            <td>
              <span
                class="badge bg-primary-subtle text-primary border border-primary-subtle"
                >Bank</span
              >
            </td>
            <td class="fw-bold text-dark">₱ 3,200.00</td>
            <td>
              <span
                class="badge bg-warning-subtle text-warning border border-warning-subtle"
                >Pending</span
              >
            </td>
            <td class="small text-muted">Feb 19, 2026 11:05 AM</td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-outline-warning">Review</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white py-3 border-top">
      <ul class="pagination justify-content-end mb-0">
        <li class="page-item disabled">
          <a class="page-link" href="#">Previous</a>
        </li>
        <li class="page-item active"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">Next</a></li>
      </ul>
    </div>
  </div>
</div>
