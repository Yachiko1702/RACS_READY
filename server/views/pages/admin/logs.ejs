  <script>
    const PAGE_SIZE = 10;
    let allLogs = [];
    let filteredLogs = [];
    let currentPage = 1;

    function renderPage(page) {
      const start = (page - 1) * PAGE_SIZE;
      const slice = filteredLogs.slice(start, start + PAGE_SIZE);
      const t = document.getElementById("logs-table-body");
      if (slice.length === 0) {
        t.innerHTML = '<tr><td colspan="4" class="text-muted small">No logs found.</td></tr>';
      } else {
        const rows = slice
          .map((l, idx) => {
            const when = new Date(l.createdAt).toLocaleString();
            const actor = l.actorEmail || l.actorName || 'system';
            const details = (l.details && l.details.reason) ? l.details.reason : (l.details ? JSON.stringify(l.details) : '');
            const num = start + idx + 1;
            return `<tr><td class="small text-muted">${num}</td><td class="small text-muted">${when}</td><td class="small">${actor}</td><td class="small text-muted">${l.action}</td><td class="small text-muted">${details}</td></tr>`;
          })
          .join('');
        t.innerHTML = rows;
      }
      // update range label
      const rangeEl = document.getElementById('logs-range');
      const total = filteredLogs.length;
      const from = total === 0 ? 0 : start + 1;
      const to = Math.min(start + PAGE_SIZE, total);
      rangeEl.textContent = `${from} to ${to} of ${total}`;
      renderPagination();
    }

    function renderPagination() {
      const total = filteredLogs.length;
      const pages = Math.ceil(total / PAGE_SIZE);
      const ul = document.getElementById('logs-pagination');
      ul.innerHTML = '';
      // prev button
      const prevLi = document.createElement('li');
      prevLi.className = 'page-item' + (currentPage <= 1 ? ' disabled' : '');
      prevLi.innerHTML = `<a class="page-link" href="#" aria-label="Previous"><span aria-hidden="true">&laquo;</span></a>`;
      prevLi.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentPage > 1) {
          currentPage--;
          renderPage(currentPage);
        }
      });
      ul.appendChild(prevLi);
      // page indicator
      const indicatorLi = document.createElement('li');
      indicatorLi.className = 'page-item disabled mx-2';
      indicatorLi.innerHTML = `<span class="page-link">${currentPage} of ${pages}</span>`;
      ul.appendChild(indicatorLi);
      // next button
      const nextLi = document.createElement('li');
      nextLi.className = 'page-item' + (currentPage >= pages ? ' disabled' : '');
      nextLi.innerHTML = `<a class="page-link" href="#" aria-label="Next"><span aria-hidden="true">&raquo;</span></a>`;
      nextLi.addEventListener('click', (e) => {
        e.preventDefault();
        if (currentPage < pages) {
          currentPage++;
          renderPage(currentPage);
        }
      });
      ul.appendChild(nextLi);
    }

    function applyFilter() {
      const filter = (document.getElementById("logs-filter").value || "").toLowerCase();
      if (!filter) {
        filteredLogs = allLogs.slice();
      } else {
        filteredLogs = allLogs.filter(l => {
          return (l.actorEmail || '').toLowerCase().includes(filter)
            || (l.action || '').toLowerCase().includes(filter)
            || (JSON.stringify(l.details || '') || '').toLowerCase().includes(filter);
        });
      }
      currentPage = 1;
      renderPage(currentPage);
      document.getElementById("logs-count").innerText = filteredLogs.length;
    }

    async function loadLogs() {
      const t = document.getElementById("logs-table-body");
      t.innerHTML = '<tr><td colspan="4" class="text-muted small">Loading...</td></tr>';
      try {
        const res = await fetch("/api/admin/logs?limit=200");
        const json = res.ok ? await res.json() : { logs: [] };
        allLogs = json.logs || [];
        applyFilter();
      } catch (e) {
        t.innerHTML = '<tr><td colspan="4" class="text-danger small">Failed to load logs.</td></tr>';
        console.error(e);
      }
    }

    document.getElementById("logs-filter").addEventListener("input", () => applyFilter());

    // initial load
    loadLogs();
  </script>
