<div class="admin-dashboard container-fluid py-4">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-box-seam me-2"></i>Inventory Analytics
        </h1>
        <p class="hero-sub">
          Monitor stock velocity, shrinkage trends, and replenishment
          performance
        </p>
      </div>
    </div>
  </div>

  <div class="section-label">Key Metrics</div>
  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-box-seam"></i>
          </div>
          <div>
            <div class="kpi-label">Total SKUs</div>
            <div class="kpi-value">1,245</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #2ec4b6, #1a8f85)"
          >
            <i class="bi bi-arrow-repeat"></i>
          </div>
          <div>
            <div class="kpi-label">Stock Turnover</div>
            <div class="kpi-value">4.2x</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #2ec4b6, #1a8f85)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #e63946, #b91c2a)"
          >
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Low Stock Items</div>
            <div class="kpi-value">38</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #e63946, #b91c2a)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #e76f0d)"
          >
            <i class="bi bi-hourglass-split"></i>
          </div>
          <div>
            <div class="kpi-label">Stock-out Incidents</div>
            <div class="kpi-value">9</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #e76f0d)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label small text-uppercase text-muted fw-bold"
          >Period</label
        ><select class="form-select">
          <option>Last 30 Days</option>
          <option>Quarterly</option>
          <option>Year-to-Date</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small text-uppercase text-muted fw-bold"
          >Category</label
        ><select class="form-select">
          <option>All Categories</option>
          <option>Parts</option>
          <option>Consumables</option>
          <option>Equipment</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small text-uppercase text-muted fw-bold"
          >Warehouse</label
        ><select class="form-select">
          <option>All</option>
          <option>Main Storage</option>
          <option>Field Mobile Stock</option>
        </select>
      </div>
      <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-light border w-100">
          <i class="bi bi-funnel me-2"></i>Apply
        </button>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Stock Movement Trend</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2" style="height: 250px">
            <canvas id="inventoryMovementChart"></canvas>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Inventory Value by Category</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2 mb-3" style="height: 160px">
            <canvas id="inventoryCategoryValueChart"></canvas>
          </div>
          <ul class="list-unstyled small mb-0">
            <li class="d-flex justify-content-between">
              <span>Spare Parts</span><strong>₱ 220k</strong>
            </li>
            <li class="d-flex justify-content-between">
              <span>Consumables</span><strong>₱ 145k</strong>
            </li>
            <li class="d-flex justify-content-between">
              <span>Equipment</span><strong>₱ 87k</strong>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Stock Aging Distribution</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2" style="height: 220px">
            <canvas id="inventoryAgingChart"></canvas>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Top Consumed Items</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2" style="height: 220px">
            <canvas id="topConsumedItemsChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    (function () {
      if (typeof Chart === "undefined") return;

      var movementCtx = document.getElementById("inventoryMovementChart");
      if (movementCtx) {
        new Chart(movementCtx, {
          type: "line",
          data: {
            labels: ["W1", "W2", "W3", "W4", "W5", "W6"],
            datasets: [
              {
                label: "Inbound",
                data: [180, 220, 205, 240, 265, 250],
                borderColor: "#198754",
                backgroundColor: "rgba(25,135,84,0.12)",
                fill: true,
                tension: 0.3,
              },
              {
                label: "Outbound",
                data: [140, 155, 168, 175, 190, 201],
                borderColor: "#dc3545",
                backgroundColor: "rgba(220,53,69,0.10)",
                fill: true,
                tension: 0.3,
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { position: "bottom" } },
          },
        });
      }

      var categoryCtx = document.getElementById("inventoryCategoryValueChart");
      if (categoryCtx) {
        new Chart(categoryCtx, {
          type: "bar",
          data: {
            labels: ["Parts", "Consumables", "Equipment"],
            datasets: [
              {
                data: [220, 145, 87],
                backgroundColor: ["#0d6efd", "#20c997", "#fd7e14"],
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
          },
        });
      }

      var agingCtx = document.getElementById("inventoryAgingChart");
      if (agingCtx) {
        new Chart(agingCtx, {
          type: "bar",
          data: {
            labels: ["Parts", "Consumables", "Equipment"],
            datasets: [
              { label: "<30d", data: [60, 45, 20], backgroundColor: "#198754" },
              {
                label: "31-90d",
                data: [28, 22, 12],
                backgroundColor: "#ffc107",
              },
              { label: ">90d", data: [10, 8, 5], backgroundColor: "#dc3545" },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { position: "bottom" } },
            scales: { x: { stacked: true }, y: { stacked: true } },
          },
        });
      }

      var consumedCtx = document.getElementById("topConsumedItemsChart");
      if (consumedCtx) {
        new Chart(consumedCtx, {
          type: "bar",
          data: {
            labels: [
              "R-32 Gas",
              "Capacitor 45uF",
              "Copper Tube",
              "Sealant",
              "Filter Drier",
            ],
            datasets: [
              {
                label: "Units",
                data: [96, 74, 69, 55, 41],
                backgroundColor: "rgba(13,110,253,0.78)",
              },
            ],
          },
          options: {
            indexAxis: "y",
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
          },
        });
      }
    })();
  </script>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 border-bottom">
      <h6 class="mb-0 fw-bold">Reorder Intelligence</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Item</th>
            <th>Current Stock</th>
            <th>Reorder Point</th>
            <th>Avg Daily Use</th>
            <th>Days Remaining</th>
            <th>Priority</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4 fw-semibold">R-32 Refrigerant</td>
            <td>12</td>
            <td>20</td>
            <td>2.1</td>
            <td>6 days</td>
            <td>
              <span
                class="badge bg-danger-subtle text-danger border border-danger-subtle"
                >High</span
              >
            </td>
          </tr>
          <tr>
            <td class="ps-4 fw-semibold">Compressor Capacitor 45uF</td>
            <td>28</td>
            <td>25</td>
            <td>1.3</td>
            <td>21 days</td>
            <td>
              <span
                class="badge bg-warning-subtle text-warning border border-warning-subtle"
                >Medium</span
              >
            </td>
          </tr>
          <tr>
            <td class="ps-4 fw-semibold">Copper Tube 1/2</td>
            <td>90</td>
            <td>50</td>
            <td>2.8</td>
            <td>32 days</td>
            <td>
              <span
                class="badge bg-success-subtle text-success border border-success-subtle"
                >Stable</span
              >
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
<!-- end admin-dashboard container -->
