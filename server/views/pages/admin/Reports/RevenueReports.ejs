<div class="admin-dashboard container-fluid py-4">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title"><i class="bi bi-graph-up me-2"></i>Revenue Analytics</h1>
        <p class="hero-sub">
          Analyze earnings, margins, and payment performance across services and
          channels
        </p>
      </div>

    </div>
  </div>

  <div class="section-label">Key Metrics</div>
  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#212529,#495057)">
            <i class="bi bi-currency-dollar"></i>
          </div>
          <div>
            <div class="kpi-label">Gross Revenue (MTD)</div>
            <div class="kpi-value">₱ 4.87M</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#212529,#495057)"></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#2ec4b6,#1a8f85)">
            <i class="bi bi-graph-up"></i>
          </div>
          <div>
            <div class="kpi-label">Net Revenue</div>
            <div class="kpi-value">₱ 3.96M</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#2ec4b6,#1a8f85)"></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#4361ee,#3a0ca3)">
            <i class="bi bi-ticket-perforated"></i>
          </div>
          <div>
            <div class="kpi-label">Average Ticket</div>
            <div class="kpi-value">₱ 3,740</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#4361ee,#3a0ca3)"></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#7b2d8b,#560bad)">
            <i class="bi bi-speedometer2"></i>
          </div>
          <div>
            <div class="kpi-label">Collection Efficiency</div>
            <div class="kpi-value">96.1%</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#7b2d8b,#560bad)"></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body row g-3">
      <div class="col-md-3">
        <label class="form-label small text-uppercase text-muted fw-bold"
          >Period</label
        ><select class="form-select">
          <option>This Month</option>
          <option>Last Month</option>
          <option>Quarterly</option>
          <option>Year-to-Date</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small text-uppercase text-muted fw-bold"
          >Revenue Source</label
        ><select class="form-select">
          <option>All Sources</option>
          <option>Core Services</option>
          <option>Repair Services</option>
          <option>Products</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small text-uppercase text-muted fw-bold"
          >Payment Channel</label
        ><select class="form-select">
          <option>All Channels</option>
          <option>GCash</option>
          <option>Cash</option>
        </select>
      </div>
      <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-light border w-100">
          <i class="bi bi-funnel me-2"></i>Apply
        </button>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Revenue Trend (Daily)</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2" style="height: 260px">
            <canvas id="revenueTrendChart"></canvas>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Revenue by Channel</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2 mb-3" style="height: 160px">
            <canvas id="revenueChannelChart"></canvas>
          </div>
          <ul class="list-unstyled small mb-0">
            <li class="d-flex justify-content-between">
              <span>GCash</span><strong>41%</strong>
            </li>
            <li class="d-flex justify-content-between">
            </li>
            <li class="d-flex justify-content-between">
              <span>Cash</span><strong>26%</strong>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Gross vs Net Margin Trend</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2" style="height: 220px">
            <canvas id="marginTrendChart"></canvas>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white py-3 border-bottom">
          <h6 class="mb-0 fw-bold">Revenue by Service Segment</h6>
        </div>
        <div class="card-body">
          <div class="rounded border bg-light p-2" style="height: 220px">
            <canvas id="revenueSegmentChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    (function () {
      if (typeof Chart === "undefined") return;

      var trendCtx = document.getElementById("revenueTrendChart");
      if (trendCtx) {
        new Chart(trendCtx, {
          type: "line",
          data: {
            labels: ["W1", "W2", "W3", "W4", "W5", "W6", "W7"],
            datasets: [
              {
                label: "Gross",
                data: [420, 468, 452, 501, 518, 542, 565],
                borderColor: "#0d6efd",
                backgroundColor: "rgba(13,110,253,0.12)",
                fill: true,
                tension: 0.35,
              },
              {
                label: "Net",
                data: [342, 376, 365, 403, 419, 438, 451],
                borderColor: "#198754",
                backgroundColor: "rgba(25,135,84,0.10)",
                fill: true,
                tension: 0.35,
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { position: "bottom" } },
          },
        });
      }

      var channelCtx = document.getElementById("revenueChannelChart");
      if (channelCtx) {
        new Chart(channelCtx, {
          type: "doughnut",
          data: {
            labels: ["GCash", "Cash", "PayMongo"],
            datasets: [
              {
                data: [41, 33, 26],
                backgroundColor: ["#0d6efd", "#20c997", "#fd7e14"],
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            cutout: "62%",
          },
        });
      }

      var marginCtx = document.getElementById("marginTrendChart");
      if (marginCtx) {
        new Chart(marginCtx, {
          type: "line",
          data: {
            labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
            datasets: [
              {
                label: "Gross Margin %",
                data: [58, 57, 59, 60, 61, 62],
                borderColor: "#6f42c1",
                tension: 0.3,
              },
              {
                label: "Net Margin %",
                data: [44, 43, 45, 46, 47, 48],
                borderColor: "#dc3545",
                tension: 0.3,
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { position: "bottom" } },
            scales: { y: { min: 35, max: 70 } },
          },
        });
      }

      var segmentCtx = document.getElementById("revenueSegmentChart");
      if (segmentCtx) {
        new Chart(segmentCtx, {
          type: "bar",
          data: {
            labels: ["Core", "Repair", "Products"],
            datasets: [
              {
                label: "Revenue (k)",
                data: [1980, 1640, 860],
                backgroundColor: ["#0d6efd", "#dc3545", "#20c997"],
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
          },
        });
      }
    })();
  </script>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 border-bottom">
      <h6 class="mb-0 fw-bold">Top Revenue Drivers</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Service/Product</th>
            <th>Transactions</th>
            <th>Gross Revenue</th>
            <th>Estimated Cost</th>
            <th>Margin</th>
            <th>Contribution</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4 fw-semibold">Aircon Preventive Maintenance</td>
            <td>302</td>
            <td>₱ 1.21M</td>
            <td>₱ 0.47M</td>
            <td><span class="text-success fw-bold">61%</span></td>
            <td>24.8%</td>
          </tr>
          <tr>
            <td class="ps-4 fw-semibold">Compressor Replacement</td>
            <td>118</td>
            <td>₱ 0.94M</td>
            <td>₱ 0.49M</td>
            <td><span class="text-success fw-bold">48%</span></td>
            <td>19.3%</td>
          </tr>
          <tr>
            <td class="ps-4 fw-semibold">General Cleaning Package</td>
            <td>547</td>
            <td>₱ 0.88M</td>
            <td>₱ 0.31M</td>
            <td><span class="text-success fw-bold">65%</span></td>
            <td>18.1%</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
</div> <!-- end admin-dashboard container -->
