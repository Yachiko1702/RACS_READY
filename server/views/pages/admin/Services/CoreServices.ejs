<div class="admin-dashboard container-fluid py-4 core-services-page">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title"><i class="bi bi-gear-fill me-2"></i>Core Services Catalog</h1>
        <p class="hero-sub">
          Configure standard service packages, rates, and service-level policies
        </p>
      </div>
      <div class="col-md-4 text-end">
        <div class="btn-group">
          <button class="btn btn-primary new-core-service">
            <i class="bi bi-plus-lg me-2"></i>New Core Service
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- original header removed -->

  <% // compute some simple stats from the list %>
  <% const totalCount = coreServices ? coreServices.length : 0; %>
  <% const activeCount = coreServices ? coreServices.filter(s=>s.active).length : 0; %>
  <% const reviewCount = totalCount - activeCount; %>
  <% const avgTime = coreServices && coreServices.length ? (coreServices.reduce((sum,s)=>sum + (s.durationMinutes||0),0) / coreServices.length) : 0; %>
  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-clipboard-data"></i>
          </div>
          <div>
            <div class="kpi-label">Total Core Services</div>
            <div class="kpi-value" id="statTotalCore"><%= totalCount %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #2ec4b6, #1a8f85)"
          >
            <i class="bi bi-check-circle"></i>
          </div>
          <div>
            <div class="kpi-label">Active Services</div>
            <div class="kpi-value" id="statActive"><%= activeCount %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #2ec4b6, #1a8f85)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #ff7422)"
          >
            <i class="bi bi-pencil-square"></i>
          </div>
          <div>
            <div class="kpi-label">Needs Review</div>
            <div class="kpi-value" id="statReview"><%= reviewCount %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #ff7422)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #7b2d8b, #560bad)"
          >
            <i class="bi bi-clock"></i>
          </div>
          <div>
            <div class="kpi-label">Avg Completion Time</div>
            <div class="kpi-value" id="statAvgTimeCore"><%= fmtDuration(Math.round(avgTime)) %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #7b2d8b, #560bad)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Search Service</label
          >
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"
              ><i class="bi bi-search text-muted"></i
            ></span>
            <input
              type="text"
              class="form-control border-start-0 bg-light"
              placeholder="Service name, code, or category"
            />
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Category</label
          >
          <select class="form-select">
            <option>All Categories</option>
            <option>Cleaning</option>
            <option>Installation</option>
            <option>Maintenance</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Status</label
          >
          <select class="form-select">
            <option>All</option>
            <option>Active</option>
            <option>Draft</option>
            <option>Archived</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-light border w-100">
            <i class="bi bi-funnel me-2"></i>Filter
          </button>
        </div>
      </div>
    </div>
  </div>

  <% /* helpers */ %>
  <% function fmtPrice(p) {
    if (p == null) return '';
    return '₱ ' + Number(p).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  } %>
  <% function fmtDuration(mins) {
    if (!mins && mins !== 0) return '';
    const h = Math.floor(mins / 60);
    const m = mins % 60;
    let out = '';
    if (h) out += h + 'h';
    if (m) out += (out ? ' ' : '') + m + 'm';
    return out || '0m';
  } %>
  <% function badgeClass(cat) {
    // simple generic badge style – categories can be customized as needed
    return 'badge bg-secondary-subtle text-secondary border border-secondary-subtle';
  } %>

  <div class="card border-0 shadow-sm">
    <div
      class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center"
    >
      <h6 class="mb-0 fw-bold">Core Service List</h6>
      <span class="text-muted small">Last pricing sync: today</span>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Service</th>
            <th>Code</th>
            <th>Category</th>
            <th>Base Price</th>
            <th>Estimated Duration</th>
            <th>Bookings (lifetime)</th>
            <th>Status</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (coreServices && coreServices.length) { %>
            <% coreServices.forEach(function(svc) { %>
              <tr data-svc="<%= encodeURIComponent(JSON.stringify(svc)) %>">
                <td class="ps-4">
                  <div class="fw-bold text-dark"><%= svc.name %></div>
                  <div class="small text-muted"><%= svc.description || '' %></div>
                </td>
                <td>
                  <span class="font-monospace small text-muted"><%= svc.slug || svc._id %></span>
                </td>
                <td>
                  <span class="<%= badgeClass(svc.category) %>"><%= svc.category || '-' %></span>
                </td>
                <td class="fw-bold"><%= fmtPrice(svc.basePrice) %></td>
                <td class="small text-muted"><%= fmtDuration(svc.durationMinutes) %></td>
                <td class="fw-bold text-dark"><%= svc.bookingCount || 0 %></td>
                <td>
                  <span class="badge <%= svc.active ? 'bg-success-subtle text-success border border-success-subtle' : 'bg-secondary-subtle text-secondary border border-secondary-subtle' %>"><%= svc.active ? 'Active' : 'Inactive' %></span>
                </td>
                <td class="text-end pe-4">
                  <button class="btn btn-sm btn-outline-primary edit-core-service">Edit</button>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-3">No core services defined.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- modal to create/edit core service -->
<div class="modal fade" id="coreServiceModal" tabindex="-1" aria-labelledby="coreServiceModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <form id="coreServiceForm" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="coreServiceModalLabel"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" name="name" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Slug</label>
          <input type="text" name="slug" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Category</label>
          <input type="text" name="category" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Base Price</label>
          <input type="number" step="0.01" name="basePrice" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Duration (minutes)</label>
          <input type="number" name="durationMinutes" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control"></textarea>
        </div>
        <div class="form-check">
          <input type="checkbox" name="active" class="form-check-input" id="activeCheck" checked />
          <label class="form-check-label" for="activeCheck">Active</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // make sure modal is moved to document.body and above other elements
    const modalEl = document.getElementById('coreServiceModal');
    if (modalEl && modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }
    const css = document.createElement('style');
    css.textContent = ".modal { z-index: 2050 !important; } .modal-backdrop { z-index: 2040 !important; }";
    document.head.appendChild(css);

    // re-use the previously obtained modalEl (already declared above)
    if (!modalEl) return;
    if (!window.bootstrap || !bootstrap.Modal) {
      console.error('Bootstrap JS not available');
    }
    const modal = bootstrap && bootstrap.Modal ? new bootstrap.Modal(modalEl) : null;
    const form = document.getElementById('coreServiceForm');
    let editingId = null;

    function openForm(data) {
      if (data) {
        editingId = data._id;
        modalEl.querySelector('.modal-title').innerText = 'Edit Core Service';
        form.name.value = data.name || '';
        form.slug.value = data.slug || '';
        form.category.value = data.category || '';
        form.description.value = data.description || '';
        form.basePrice.value = data.basePrice || '';
        form.durationMinutes.value = data.durationMinutes || '';
        form.active.checked = !!data.active;
      } else {
        editingId = null;
        modalEl.querySelector('.modal-title').innerText = 'New Core Service';
        form.reset();
        form.active.checked = true;
      }
      modal.show();
    }

    document.querySelector('.new-core-service').addEventListener('click', function() {
      openForm();
    });

    document.body.addEventListener('click', function(e) {
      if (e.target.matches('.edit-core-service')) {
        const tr = e.target.closest('tr');
        if (!tr) return;
        const svc = JSON.parse(decodeURIComponent(tr.dataset.svc || '{}'));
        openForm(svc);
      }
    });

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const payload = {
        name: form.name.value.trim(),
        slug: form.slug.value.trim(),
        category: form.category.value.trim(),
        description: form.description.value.trim(),
        basePrice: form.basePrice.value ? parseFloat(form.basePrice.value) : undefined,
        durationMinutes: form.durationMinutes.value ? parseInt(form.durationMinutes.value) : undefined,
        active: form.active.checked,
      };
      let url = '/api/admin/core-services';
      let method = 'POST';
      if (editingId) {
        url += '/' + editingId;
        method = 'PATCH';
      }
      try {
        const r = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (r.ok) {
          location.reload();
        } else {
          const j = await r.json();
          alert(j.error || 'Save failed');
        }
      } catch (err) {
        alert('Save failed');
      }
    });
  })();
</script>
