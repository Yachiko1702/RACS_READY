<div class="admin-dashboard container-fluid py-4 repair-services-page">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title"><i class="bi bi-wrench-adjustable-circle-fill me-2"></i>Repair Services Matrix</h1>
        <p class="hero-sub">
          Manage diagnostics, repair categories, parts policy, and SLA targets
        </p>
      </div>
      <div class="col-md-4 text-end">
        <div class="btn-group">
          <button class="btn btn-primary new-repair-service">
            <i class="bi bi-plus-lg me-2"></i>Add Repair Service
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- original header removed -->

  <% const totalRepairs = repairServices ? repairServices.length : 0; %>
  <% const activeRepairs = repairServices ? repairServices.filter(r=>r.active).length : 0; %>
  <% const inactiveRepairs = totalRepairs - activeRepairs; %>
  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #e63946, #b91c2a)"
          >
            <i class="bi bi-exclamation-octagon-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Total Repair Services</div>
            <div class="kpi-value" id="statOpen"><%= totalRepairs %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #e63946, #b91c2a)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #ff7422)"
          >
            <i class="bi bi-tools"></i>
          </div>
          <div>
            <div class="kpi-label">Active Services</div>
            <div class="kpi-value" id="statComplex"><%= activeRepairs %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #ff7422)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #2ec4b6, #1a8f85)"
          >
            <i class="bi bi-check-circle"></i>
          </div>
          <div>
            <div class="kpi-label">Inactive/Review</div>
            <div class="kpi-value" id="statResolved"><%= inactiveRepairs %></div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #2ec4b6, #1a8f85)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-clock"></i>
          </div>
          <div>
            <div class="kpi-label">Avg Est. Duration</div>
            <div class="kpi-value" id="statSLA">
              <% if (repairServices && repairServices.length) { %>
                <%= fmtDuration(Math.round(repairServices.reduce((sum,r)=>sum+(r.estimatedDurationMinutes||0),0)/repairServices.length)) %>
              <% } else { %>-
              <% } %>
            </div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Search Repair Service</label
          >
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"
              ><i class="bi bi-search text-muted"></i
            ></span>
            <input
              type="text"
              class="form-control border-start-0 bg-light"
              placeholder="Issue type, code, or service name"
            />
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Severity</label
          >
          <select class="form-select">
            <option>All Severities</option>
            <option>Minor</option>
            <option>Major</option>
            <option>Critical</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Skill Requirement</label
          >
          <select class="form-select">
            <option>All Levels</option>
            <option>Level 1 Technician</option>
            <option>Level 2 Technician</option>
            <option>Senior Specialist</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-light border w-100">
            <i class="bi bi-funnel me-2"></i>Filter
          </button>
        </div>
      </div>
    </div>
  </div>

<% /* helper functions for repair table */ %>
  <% function fmtPrice(p) { if (p == null) return ''; return '₱ ' + Number(p).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); } %>
  <% function fmtDuration(mins) { if (!mins && mins !== 0) return ''; const h=Math.floor(mins/60); const m=mins%60; let out=''; if(h) out+=h+'h'; if(m) out+=(out?' ':'')+m+'m'; return out||'0m'; } %>
  <% function statusBadge(active) { if(active) return 'bg-success-subtle text-success border border-success-subtle'; return 'bg-secondary-subtle text-secondary border border-secondary-subtle'; } %>

  <div class="card border-0 shadow-sm mb-4">
    <div
      class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center"
    >
      <h6 class="mb-0 fw-bold">Repair Service Definitions</h6>
      <span class="text-muted small">Updated with diagnostic matrix</span>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Repair Service</th>
            <th>Code</th>
            <th>Appliance</th>
            <th>Baseline Fee</th>
            <th>Est. Duration</th>
            <th>Warranty</th>
            <th>Status</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (repairServices && repairServices.length) { %>
            <% repairServices.forEach(function(svc) { %>
              <tr data-svc="<%= encodeURIComponent(JSON.stringify(svc)) %>">
                <td class="ps-4">
                  <div class="fw-bold text-dark"><%= svc.name %></div>
                  <div class="small text-muted"><%= svc.applianceType || '' %></div>
                </td>
                <td>
                  <span class="font-monospace small text-muted"><%= svc.slug || svc._id %></span>
                </td>
                <td><%= svc.applianceType || '-' %></td>
                <td class="fw-bold"><%= fmtPrice(svc.basePrice) %></td>
                <td class="small text-muted"><%= fmtDuration(svc.estimatedDurationMinutes) %></td>
                <td class="small text-muted"><%= svc.warrantyDays != null ? svc.warrantyDays + 'd' : '-' %></td>
                <td>
                  <span class="badge <%= statusBadge(svc.active) %>"><%= svc.active ? 'Active' : 'Inactive' %></span>
                </td>
                <td class="text-end pe-4">
                  <button class="btn btn-sm btn-outline-primary edit-repair-service">Edit</button>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-3">No repair services defined.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3 border-bottom">
      <h6 class="mb-0 fw-bold">Repair Policy Notes</h6>
    </div>
    <div class="card-body">
      <ul class="mb-0 text-muted">
        <li>
          Critical repairs require pre-approval and parts availability
          confirmation.
        </li>
        <li>
          All final quotes should include service labor + parts + warranty
          scope.
        </li>
        <li>
          Draft services are hidden from booking until approved by an admin
          reviewer.
        </li>
      </ul>
    </div>
  </div>
</div>

<!-- modal for repair service create/edit -->
<div class="modal fade" id="repairServiceModal" tabindex="-1" aria-labelledby="repairServiceModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <form id="repairServiceForm" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="repairServiceModalLabel"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" name="name" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Slug</label>
          <input type="text" name="slug" class="form-control" required />
        </div>
        <div class="mb-3">
          <label class="form-label">Appliance Type</label>
          <input type="text" name="applianceType" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Base Price</label>
          <input type="number" step="0.01" name="basePrice" class="form-control" />
        </div>
        <div class="mb-3">
          <label class="form-label">Estimated Duration Minutes</label>
          <input type="number" name="estimatedDurationMinutes" class="form-control" />
        </div>
        <div class="form-check mb-3">
          <input type="checkbox" name="active" class="form-check-input" id="repairActiveCheck" checked />
          <label class="form-check-label" for="repairActiveCheck">Active</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // relocate modal to top-level to avoid being clipped by parent stacking contexts
    const modalEl = document.getElementById('repairServiceModal');
    if (modalEl && modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }
    const css = document.createElement('style');
    css.textContent = ".modal { z-index: 2050 !important; } .modal-backdrop { z-index: 2040 !important; }";
    document.head.appendChild(css);
    if (!modalEl) return;
    const modal = window.bootstrap && bootstrap.Modal ? new bootstrap.Modal(modalEl) : null;
    const form = document.getElementById('repairServiceForm');
    let editingId = null;

    function openForm(data) {
      if (data) {
        editingId = data._id;
        modalEl.querySelector('.modal-title').innerText = 'Edit Repair Service';
        form.name.value = data.name || '';
        form.slug.value = data.slug || '';
        form.applianceType.value = data.applianceType || '';
        form.basePrice.value = data.basePrice || '';
        form.estimatedDurationMinutes.value = data.estimatedDurationMinutes || '';
        form.active.checked = !!data.active;
      } else {
        editingId = null;
        modalEl.querySelector('.modal-title').innerText = 'New Repair Service';
        form.reset();
        form.active.checked = true;
      }
      modal && modal.show();
    }

    document.querySelector('.new-repair-service').addEventListener('click', function() {
      openForm();
    });

    document.body.addEventListener('click', function(e) {
      if (e.target.matches('.edit-repair-service')) {
        const tr = e.target.closest('tr');
        if (!tr) return;
        const svc = JSON.parse(decodeURIComponent(tr.dataset.svc || '{}'));
        openForm(svc);
      }
    });

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const payload = {
        name: form.name.value.trim(),
        slug: form.slug.value.trim(),
        applianceType: form.applianceType.value.trim(),
        basePrice: form.basePrice.value ? parseFloat(form.basePrice.value) : undefined,
        estimatedDurationMinutes: form.estimatedDurationMinutes.value ? parseInt(form.estimatedDurationMinutes.value) : undefined,
        active: form.active.checked,
      };
      let url = '/api/admin/repair-services';
      let method = 'POST';
      if (editingId) {
        url += '/' + editingId;
        method = 'PATCH';
      }
      try {
        const r = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (r.ok) {
          location.reload();
        } else {
          const j = await r.json();
          alert(j.error || 'Save failed');
        }
      } catch (err) {
        alert('Save failed');
      }
    });
  });
</script>
