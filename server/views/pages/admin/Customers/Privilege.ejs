<div class="admin-dashboard container-fluid py-4">
  <%- include('../../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-star-fill me-2"></i>Customer Privileges
        </h1>
        <p class="hero-sub">
          Control membership levels, rewards, and special access policies
        </p>
      </div>
    </div>
  </div>

  <!-- KPI cards -->
  <div class="row mb-4 g-3 kpi-row">
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #4361ee, #3a0ca3)"
          >
            <i class="bi bi-people-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Regular Members</div>
            <div class="kpi-value">1,920</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #4361ee, #3a0ca3)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #ff9f1c, #ff7422)"
          >
            <i class="bi bi-star-fill"></i>
          </div>
          <div>
            <div class="kpi-label">VIP Members</div>
            <div class="kpi-value">204</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #ff9f1c, #ff7422)"
        ></div>
      </div>
    </div>
    <div class="col-md-3 d-flex">
      <div class="kpi-card w-100 h-100">
        <div class="d-flex align-items-center gap-3">
          <div
            class="kpi-icon"
            style="background: linear-gradient(135deg, #2ec4b6, #1a8f85)"
          >
            <i class="bi bi-building"></i>
          </div>
          <div>
            <div class="kpi-label">Corporate Accounts</div>
            <div class="kpi-value">24</div>
          </div>
        </div>
        <div
          class="kpi-bar"
          style="background: linear-gradient(90deg, #2ec4b6, #1a8f85)"
        ></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Search Customer</label
          >
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0"
              ><i class="bi bi-search text-muted"></i
            ></span>
            <input
              type="text"
              class="form-control border-start-0 bg-light"
              placeholder="Name, email, or ID"
            />
          </div>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Tier</label
          >
          <select class="form-select">
            <option>All Tiers</option>
            <option>Regular</option>
            <option>VIP</option>
            <option>Corporate</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold"
            >Benefit Type</label
          >
          <select class="form-select">
            <option>Any Benefit</option>
            <option>Discount</option>
            <option>Priority Booking</option>
            <option>Extended Warranty</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-light w-100 border">
            <i class="bi bi-funnel me-2"></i>Filter
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3 border-bottom">
      <h6 class="mb-0 fw-bold">Privilege Tiers</h6>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Tier</th>
            <th>Eligibility Rule</th>
            <th>Benefits</th>
            <th>Members</th>
            <th>Service Discount</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4">
              <span class="badge bg-light text-dark border">Regular</span>
            </td>
            <td class="small text-muted">Default upon account verification</td>
            <td class="small text-dark">
              Standard booking queue, promo notifications
            </td>
            <td><span class="fw-bold">1,920</span></td>
            <td><span class="fw-bold text-muted">0%</span></td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-light border">View</button>
            </td>
          </tr>
          <tr>
            <td class="ps-4">
              <span
                class="badge bg-warning-subtle text-warning border border-warning-subtle"
                >VIP</span
              >
            </td>
            <td class="small text-muted">
              Spent ₱20,000+ or 10+ completed bookings
            </td>
            <td class="small text-dark">
              Priority scheduling, dedicated support, promo-first access
            </td>
            <td><span class="fw-bold">204</span></td>
            <td><span class="fw-bold text-warning">10%</span></td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-outline-warning">Edit</button>
            </td>
          </tr>
          <tr>
            <td class="ps-4">
              <span
                class="badge bg-primary-subtle text-primary border border-primary-subtle"
                >Corporate</span
              >
            </td>
            <td class="small text-muted">Approved business profile</td>
            <td class="small text-dark">
              Bulk booking, monthly billing, account manager
            </td>
            <td><span class="fw-bold">24</span></td>
            <td><span class="fw-bold text-primary">15%</span></td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-outline-primary">Edit</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div
      class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center"
    >
      <h6 class="mb-0 fw-bold">Assigned Customer Privileges</h6>
      <span class="text-muted small"
        >Manual overrides and approved upgrades</span
      >
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
          <tr>
            <th class="ps-4">Customer</th>
            <th>Current Tier</th>
            <th>Assigned By</th>
            <th>Valid Until</th>
            <th>Notes</th>
            <th class="text-end pe-4">Actions</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">Maria Santos</div>
              <div class="small text-muted">maria.santos@gmail.com</div>
            </td>
            <td>
              <span
                class="badge bg-warning-subtle text-warning border border-warning-subtle"
                >VIP</span
              >
            </td>
            <td class="small text-muted">Admin - Josh A.</td>
            <td class="small text-dark">Dec 31, 2026</td>
            <td class="small text-muted">
              Top repeat customer (annual retention)
            </td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-outline-secondary">Adjust</button>
            </td>
          </tr>
          <tr>
            <td class="ps-4">
              <div class="fw-bold text-dark">Summit Tower Office</div>
              <div class="small text-muted">operations@summittower.ph</div>
            </td>
            <td>
              <span
                class="badge bg-primary-subtle text-primary border border-primary-subtle"
                >Corporate</span
              >
            </td>
            <td class="small text-muted">Admin - Team Lead</td>
            <td class="small text-dark">Jun 30, 2026</td>
            <td class="small text-muted">Quarterly maintenance contract</td>
            <td class="text-end pe-4">
              <button class="btn btn-sm btn-outline-secondary">Adjust</button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="card-footer bg-white py-3 border-top">
      <ul class="pagination justify-content-end mb-0">
        <li class="page-item disabled">
          <a class="page-link" href="#">Previous</a>
        </li>
        <li class="page-item active"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">Next</a></li>
      </ul>
    </div>
  </div>
</div>
