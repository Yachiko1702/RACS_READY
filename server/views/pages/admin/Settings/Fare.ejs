<div class="admin-dashboard container-fluid py-4 fare-settings-page">
  <%- include('../../../partials/dashboard-styles') %>

  <style>
    .fare-settings-page {
      --surface: #ffffff;
      --surface-soft: #f8fafc;
      --line: rgba(15,23,42,0.08);
      --line-strong: rgba(15,23,42,0.14);
      --brand: #0d6efd;
      --text-muted: #64748b;
    }
    .fare-settings-page .card {
      border: 1px solid var(--line);
      border-radius: 14px;
      box-shadow: 0 10px 28px rgba(15,23,42,0.05);
      background: linear-gradient(180deg,#ffffff,#fbfdff);
    }
    .fare-settings-page .form-control {
      border-radius: 10px;
      border-color: var(--line-strong);
    }
    .fare-settings-page .form-control:focus {
      border-color: rgba(13,110,253,0.45);
      box-shadow: 0 0 0 0.15rem rgba(13,110,253,0.16);
    }
    .fare-preview {
      background: var(--surface-soft);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1rem 1.25rem;
      font-size: 0.9rem;
      color: #374151;
    }
    .fare-preview table { width: 100%; border-collapse: collapse; }
    .fare-preview td { padding: 4px 0; }
    .fare-preview td:last-child { text-align: right; font-weight: 600; color: #0d6efd; }
  </style>

  <!-- Header -->
  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-cash-coin me-2"></i>Fare &amp; Pricing Settings
        </h1>
        <p class="hero-sub">
          Configure the distance meter fare rate charged to customers for technician travel.
        </p>
      </div>
    </div>
  </div>

  <!-- Alert area -->
  <div id="fareAlert" class="d-none mb-3"></div>

  <div class="row g-4">
    <!-- Edit card -->
    <div class="col-lg-6">
      <div class="card p-4">
        <h5 class="fw-semibold mb-1"><i class="bi bi-pencil-square me-2 text-primary"></i>Distance Meter Rate</h5>
        <p class="small text-muted mb-3">
          This rate is applied when calculating the travel fare shown to customers
          during the booking process. It is based on the road distance between the
          assigned technician and the customer's pinned location.
        </p>
        <div class="mb-3">
          <label for="farePerKmInput" class="form-label fw-semibold">Rate (₱ per km)</label>
          <div class="input-group">
            <span class="input-group-text">₱</span>
            <input
              type="number"
              id="farePerKmInput"
              class="form-control"
              min="0"
              max="10000"
              step="1"
              placeholder="e.g. 40"
            />
            <span class="input-group-text">/ km</span>
          </div>
          <div class="form-text">Allowed range: ₱0 – ₱10,000 per km.</div>
        </div>
        <button
          type="button"
          id="saveFareBtn"
          class="btn btn-primary"
          style="min-width:140px;"
        >
          <i class="bi bi-floppy-disk me-1"></i>Save Rate
        </button>
      </div>
    </div>

    <!-- Live preview card -->
    <div class="col-lg-6">
      <div class="card p-4">
        <h5 class="fw-semibold mb-1"><i class="bi bi-calculator me-2 text-success"></i>Fare Preview</h5>
        <p class="small text-muted mb-3">
          How the current rate translates at common distances.
        </p>
        <div class="fare-preview">
          <table id="farePreviewTable">
            <tr><td>1 km</td><td id="prev1">—</td></tr>
            <tr><td>3 km</td><td id="prev3">—</td></tr>
            <tr><td>5 km</td><td id="prev5">—</td></tr>
            <tr><td>10 km</td><td id="prev10">—</td></tr>
            <tr><td>20 km</td><td id="prev20">—</td></tr>
          </table>
        </div>
        <p class="small text-muted mt-3 mb-0">
          <i class="bi bi-info-circle me-1"></i>Distances use actual road distance
          (OSRM routing), not straight-line.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const input   = document.getElementById("farePerKmInput");
  const saveBtn = document.getElementById("saveFareBtn");
  const alertEl = document.getElementById("fareAlert");

  function updatePreview(rate) {
    [1, 3, 5, 10, 20].forEach((km) => {
      const el = document.getElementById("prev" + km);
      if (el) el.textContent = "₱" + (km * rate).toLocaleString("en-PH", { minimumFractionDigits: 2 });
    });
  }

  function showAlert(msg, type) {
    alertEl.className = "alert alert-" + type;
    alertEl.textContent = msg;
    alertEl.classList.remove("d-none");
    setTimeout(() => alertEl.classList.add("d-none"), 4000);
  }

  // Load current value
  fetch("/api/admin/settings/fare", { credentials: "same-origin" })
    .then((r) => r.json())
    .then((data) => {
      const v = data.farePerKm ?? 40;
      input.value = v;
      updatePreview(v);
    })
    .catch(() => { input.value = 40; updatePreview(40); });

  // Live preview on input
  input.addEventListener("input", () => {
    const v = parseFloat(input.value);
    if (Number.isFinite(v) && v >= 0) updatePreview(v);
  });

  // Save
  saveBtn.addEventListener("click", async () => {
    const val = parseFloat(input.value);
    if (!Number.isFinite(val) || val < 0 || val > 10000) {
      showAlert("Please enter a valid rate between 0 and 10,000.", "danger");
      return;
    }
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving…';
    try {
      const resp = await fetch("/api/admin/settings/fare", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify({ farePerKm: val }),
      });
      const data = await resp.json();
      if (!resp.ok) throw new Error(data.error || "Save failed");
      showAlert("Fare rate updated to ₱" + val + " / km successfully.", "success");
      updatePreview(val);
    } catch (err) {
      showAlert("Error: " + err.message, "danger");
    } finally {
      saveBtn.disabled = false;
      saveBtn.innerHTML = '<i class="bi bi-floppy-disk me-1"></i>Save Rate';
    }
  });
})();
</script>
