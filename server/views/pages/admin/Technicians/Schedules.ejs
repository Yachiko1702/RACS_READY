    <script>
      (function () {
        "use strict";

        /* ── helpers ─────────────────────────────────────────────────── */
        const $ = (id) => document.getElementById(id);
        const DAY_SHORT = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

        function adjustLayoutForWeekView(view) {
          const root = document.querySelector(".ts-page");
          if (!root) return;
          const isTimegrid =
            view.type === "timeGridWeek" || view.type === "timeGridDay";
          const isMonth = view.type === "dayGridMonth";
          if (isTimegrid) {
            root.classList.add("ts-week-full");
          } else {
            root.classList.remove("ts-week-full");
          }
          if (isMonth) {
            root.classList.add("ts-month-full");
          } else {
            root.classList.remove("ts-month-full");
          }
          /* adjust calendar height according to view */
          if (techCal) {
            if (isTimegrid) {
              // shrink the calendar slightly more to avoid the page itself
              // getting a scrollbar.  200px offset accounts for header,
              // legend and any surrounding padding.  All slots still fit.
              techCal.setOption("height", "calc(100vh - 200px)");
            } else if (isMonth) {
              // month view should auto-expand so all month rows (dates) are visible
              techCal.setOption("height", "auto");
            } else {
              techCal.setOption("height", "100%");
            }
            // force grid recalculation after height / class changes
            // Use staggered timeouts so the browser has time to apply
            // the CSS class changes before FullCalendar measures.
            setTimeout(() => {
              if (techCal) techCal.updateSize();
            }, 0);
            setTimeout(() => {
              if (techCal) techCal.updateSize();
            }, 150);
            setTimeout(() => {
              if (techCal) techCal.updateSize();
            }, 400);
            // after possible resize, also recompute exact timegrid height
            adjustTimegridHeight();
          }
        }

        function adjustTimegridHeight() {
          if (!techCal) return;
          const view = techCal.view;
          if (!view) return;
          if (view.type !== "timeGridWeek" && view.type !== "timeGridDay")
            return;
          // method1: measure first-to-last slot positions
          const slots = document.querySelectorAll(
            ".fc-timegrid-slot:not(.fc-timegrid-slot-minor)",
          );
          let slotsHeight = 0;
          if (slots.length) {
            const first = slots[0];
            const last = slots[slots.length - 1];
            const rect1 = first.getBoundingClientRect();
            const rectN = last.getBoundingClientRect();
            slotsHeight = rectN.bottom - rect1.top + 1; // include border
          }
          // method2: scrollHeight of body (more authoritative)
          const body = document.querySelector(".fc-timegrid-body");
          let bodyHeight = body ? body.scrollHeight : 0;

          const headerEl = document.querySelector(".fc-col-header");
          const headerH = headerEl
            ? headerEl.getBoundingClientRect().height
            : 0;
          const axisEl = document.querySelector(".fc-timegrid-axis");
          const axisH = axisEl ? axisEl.getBoundingClientRect().height : 0;

          // choose maximum of the two measurements, add padding to cover
          // any rounding/edge pixels
          const contentH = Math.max(slotsHeight, bodyHeight);
          if (contentH <= 0) return;
          const target = contentH + headerH + axisH + 8;
          techCal.setOption("height", target);
        }
        function minToHHMM(m) {
          const h = Math.floor(m / 60);
          const mm = String(m % 60).padStart(2, "0");
          return String(h).padStart(2, "0") + ":" + mm;
        }
        function minTo12(m) {
          const h = Math.floor(m / 60);
          const mm = String(m % 60).padStart(2, "0");
          const period = h < 12 ? "AM" : "PM";
          const h12 = ((h + 11) % 12) + 1;
          return h12 + ":" + mm + " " + period;
        }
        function parseMinuteValue(value) {
          if (value === null || value === undefined) return NaN;
          const raw = String(value).trim();
          if (!raw) return NaN;
          if (/^\d{1,4}$/.test(raw)) return Number(raw);
          const hm = raw.match(/^(\d{1,2}):(\d{2})$/);
          if (hm) return Number(hm[1]) * 60 + Number(hm[2]);
          const ampm = raw.match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);
          if (ampm) {
            let hh = Number(ampm[1]) % 12;
            if (ampm[3].toUpperCase() === "PM") hh += 12;
            return hh * 60 + Number(ampm[2]);
          }
          return NaN;
        }
        function toCalendarTime(value, fallbackMinutes) {
          const mins = parseMinuteValue(value);
          if (Number.isFinite(mins)) return minToHHMM(mins) + ":00";
          return minToHHMM(fallbackMinutes) + ":00";
        }
        function mergeIntervals(intervals) {
          const sorted = (intervals || [])
            .filter((slot) => Number.isFinite(slot.start) && Number.isFinite(slot.end) && slot.end > slot.start)
            .sort((a, b) => a.start - b.start);
          const merged = [];
          sorted.forEach((slot) => {
            const last = merged[merged.length - 1];
            if (!last || slot.start > last.end) {
              merged.push({ start: slot.start, end: slot.end });
            } else {
              last.end = Math.max(last.end, slot.end);
            }
          });
          return merged;
        }
        function remainingIntervals(workStart, workEnd, bookedIntervals) {
          if (!Number.isFinite(workStart) || !Number.isFinite(workEnd) || workEnd <= workStart) return [];
          const clampedBooked = mergeIntervals(
            (bookedIntervals || []).map((slot) => ({
              start: Math.max(workStart, Number(slot.start)),
              end: Math.min(workEnd, Number(slot.end)),
            })),
          );
          const remaining = [];
          let cursor = workStart;
          clampedBooked.forEach((slot) => {
            if (slot.start > cursor) {
              remaining.push({ start: cursor, end: slot.start });
            }
            cursor = Math.max(cursor, slot.end);
          });
          if (cursor < workEnd) {
            remaining.push({ start: cursor, end: workEnd });
          }
          return remaining;
        }
        function isoDate(d) {
          // Use LOCAL date components to avoid UTC timezone shift (e.g. UTC+8
          // midnight = previous day in UTC, causing off-by-one on date keys)
          const dt = d instanceof Date ? d : new Date(String(d));
          const y = dt.getFullYear();
          const m = String(dt.getMonth() + 1).padStart(2, "0");
          const day = String(dt.getDate()).padStart(2, "0");
          return `${y}-${m}-${day}`;
        }
        function fmtDate(d) {
          return new Date(d).toLocaleDateString(undefined, {
            month: "short",
            day: "numeric",
            year: "numeric",
          });
        }
        function resolveServiceName(a) {
          if (!a) return "Appointment";
          if (a.serviceType === "core") return "Core Service";
          if (a.serviceType === "repair") return "Repair";
          if (typeof a.service === "string" && a.service.trim()) return a.service.trim();
          if (a.service && typeof a.service === "object") {
            return (
              a.service.name ||
              a.service.title ||
              a.service.serviceName ||
              a.service.label ||
              "Appointment"
            );
          }
          if (a.serviceId && typeof a.serviceId === "object") {
            return a.serviceId.name || a.serviceId.title || "Appointment";
          }
          if (typeof a.title === "string" && a.title.trim()) return a.title.trim();
          return "Appointment";
        }
        function resolveCustomerName(a) {
          if (!a) return "—";
          if (typeof a.customerName === "string" && a.customerName.trim()) return a.customerName.trim();
          if (a.customer && typeof a.customer === "object") {
            const full =
              a.customer.name ||
              a.customer.fullName ||
              `${a.customer.firstName || ""} ${a.customer.lastName || ""}`.trim();
            if (full) return full;
            if (a.customer.email) return a.customer.email;
          }
          if (typeof a.customer === "string" && a.customer.trim()) return a.customer.trim();
          return "—";
        }
        function resolveAddressText(a) {
          if (!a) return "—";
          const addr = a.location && a.location.address;
          if (typeof addr === "string" && addr.trim()) return addr.trim();
          if (addr && typeof addr === "object") {
            const joined = Object.values(addr)
              .filter((v) => v !== null && v !== undefined && String(v).trim() !== "")
              .join(", ");
            if (joined) return joined;
          }
          if (
            a.location &&
            a.location.coordinates &&
            Array.isArray(a.location.coordinates.coordinates)
          ) {
            const [lng, lat] = a.location.coordinates.coordinates.map(Number);
            if (Number.isFinite(lat) && Number.isFinite(lng)) {
              return `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
            }
          }
          if (typeof a.address === "string" && a.address.trim()) return a.address.trim();
          if (a.address && typeof a.address === "object") {
            const joined = Object.values(a.address)
              .filter((v) => v !== null && v !== undefined && String(v).trim() !== "")
              .join(", ");
            if (joined) return joined;
          }
          return "—";
        }
        function formatApptTimeRange(a) {
          const startMin = parseMinuteValue(a && a.startTime);
          const endMin = parseMinuteValue(a && a.endTime);
          if (Number.isFinite(startMin) && Number.isFinite(endMin) && endMin > startMin) {
            return `${minTo12(startMin)} – ${minTo12(endMin)}`;
          }
          if (Number.isFinite(startMin)) return minTo12(startMin);
          const rawStart = a && a.startTime ? String(a.startTime) : "";
          const rawEnd = a && a.endTime ? String(a.endTime) : "";
          if (rawStart && rawEnd) return `${rawStart} – ${rawEnd}`;
          if (rawStart) return rawStart;
          return "—";
        }
        function statusBadge(status) {
          const map = {
            confirmed: ["bg-success", "Confirmed"],
            pending: ["bg-warning text-dark", "Pending"],
            completed: ["bg-success", "Completed"],
            cancelled: ["bg-secondary", "Cancelled"],
            "re-scheduled": ["bg-info text-dark", "Re-scheduled"],
          };
          const [cls, label] = map[status] || ["bg-secondary", status];
          return `<span class="badge ${cls}">${label}</span>`;
        }

        /* ── state ───────────────────────────────────────────────────── */
        let techCal = null;
        let currentTechId = null;
        let loadingCtrl = null;
        const technicianIdentityMap = new Map();

        /* ── FullCalendar loader ─────────────────────────────────────── */
        async function ensureFC() {
          if (window.FullCalendar && window.FullCalendar.Calendar) return;
          // FullCalendar v6 global build injects its own CSS — no separate
          // CSS file needed. Load JS only.
          // IMPORTANT: v6 uses index.global.min.js (main.min.js does not exist in v6)
          const sources = [
            "https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js",
            "/vendor/fullcalendar/main.min.js", // offline stub fallback
          ];

          await new Promise((resolve, reject) => {
            const load = (srcs) => {
              if (!srcs.length)
                return reject(new Error("FullCalendar failed to load"));
              const s = document.createElement("script");
              s.src = srcs[0];
              s.async = true;
              try {
                s.crossOrigin = "anonymous";
              } catch (_) {}
              s.onload = resolve;
              s.onerror = () => setTimeout(() => load(srcs.slice(1)), 50);
              document.head.appendChild(s);
            };
            load(sources);
          });
        }

        /* ── Init calendar ───────────────────────────────────────────── */
        async function initCalendar() {
          await ensureFC();
          const FC = window.FullCalendar;
          const el = $("techCalendar");
          if (!el || techCal) return;

          console.log(
            "[Calendar] Initializing FullCalendar v" +
              (FC.version || "unknown"),
          );
          console.log("[Calendar] FullCalendar object:", FC);

          techCal = new FC.Calendar(el, {
            initialView: "timeGridWeek",
            themeSystem: "bootstrap",
            height: "100%",
            nowIndicator: false,
            eventDisplay: "block",
            events: [],
            businessHours: false,
            fixedWeekCount: false, // drop extra blank rows at month start/end
            headerToolbar: {
              left: "prev,next today",
              center: "title",
              right: "timeGridWeek,timeGridDay,dayGridMonth",
            },
            buttonText: {
              prev: "‹",
              next: "›",
              today: "Today",
              month: "Month",
              week: "Week",
              day: "Day",
            },
            buttonIcons: false,
            dayMaxEvents: 4,
            moreLinkContent: (args) => `+${args.num} more`,
            slotMinTime: "06:00:00",
            slotMaxTime: "20:00:00",
            slotDuration: "01:00:00",
            slotLabelInterval: "01:00",
            slotLabelFormat: {
              hour: "numeric",
              minute: "2-digit",
              hour12: true,
              meridiem: "short",
            },
            eventTimeFormat: {
              hour: "numeric",
              minute: "2-digit",
              hour12: true,
            },
            allDaySlot: false,
            viewDidMount: function (info) {
              // called after a view is mounted in the DOM –
              // ensure the grid measures correctly after CSS settles
              setTimeout(() => {
                if (techCal) techCal.updateSize();
              }, 60);
            },
            datesSet: function (info) {
              if (!currentTechId) return;
              adjustLayoutForWeekView(info.view);
              const start = isoDate(info.view.activeStart);
              const end = isoDate(
                new Date(info.view.activeEnd.getTime() - 86400000),
              );
              loadCalendarData(currentTechId, start, end);
            },
            eventClick: function (info) {
              const appt = info.event.extendedProps.appointment;
              if (!appt) {
                showInfoModal(info.event);
                return;
              }
              openApptModal(appt);
            },
          });
          techCal.render();
          // ensure the height matches the freshly rendered slots
          adjustTimegridHeight();

          /* keep calendar size in sync whenever the container dimensions
             change (sidebar toggle, CSS transitions, window resize, etc.) */
          const _calEl = $("techCalendar");
          if (_calEl && window.ResizeObserver) {
            let _rTick = 0;
            new ResizeObserver(() => {
              cancelAnimationFrame(_rTick);
              _rTick = requestAnimationFrame(() => {
                if (techCal) techCal.updateSize();
              });
            }).observe(_calEl);
          }
        }

        /* ── Load technician list from DB ───────────────────────────── */
        async function loadTechnicians() {
          try {
            const r = await fetch("/api/admin/technicians", {
              cache: "no-store",
            });
            if (!r.ok) throw new Error("HTTP " + r.status);
            const j = await r.json();
            const sel = $("techSelect");
            const prev = sel.value; // preserve current selection if any
            sel.innerHTML = '<option value="">Select a technician</option>';
            technicianIdentityMap.clear();
            const techs = j.technicians || [];
            if (!techs.length) {
              const opt = document.createElement("option");
              opt.disabled = true;
              opt.textContent = "No technicians found in database";
              sel.appendChild(opt);
              return;
            }
            techs.forEach((t) => {
              const name =
                t.name ||
                ((t.firstName || "") + " " + (t.lastName || "")).trim() ||
                t.email ||
                t._id;
              const opt = document.createElement("option");
              opt.value = t._id;
              opt.textContent =
                name + (t.active === false ? " \u2014 inactive" : "");
              if (t.active === false) opt.style.color = "#9ca3af";
              sel.appendChild(opt);
              technicianIdentityMap.set(String(t._id), {
                id: String(t._id),
                user: t.user ? String(t.user) : "",
              });
            });
            // restore previous selection after reload
            if (prev) sel.value = prev;
          } catch (e) {
            console.warn("loadTechnicians:", e);
            const sel = $("techSelect");
            sel.innerHTML =
              '<option value="" disabled>\u26a0 Failed to load technicians</option>';
          }
        }

        /* ── Load schedule from scheduling configuration ─────────────── */
        async function loadScheduleInfo(techId) {
          if (!techId) return;
          try {
            // fetch the technician's schedule from the scheduling config
            const [schedRes, holidayRes] = await Promise.all([
              fetch(
                "/api/admin/technician-schedules/" + encodeURIComponent(techId),
                { cache: "no-store" },
              ),
              fetch("/api/admin/dayoffs", { cache: "no-store" }),
            ]);

            const schedJson = schedRes.ok ? await schedRes.json() : null;
            const holidayJson = holidayRes.ok ? await holidayRes.json() : null;

            const schedule = schedJson
              ? schedJson.schedule || {
                  workingDays: [],
                  nonWorkingWeekdays: [],
                  restDates: [],
                }
              : { workingDays: [], nonWorkingWeekdays: [], restDates: [] };

            // /api/admin/dayoffs returns { dayoffs: [...] }
            const rawHolidays = holidayJson ? holidayJson.dayoffs || [] : [];

            // normalise holiday dates to YYYY-MM-DD strings
            const normHolidays = rawHolidays.map((h) => ({
              ...h,
              date:
                typeof h.date === "string"
                  ? h.date.slice(0, 10)
                  : new Date(h.date).toISOString().slice(0, 10),
              reason: h.note || h.reason || "Holiday",
            }));

            renderWorkingDays(
              schedule.workingDays,
              schedule.nonWorkingWeekdays || [],
            );
            renderRestAndHolidays(
              schedule.restDates,
              normHolidays,
              schedule.workingDays,
              schedule.nonWorkingWeekdays || [],
              new Set(), // no busy info yet
            );
            updateStats(schedule.workingDays, 0, 0); // booking counts updated via loadCalendarData
          } catch (e) {
            console.warn("loadScheduleInfo:", e);
          }
        }

        /* ── Load calendar data for a date range ─────────────────────── */
        async function loadCalendarData(techId, start, end) {
          if (!techCal) return;
          if (loadingCtrl) {
            loadingCtrl.abort();
          }
          loadingCtrl = new AbortController();
          const signal = loadingCtrl.signal;
          showCalSpinner(true);
          try {
            const schedRes = await fetch(
              `/api/admin/technicians/${encodeURIComponent(techId)}/calendar?start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`,
              { cache: "no-store", signal },
            );
            if (!schedRes.ok) throw new Error("schedule fetch failed");
            const data = await schedRes.json();
            console.log("[Calendar] Schedule data:", data);

            // pull technician appointments, but keep only confirmed + pending for this calendar view
            const apptRes = await fetch(
              "/api/appointments?limit=500",
              {
                cache: "no-store",
                signal,
              },
            );
            let appointments = [];
            if (apptRes.ok) {
              const aj = await apptRes.json();
              console.log(
                "[Calendar] All appointments count:",
                (aj.items || aj.appointments || []).length,
              );
              const selectedTech = technicianIdentityMap.get(String(techId));
              const allowedIds = new Set([String(techId)]);
              if (selectedTech && selectedTech.user) {
                allowedIds.add(String(selectedTech.user));
              }

              appointments = (aj.items || aj.appointments || []).filter((a) => {
                const ids = [];
                if (a.technicianId) {
                  if (typeof a.technicianId === "string") {
                    ids.push(String(a.technicianId));
                  } else {
                    if (a.technicianId._id) ids.push(String(a.technicianId._id));
                    if (a.technicianId.user) ids.push(String(a.technicianId.user));
                  }
                }
                if (a.technician && a.technician._id) {
                  ids.push(String(a.technician._id));
                }
                const status = String(a.status || "").toLowerCase();
                return (
                  ids.some((id) => allowedIds.has(String(id))) &&
                  ["confirmed", "pending"].includes(status)
                );
              });
              console.log(
                "[Calendar] Filtered appointments for tech",
                techId,
                ":",
                appointments.length,
                appointments,
              );
            }
            // build busy date set (any appointment on that day)
            const busySet = new Set();
            appointments.forEach((a) => {
              const dRaw = a.bookingDate || a.date || a.start || new Date();
              const iso = isoDate(dRaw);
              busySet.add(iso);
            });

            /* ── Batch removeAll + addEvent calls so the grid redraws
               only once, preventing partial-column / clipping issues ── */
            techCal.batchRendering(() => {
              techCal.removeAllEvents();
              _batchAddEvents(data, appointments, busySet);
            }); // end batchRendering

            /* wrap the event-building logic so batchRendering can call it */
            function _batchAddEvents(data, appointments, busySet) {
              const schedule = data.schedule || {
                workingDays: [],
                restDates: [],
              };
              const holidays = data.holidays || [];
              console.log("[Calendar] Working days:", schedule.workingDays);
              console.log("[Calendar] Rest dates:", schedule.restDates);
              console.log("[Calendar] Holidays:", holidays);
              const holidaySet = new Set(holidays.map((h) => h.date || ""));
              const restSet = new Set(
                (schedule.restDates || []).map((r) =>
                  typeof r === "string" ? r : r.date || "",
                ),
              );
              const nonWeekSet = new Set(
                (schedule.nonWorkingWeekdays || []).map((n) => Number(n)),
              );
              console.log(
                "[Calendar] Weekly non-working weekdays:",
                Array.from(nonWeekSet),
              );
              console.log("[Calendar] Holiday set:", Array.from(holidaySet));
              console.log("[Calendar] Rest set:", Array.from(restSet));

              const sDate = new Date(start + "T00:00:00");
              const eDate = new Date(end + "T00:00:00");

              const todayKey = isoDate(new Date());
              // helper for time-grid column shading
              const isTimeGrid =
                techCal.view &&
                (techCal.view.type === "timeGridWeek" ||
                  techCal.view.type === "timeGridDay");
              const nextDayKey = (k) => {
                const nd = new Date(k + "T00:00:00");
                nd.setDate(nd.getDate() + 1);
                return isoDate(nd);
              };

              const bookedIntervalsByDate = new Map();
              appointments.forEach((a) => {
                const dateKey = isoDate(a.bookingDate || a.date || a.start || new Date());
                const startMin = parseMinuteValue(a.startTime);
                if (!Number.isFinite(startMin)) return;
                const rawEndMin = parseMinuteValue(a.endTime);
                const endMin = Number.isFinite(rawEndMin) && rawEndMin > startMin ? rawEndMin : startMin + 60;
                const current = bookedIntervalsByDate.get(dateKey) || [];
                current.push({ start: startMin, end: endMin });
                bookedIntervalsByDate.set(dateKey, current);
              });

              for (
                let d = new Date(sDate);
                d <= eDate;
                d.setDate(d.getDate() + 1)
              ) {
                const key = isoDate(d);
                // past dates should not be marked available
                if (key < todayKey) {
                  console.log("[Calendar] Skipping past date", key);
                  techCal.addEvent({
                    id: "past_" + key,
                    start: key,
                    allDay: true,
                    display: "background",
                    backgroundColor: "#f1f5f9", // gray like non-working
                    classNames: ["ts-bg-gray"],
                    extendedProps: { type: "past" },
                  });
                  if (isTimeGrid) {
                    techCal.addEvent({
                      id: "past_shade_" + key,
                      start: key + "T00:00:00",
                      end: nextDayKey(key) + "T00:00:00",
                      display: "background",
                      backgroundColor: "#f1f5f9",
                      classNames: ["ts-bg-gray"],
                      extendedProps: { type: "past" },
                    });
                  }
                  continue;
                }
                const dow = d.getDay();
                const rule = (schedule.workingDays || []).find(
                  (w) => Number(w.dayOfWeek) === dow,
                );

                if (holidaySet.has(key)) {
                  const hol = holidays.find((h) => h.date === key) || {};
                  techCal.addEvent({
                    id: "hol_" + key,
                    title: hol.reason || hol.note || "Holiday",
                    start: key,
                    allDay: true,
                    display: "block",
                    backgroundColor: "#f1f5f9",
                    borderColor: "#d1d5db",
                    textColor: "#111827", // dark text for holiday label
                    extendedProps: { type: "holiday" },
                  });
                  if (isTimeGrid) {
                    techCal.addEvent({
                      id: "hol_shade_" + key,
                      start: key + "T00:00:00",
                      end: nextDayKey(key) + "T00:00:00",
                      display: "background",
                      classNames: ["ts-bg-gray"],
                      extendedProps: { type: "holiday" },
                    });
                  }
                  continue;
                }
                if (restSet.has(key)) {
                  const rd =
                    (schedule.restDates || []).find(
                      (r) => (typeof r === "string" ? r : r.date) === key,
                    ) || {};
                  techCal.addEvent({
                    id: "rest_" + key,
                    title: rd.reason || "Rest day",
                    start: key,
                    allDay: true,
                    display: "block",
                    backgroundColor: "#f1f5f9",
                    borderColor: "#d1d5db",
                    textColor: "#6b7280",
                    extendedProps: { type: "rest" },
                  });
                  if (isTimeGrid) {
                    techCal.addEvent({
                      id: "rest_shade_" + key,
                      start: key + "T00:00:00",
                      end: nextDayKey(key) + "T00:00:00",
                      display: "background",
                      classNames: ["ts-bg-gray"],
                      extendedProps: { type: "rest" },
                    });
                  }
                  continue;
                }
                if (nonWeekSet.has(dow)) {
                  techCal.addEvent({
                    id: "weekoff_" + key,
                    title: "Weekly off",
                    start: key,
                    allDay: true,
                    display: "block",
                    backgroundColor: "#f1f5f9",
                    borderColor: "#d1d5db",
                    textColor: "#6b7280",
                    extendedProps: { type: "weekly-nonworking" },
                  });
                  if (isTimeGrid) {
                    techCal.addEvent({
                      id: "weekoff_shade_" + key,
                      start: key + "T00:00:00",
                      end: nextDayKey(key) + "T00:00:00",
                      display: "background",
                      classNames: ["ts-bg-nonwork-yellow"],
                      extendedProps: { type: "weekly-nonworking" },
                    });
                  }
                  continue;
                }
                if (nonWeekSet.has(dow)) {
                  techCal.addEvent({
                    id: "weekoff_" + key,
                    start: key,
                    allDay: true,
                    display: "background",
                    // weekly off should use distinct colour even in month view
                    classNames: ["ts-bg-weekly-nonwork"],
                    extendedProps: { type: "weekly-nonworking" },
                  });
                  if (isTimeGrid) {
                    techCal.addEvent({
                      id: "weekoff_shade_" + key,
                      start: key + "T00:00:00",
                      end: nextDayKey(key) + "T00:00:00",
                      display: "background",
                      classNames: ["ts-bg-nonwork-yellow"],
                      extendedProps: { type: "weekly-nonworking" },
                    });
                  }
                  continue;
                }
                if (rule) {
                  const workStart = Number(rule.startMinutes);
                  const workEnd = Number(rule.endMinutes);
                  const bookedDayIntervals = bookedIntervalsByDate.get(key) || [];
                  const remainingSlots = remainingIntervals(
                    workStart,
                    workEnd,
                    bookedDayIntervals,
                  );
                  const hasBookedSlots = bookedDayIntervals.length > 0;
                  const startIso = key + "T" + minToHHMM(workStart) + ":00";
                  const endIso = key + "T" + minToHHMM(workEnd) + ":00";

                  if (techCal.view && techCal.view.type === "dayGridMonth") {
                    techCal.addEvent({
                      id: "avail_bg_" + key,
                      start: key,
                      allDay: true,
                      display: "background",
                      backgroundColor: hasBookedSlots ? "#fef3c7" : "#dcfce7",
                      extendedProps: { type: "work_bg" },
                    });
                    if (remainingSlots.length) {
                      techCal.addEvent({
                        id: "avail_" + key,
                        title: remainingSlots
                          .map((slot) => `${minTo12(slot.start)}–${minTo12(slot.end)}`)
                          .join("\n"),
                        start: startIso,
                        end: endIso,
                        display: "block",
                        backgroundColor: "#16a34a",
                        borderColor: "#15803d",
                        textColor: "#ffffff",
                        extendedProps: { type: "available" },
                      });
                    } else {
                      techCal.addEvent({
                        id: "full_" + key,
                        title: "Fully booked",
                        start: startIso,
                        end: endIso,
                        display: "block",
                        backgroundColor: "#f59e0b",
                        borderColor: "#d97706",
                        textColor: "#111827",
                        extendedProps: { type: "fully-booked" },
                      });
                    }
                  } else {
                    if (!remainingSlots.length) {
                      techCal.addEvent({
                        id: "full_bg_" + key,
                        start: startIso,
                        end: endIso,
                        display: "background",
                        backgroundColor: "#fef3c7",
                        extendedProps: { type: "work_bg_full" },
                      });
                    } else {
                      remainingSlots.forEach((slot, idx) => {
                        techCal.addEvent({
                          id: `avail_bg_${key}_${idx}`,
                          start: key + "T" + minToHHMM(slot.start) + ":00",
                          end: key + "T" + minToHHMM(slot.end) + ":00",
                          display: "background",
                          backgroundColor: "#dcfce7",
                          extendedProps: { type: "work_bg" },
                        });
                      });
                    }
                  }
                } else {
                  techCal.addEvent({
                    id: "nonwork_" + key,
                    start: key,
                    allDay: true,
                    display: "background",
                    backgroundColor: "#f1f5f9",
                    classNames: ["ts-bg-gray"],
                    extendedProps: { type: "nonworking" },
                  });
                  if (isTimeGrid) {
                    techCal.addEvent({
                      id: "nonwork_shade_" + key,
                      start: key + "T00:00:00",
                      end: nextDayKey(key) + "T00:00:00",
                      display: "background",
                      backgroundColor: "#f1f5f9",
                      classNames: ["ts-bg-gray"],
                      extendedProps: { type: "nonworking" },
                    });
                  }
                }
              }

              let bookedCount = 0,
                pendingCount = 0;
              console.log(
                "[Calendar] Adding",
                appointments.length,
                "appointment events...",
              );
              appointments.forEach((a, idx) => {
                try {
                  const dateRaw =
                    a.bookingDate || a.date || a.start || new Date();
                  // Use isoDate() to avoid UTC timezone shift (consistent with calendar keys)
                  const dateKey = isoDate(dateRaw);
                  const startISO = dateKey + "T" + toCalendarTime(a.startTime, 9 * 60);
                  const endMins = parseMinuteValue(a.endTime);
                  const startMins = parseMinuteValue(a.startTime);
                  const safeEnd = Number.isFinite(endMins)
                    ? endMins
                    : (Number.isFinite(startMins) ? startMins + 60 : 10 * 60);
                  const endISO = dateKey + "T" + toCalendarTime(safeEnd, 10 * 60);
                  const status = String(a.status || "confirmed").toLowerCase();
                  const service = resolveServiceName(a);
                  const customer = resolveCustomerName(a);
                  const colorMap = {
                    confirmed: {
                      bg: "#fde68a",
                      border: "#f59e0b",
                    }, // yellow – booked
                    pending: {
                      bg: "#fde68a",
                      border: "#f59e0b",
                    }, // yellow – booked
                  };
                  const c = colorMap[status] || colorMap.confirmed;
                  if (["confirmed", "pending"].includes(status)) bookedCount++;
                  if (status === "pending") pendingCount++;
                  const ev = {
                    id: a._id || "appt_" + idx,
                    title: `${service} • ${customer}`,
                    start: startISO,
                    allDay: false,
                    backgroundColor: c.bg,
                    borderColor: c.border,
                    textColor: "#111827",
                    extendedProps: {
                      type: "appointment",
                      appointment: a,
                      status,
                    },
                  };
                  if (endISO) ev.end = endISO;
                  console.log("[Calendar] Adding appointment event:", ev);
                  techCal.addEvent(ev);
                } catch (e) {
                  console.warn("add appt event:", e);
                }
              });

              renderWorkingDays(
                schedule.workingDays,
                schedule.nonWorkingWeekdays || [],
              );
              renderRestAndHolidays(
                schedule.restDates,
                holidays,
                schedule.workingDays,
                schedule.nonWorkingWeekdays || [],
                busySet,
              );
              updateStats(schedule.workingDays, bookedCount, pendingCount);

              const bh = (schedule.workingDays || []).map((w) => ({
                daysOfWeek: [Number(w.dayOfWeek)],
                startTime: minToHHMM(Number(w.startMinutes || 480)),
                endTime: minToHHMM(Number(w.endMinutes || 1020)),
              }));
              techCal.setOption("businessHours", bh);
            } // end _batchAddEvents
          } catch (e) {
            if (e.name === "AbortError") return;
            console.error("loadCalendarData failed:", e);
          } finally {
            showCalSpinner(false);
            // force FullCalendar to recalculate grid columns / row heights
            if (techCal) {
              setTimeout(() => {
                if (techCal) techCal.updateSize();
              }, 0);
              setTimeout(() => {
                if (techCal) techCal.updateSize();
              }, 200);
            }
            const allEvents = techCal.getEvents ? techCal.getEvents() : [];
            console.log(
              "[Calendar] Final event count on calendar:",
              allEvents.length,
            );
            if (allEvents.length > 0) {
              console.log(
                "[Calendar] Sample events:",
                allEvents.slice(0, 5).map((e) => ({
                  id: e.id,
                  title: e.title,
                  start: e.start,
                  type: e.extendedProps?.type,
                })),
              );
            }
          }
        }

        /* ── Render info cards ──────────────────────────────────────── */
        function renderWorkingDays(workingDays, nonWorkingWeekdays) {
          const el = $("workingDaysList");
          if (
            (!workingDays || !workingDays.length) &&
            (!nonWorkingWeekdays || !nonWorkingWeekdays.length)
          ) {
            el.innerHTML =
              '<span class="text-muted">No working day rules configured.</span>';
            return;
          }
          let html = "";
          if (workingDays && workingDays.length) {
            const sorted = [...workingDays].sort(
              (a, b) => Number(a.dayOfWeek) - Number(b.dayOfWeek),
            );
            html += sorted
              .map((w) => {
                const from = minTo12(Number(w.startMinutes || 480));
                const to = minTo12(Number(w.endMinutes || 1020));
                const hrs = ((w.endMinutes - w.startMinutes) / 60).toFixed(1);
                return `<div class="ts-wd-row">
        <span class="ts-wd-day">${DAY_SHORT[Number(w.dayOfWeek)]}</span>
        <span class="ts-wd-time">${from} \u2013 ${to}</span>
        <span class="text-muted" style="font-size:0.75rem">${hrs}h</span>
      </div>`;
              })
              .join("");
          }
          if (nonWorkingWeekdays && nonWorkingWeekdays.length) {
            const names = nonWorkingWeekdays
              .map((d) => DAY_SHORT[Number(d)])
              .join(", ");
            html += `<div class="ts-wd-row">
        <span class="ts-wd-day text-warning">Off</span>
        <span class="ts-wd-time">${names}</span>
      </div>`;
          }
          el.innerHTML = html;
        }

        function renderRestAndHolidays(
          restDates,
          holidays,
          workingDays,
          nonWorkingWeekdays,
          busySet,
        ) {
          const el = $("restDatesList");
          const today = isoDate(new Date());
          // show weekday names for weekly offs
          const weekNames = (nonWorkingWeekdays || [])
            .map((n) => DAY_SHORT[Number(n)])
            .filter(Boolean);

          // upcoming rest dates
          const restArr = [];
          (restDates || []).forEach((r) => {
            const d = typeof r === "string" ? r : r.date;
            if (d && d >= today) {
              let label = (r.reason && r.reason.trim()) || "Rest";
              if (busySet && busySet.has(d)) label += " / Busy";
              restArr.push({ date: d, label });
            }
          });

          // upcoming holidays
          const holArr = [];
          (holidays || []).forEach((h) => {
            if (h.date >= today) {
              holArr.push({
                date: h.date,
                label: (h.reason && h.reason.trim()) || h.note || "Holiday",
              });
            }
          });

          if (!weekNames.length && !restArr.length && !holArr.length) {
            el.innerHTML =
              '<span class="text-muted">No upcoming rest dates or holidays.</span>';
            return;
          }

          let html = "";
          if (weekNames.length) {
            html += `<div class="ts-rd-section">Weekly off: ${weekNames.join(", ")}</div>`;
          }
          if (restArr.length) {
            html += '<div class="ts-rd-section">Rest dates</div>';
            html += restArr
              .map(
                (r) =>
                  `<div class="ts-rd-row"><span class="ts-rd-date">${r.date}</span><span class="ts-rd-reason">${r.label}</span></div>`,
              )
              .join("");
          }
          if (holArr.length) {
            html += '<div class="ts-rd-section">Holidays</div>';
            html += holArr
              .map(
                (h) =>
                  `<div class="ts-rd-row"><span class="ts-rd-date">${h.date}</span><span class="ts-rd-reason">${h.label}</span></div>`,
              )
              .join("");
          }
          el.innerHTML = html;
        }
        function updateStats(workingDays, booked, pending) {
          const now = new Date();
          const year = now.getFullYear();
          const month = now.getMonth();
          const daysInMonth = new Date(year, month + 1, 0).getDate();
          const workSet = new Set(
            (workingDays || []).map((w) => Number(w.dayOfWeek)),
          );
          let workCount = 0;
          for (let d = 1; d <= daysInMonth; d++) {
            if (workSet.has(new Date(year, month, d).getDay())) workCount++;
          }
          $("statWorkDays").textContent = workCount;
          $("statBooked").textContent = booked;
          $("statPending").textContent = pending;
        }

        /* ── Spinner ────────────────────────────────────────────────── */

        /* ensure modal sits above everything */
        const css = document.createElement('style');
        css.textContent = 
          '.modal { z-index: 2000 !important; } ' +
          '.modal-backdrop { z-index: 1500 !important; backdrop-filter: none !important; }';
        document.head.appendChild(css);
        function showCalSpinner(show) {
          const card = document.querySelector(".ts-cal-card");
          if (!card) return;
          let sp = card.querySelector(".ts-spinner-wrap");
          if (show) {
            if (!sp) {
              sp = document.createElement("div");
              sp.className = "ts-spinner-wrap";
              sp.innerHTML =
                '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading\u2026</span></div>';
              card.appendChild(sp);
            }
          } else {
            if (sp) sp.remove();
          }
        }

        /* ── Event modals ────────────────────────────────────────────── */
        function showInfoModal(event) {
          // if sidebar backdrop is still visible, hide it so the modal isn't blocked
          if (window.hideBackdrop) hideBackdrop();
          const type = (event.extendedProps || {}).type;
          const titles = {
            holiday: "Holiday",
            rest: "Rest Day",
            available: "Available",
            work_bg: "Working Day",
          };
          const titleText = titles[type] || event.title || "";
          $("apptModalTitle").textContent = titleText;

          // build a more structured body using the existing grid styles
          let details = `<div class="appt-detail-grid">`;
          if (event.title) {
            details +=
              `<span class="appt-detail-label"><i class="bi bi-clock-history me-1 text-primary"></i>Time</span>` +
              `<span class="appt-detail-val">${event.title}</span>`;
          }
          details += `</div>`;
          $("apptModalBody").innerHTML = details;
          $("apptModalLink").classList.add("d-none");
          bootstrap.Modal.getOrCreateInstance($("apptDetailModal")).show();
        }

        function openApptModal(a) {
          if (window.hideBackdrop) hideBackdrop();
          const status = String(a.status || "confirmed").toLowerCase();
          const service = resolveServiceName(a);
          const customer = resolveCustomerName(a);
          const date = a.bookingDate ? fmtDate(a.bookingDate) : "\u2014";
          const timeRange = formatApptTimeRange(a);
          const payment = a.paymentMethod || "\u2014";
          const address = resolveAddressText(a);
          $("apptModalTitle").textContent = service;
          $("apptModalBody").innerHTML = `
      <div class="d-flex align-items-center gap-2 mb-3">
        ${statusBadge(status)}
        <span class="text-muted small">#${String(a._id || "").slice(-6)}</span>
      </div>
      <div class="appt-detail-grid">
        <span class="appt-detail-label">Service</span>   <span class="appt-detail-val">${service}</span>
        <span class="appt-detail-label">Date</span>      <span class="appt-detail-val">${date}</span>
        <span class="appt-detail-label"><i class="bi bi-clock-history me-1 text-primary"></i></span><span class="appt-detail-val">${timeRange}</span>
        <span class="appt-detail-label">Customer</span>  <span class="appt-detail-val">${customer}</span>
        <span class="appt-detail-label">Payment</span>
        <span class="appt-detail-val" style="text-transform:uppercase">
          ${payment}
          ${a.paymentMethod === "cash" && a.downpaymentAmount ? `(down ₱${Number(a.downpaymentAmount).toLocaleString()})` : ""}
          ${a.paymentMethod === "cash" && !a.downpaymentAmount ? `<span class="text-danger small ms-1">(no downpayment)</span>` : ""}
        </span>
        <span class="appt-detail-label">Address</span>   <span class="appt-detail-val">${address}</span>
      </div>`;
          const link = $("apptModalLink");
          if (a._id) {
            link.href = "/admin/appointments/" + a._id;
            link.classList.remove("d-none");
          } else {
            link.classList.add("d-none");
          }
          bootstrap.Modal.getOrCreateInstance($("apptDetailModal")).show();
        }

        /* ── Technician change ───────────────────────────────────────── */
        $("techSelect").addEventListener("change", async function () {
          const techId = this.value;
          currentTechId = techId || null;
          if (!techId) {
            // no tech selected → reset everything
            $("calPlaceholder").classList.remove("d-none");
            $("btnRefresh").classList.add("d-none");
            $("techInfoBadge").classList.add("d-none");
            $("workingDaysList").innerHTML =
              '<span class="text-muted">Select a technician to see their schedule.</span>';
            $("restDatesList").innerHTML =
              '<span class="text-muted">No exceptions found.</span>';
            $("statWorkDays").textContent = "\u2014";
            $("statBooked").textContent = "\u2014";
            $("statPending").textContent = "\u2014";
            if (techCal) {
              techCal.removeAllEvents();
              techCal.setOption("businessHours", false);
            }
            // hide legend when calendar empty
            const legend = document.querySelector(".ts-legend");
            if (legend) legend.classList.add("d-none");
            return;
          }
          // tech selected – ensure legend visible
          const legend = document.querySelector(".ts-legend");
          if (legend) legend.classList.remove("d-none");
          const selOpt = this.options[this.selectedIndex];
          // Show tech name in badge, strip the " — inactive" suffix for display
          $("techBadgeName").textContent = selOpt.textContent.replace(
            / \u2014 inactive$/,
            "",
          );
          const isActive = !selOpt.textContent.includes("\u2014 inactive");
          $("techBadgeStatus").textContent = isActive ? "Active" : "Inactive";
          $("techBadgeStatus").className =
            "badge ms-2 " + (isActive ? "bg-success" : "bg-secondary");
          $("techInfoBadge").classList.remove("d-none");
          $("btnRefresh").classList.remove("d-none");
          $("calPlaceholder").classList.add("d-none");

          // ① Immediately populate info panel from scheduling config (no date range needed)
          loadScheduleInfo(techId);

          // ② Initialize calendar (loads FullCalendar if needed) and trigger data fetch
          const calExisted = !!techCal;
          await initCalendar();
          if (techCal) {
            adjustLayoutForWeekView(techCal.view);
            techCal.updateSize();
            // If calendar already existed (switching techs), datesSet won't
            // fire from render(), so explicitly reload data.
            if (calExisted) {
              const view = techCal.view;
              const start = isoDate(view.activeStart);
              const end = isoDate(
                new Date(view.activeEnd.getTime() - 86400000),
              );
              loadCalendarData(techId, start, end);
            }
          }
        });

        $("btnRefresh").addEventListener("click", () => {
          if (!currentTechId || !techCal) return;
          const view = techCal.view;
          const start = isoDate(view.activeStart);
          const end = isoDate(new Date(view.activeEnd.getTime() - 86400000));
          loadCalendarData(currentTechId, start, end);
        });

        /* ── Init ────────────────────────────────────────────────────── */
        // move modal element to body so it's not constrained by parent stacking
        document.addEventListener("DOMContentLoaded", () => {
          const modalEl = document.getElementById("apptDetailModal");
          if (modalEl && modalEl.parentElement !== document.body) {
            document.body.appendChild(modalEl);
          }
        });
        // Only load the technician list. The calendar is initialised lazily when
        // the first technician is selected so that datesSet fires with
        // currentTechId already set and immediately populates the calendar.
        loadTechnicians();
        // legend should be hidden until a tech is chosen
        const lg = document.querySelector(".ts-legend");
        if (lg) lg.classList.add("d-none");

        window.addEventListener("storage", (e) => {
          if (e.key !== "techScheduleUpdated" || !currentTechId || !techCal)
            return;
          try {
            const msg = JSON.parse(e.newValue || "{}");
            if (
              msg.technicianId === "ALL" ||
              msg.technicianId === currentTechId
            ) {
              const view = techCal.view;
              const start = isoDate(view.activeStart);
              const end = isoDate(
                new Date(view.activeEnd.getTime() - 86400000),
              );
              loadCalendarData(currentTechId, start, end);
            }
          } catch (_) {}
        });

        /* ── Sidebar fold/unfold: tell FullCalendar to recalculate ──── */
        const sidebarToggleBtn = document.getElementById("sidebarToggle");
        if (sidebarToggleBtn) {
          sidebarToggleBtn.addEventListener("click", () => {
            // wait for the CSS transition to finish (~420ms)
            setTimeout(() => {
              if (techCal) techCal.updateSize();
            }, 450);
          });
        }
      })();
    </script>
  </div>
  <!-- /.ts-page -->
</div>
<!-- /.admin-dashboard -->
