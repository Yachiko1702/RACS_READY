<div class="admin-dashboard secretary-dashboard container-fluid px-0 py-4">
  <%- include('../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-speedometer2 me-2"></i>Secretary Dashboard
        </h1>
        <p class="hero-sub small">
          Welcome back, <%= typeof user !== 'undefined' && user ? user.email :
          'Secretary' %>
        </p>
      </div>
    </div>
  </div>

  <!-- Analytics cards -->
  <div class="d-flex align-items-center justify-content-between mb-2">
    <span class="section-label">Analytics</span>
    <button id="btn-refresh" class="btn btn-sm btn-outline-secondary" title="Refresh metrics">
      <i class="bi bi-arrow-clockwise"></i>
    </button>
  </div>
  <div class="row mb-4 g-3 kpi-row align-items-stretch">
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#4361ee,#3a0ca3)">
            <i class="bi bi-calendar-event"></i>
          </div>
          <div>
            <div class="kpi-label">Bookings</div>
            <div class="kpi-value" id="kpi-today-appointments">—</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#4361ee,#3a0ca3)"></div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#ff9f1c,#e76f0d)">
            <i class="bi bi-hourglass-split"></i>
          </div>
          <div>
            <div class="kpi-label">Pending</div>
            <div class="kpi-value" id="kpi-pending-bookings">—</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#ff9f1c,#e76f0d)"></div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#7b2d8b,#560bad)">
            <i class="bi bi-check2-circle"></i>
          </div>
          <div>
            <div class="kpi-label">Confirmed</div>
            <div class="kpi-value" id="kpi-active-jobs">—</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#7b2d8b,#560bad)"></div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#2ec4b6,#1a8f85)">
            <i class="bi bi-check-circle-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Completed</div>
            <div class="kpi-value" id="kpi-completed-jobs">—</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#2ec4b6,#1a8f85)"></div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#e63946,#b91c2a)">
            <i class="bi bi-exclamation-triangle-fill"></i>
          </div>
          <div>
            <div class="kpi-label">Low Stock</div>
            <div class="kpi-value" id="kpi-lowstock">—</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#e63946,#b91c2a)"></div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-xl-2">
      <div class="kpi-card">
        <div class="d-flex align-items-center gap-3">
          <div class="kpi-icon" style="background:linear-gradient(135deg,#212529,#495057)">
            <i class="bi bi-currency-dollar"></i>
          </div>
          <div>
            <div class="kpi-label">Revenue</div>
            <div class="kpi-value" id="kpi-revenue-today">—</div>
          </div>
        </div>
        <div class="kpi-bar" style="background:linear-gradient(90deg,#212529,#495057)"></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/secretary-dashboard.js"></script>
