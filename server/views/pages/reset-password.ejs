<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
      <div class="card shadow-sm border-0 auth-card-wide reset-card">
        <div class="card-header bg-primary text-white text-center">
          <h1 class="h4 fw-bold mb-1">Reset your password</h1>
        </div>
        <div class="card-body p-5">
          <div id="resetAlert" class="alert d-none" role="alert"></div>

          <form
            id="resetForm"
            action="/api/auth/reset-password"
            method="POST"
            autocomplete="on"
            novalidate
          >
            <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
            <input type="hidden" name="token" value="<%= token %>" />

            <div class="input-group mb-3">
              <span class="input-group-text"><i class="bi bi-lock"></i></span>
              <input
                id="password"
                name="password"
                type="password"
                class="form-control"
                placeholder="Enter your new password"
                required
                autocomplete="new-password"
                maxlength="20"
                pattern="^(?=(?:.*[A-Z]){1})(?!.*[A-Z].*[A-Z])(?!.*@.*@)[A-Za-z0-9@]{8,20}$"
                title="8–20 chars, letters/numbers and up to one '@'; exactly one uppercase letter."
              />
              <button
                class="btn input-toggle"
                type="button"
                id="togglePasswordReset"
                aria-label="Toggle password visibility"
              >
                <i class="bi bi-eye"></i>
              </button>
              <span id="reset-password-check" class="match-indicator d-none"></span>
            </div>
            <div id="reset-password-suggestions" class="form-text small">
              <!-- password hints -->
            </div>

            <div class="input-group mb-3">
              <span class="input-group-text"
                ><i class="bi bi-shield-lock"></i
              ></span>
              <input
                id="confirmPassword"
                name="confirmPassword"
                type="password"
                class="form-control"
                placeholder="Re-enter your new password"
                required
                autocomplete="new-password"
                maxlength="20"
                pattern="(?=.*[A-Z])[A-Za-z0-9]{8,20}"
                title="Repeat the password (must meet the same rules)."
              />
              <button
                class="btn input-toggle"
                type="button"
                id="toggleConfirmPasswordReset"
                aria-label="Toggle confirm password visibility"
              >
                <i class="bi bi-eye"></i>
              </button>
              <span id="reset-confirm-check" class="match-indicator d-none"></span>
            </div>

            <div class="d-grid mb-2">
              <button id="resetBtn" class="button" type="submit">
                Reset Password
              </button>
            </div>

            <div class="mt-2 text-center small text-muted">
              Remembered your password? <a href="/login">Login</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
