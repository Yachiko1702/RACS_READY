  .calendar-cell[data-status="available"] { background: linear-gradient(135deg,#7dd3b9,#5fd6c8); color: #fff; border: 1px solid rgba(125,211,185,0.25); cursor: pointer; box-shadow: 0 8px 18px rgba(125,211,185,0.12); }
  .calendar-cell[data-status="available"]:hover { transform: translateY(-4px); box-shadow: 0 14px 30px rgba(125,211,185,0.18); }
  .calendar-cell[data-status="booked"] { background: linear-gradient(135deg,#ff6384,#ff4f6b); color: #fff; border: 1px solid rgba(255,99,132,0.22); box-shadow: 0 8px 18px rgba(255,99,132,0.12); }
  .calendar-cell[data-status="blocked"] { background: linear-gradient(135deg,#f8f9fa,#eef1f3); color: #343a40; border: 1px solid rgba(0,0,0,0.04); box-shadow: inset 0 -4px 8px rgba(0,0,0,0.02); }
  .calendar-cell[data-status="public"] { background: linear-gradient(135deg,#f8f9fa,#eef1f3); color: #343a40; border: 1px solid rgba(0,0,0,0.04); box-shadow: inset 0 -4px 8px rgba(0,0,0,0.02); }
  /* Selected date: thin green outline, subtle shadow, white fill */
  .calendar-cell.is-selected { background: #ffffff; color: #16caa1; border: 2px solid #16caa1; box-shadow: 0 10px 30px rgba(22,202,161,0.12); transform: scale(0.98); }
  .calendar-cell.is-selected:hover { color: #16caa1; box-shadow: 0 12px 36px rgba(22,202,161,0.16); transform: scale(1); }
