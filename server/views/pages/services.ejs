#timeSlots .time-slot { flex: 1 1 calc(33.333% - .5rem); max-width: calc(33.333% - .5rem); display: inline-flex; flex-direction: column; align-items: flex-start; justify-content: center; border-radius: .6rem; padding: .45rem .75rem; min-height: 52px; height: auto; font-size: .92rem; text-align: left; border: 1px solid rgba(13,110,253,0.12); background: #fff; transition: transform .12s, box-shadow .12s, background .12s; white-space: normal; overflow: visible; box-sizing: border-box; }
#timeSlots .time-slot:hover { background: rgba(13,110,253,0.06); transform: translateY(-2px); border-color: rgba(13,110,253,0.28); }
#timeSlots .time-slot.active { background: linear-gradient(90deg,#0d6efd,#4f9dff); color:#fff; border-color: transparent; box-shadow: 0 10px 20px rgba(13,110,253,0.15); }
#timeSlots .time-slot.active .text-muted { color: rgba(255,255,255,0.8) !important; }
@media (max-width: 767px) { #timeSlots .time-slot { flex: 1 1 calc(50% - .5rem); max-width: calc(50% - .5rem); } }
@media (max-width: 480px) { #timeSlots .time-slot { flex: 1 1 100%; max-width: 100%; } }
