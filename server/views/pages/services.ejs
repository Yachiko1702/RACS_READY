<section class="booking-hero py-5">
  <div class="container">
  <div class="text-center mb-5" data-aos="fade-up" data-aos-duration="1000">
    <h2 class="display-5 fw-bold text-primary">Book a Service</h2>
    <p class="lead text-secondary">Smart scheduling for all services and repairs</p>
  </div>

  <div class="booking-container shadow-sm p-4 rounded-4 bg-white">

    <!-- Step 1: Choose Service Category -->
    <div class="mb-4">
      <h5 class="fw-semibold mb-3">Step 1: Choose Service Category</h5>
      <div class="d-flex gap-3 flex-wrap">
        <button type="button" class="btn btn-outline-primary btn-lg category-btn" data-category="services">
          <i class="bi bi-gear-fill me-2"></i>Core Services
        </button>
        <button type="button" class="btn btn-outline-secondary btn-lg category-btn" data-category="repairs">
          <i class="bi bi-tools me-2"></i>Repair Services
        </button>
      </div>
    </div>

    <!-- Step 2: Select Specific Service -->
    <div class="mb-4 d-none" id="serviceSelection">
      <h5 class="fw-semibold mb-2">Step 2: Select Service / Repair</h5>
      <div class="row g-3" id="serviceCards"></div>
    </div>

    <!-- Step 3: Scheduling Mode -->
    <div class="mb-4 d-none" id="modeSelection">
      <h5 class="fw-semibold mb-2">Step 3: Scheduling Mode</h5>
      <div class="d-flex gap-3">
        <button type="button" class="btn btn-outline-primary btn-sm mode-btn" data-mode="suggested">
          <i class="bi bi-stars me-1"></i>Suggested Dates (AI)
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm mode-btn" data-mode="manual">
          <i class="bi bi-calendar3 me-1"></i>Manual Calendar
        </button>
      </div>
    </div>

    <!-- Step 4: Suggested AI Dates -->
    <div class="mb-4 d-none" id="suggestedDates">
      <h5 class="fw-semibold mb-1">Step 4: Suggested Schedule</h5>
      <p class="text-muted small mb-3">These slots adjust based on technician load, travel time, and the duration of your selected service.</p>
      <div class="row g-3" id="suggestedCards"></div>
    </div>

    <!-- Step 4: Manual Calendar -->
    <div class="mb-4 d-none" id="manualCalendar">
      <div class="manual-guide alert alert-info border-0 shadow-sm">
        <div class="d-flex align-items-start">
          <i class="bi bi-calendar3-range text-primary fs-4 me-3"></i>
          <div>
            <h6 class="mb-1">Manual scheduling guide</h6>
            <ul class="mb-0 small">
              <li>Browse dates using the arrows on the calendar.</li>
              <li>Green means available. Red means reserved. Gray is a technician rest day.</li>
              <li>Pick any green date and we will confirm your exact time over chat.</li>
            </ul>
          </div>
        </div>
      </div>
      <h5 class="fw-semibold mb-1">Step 4: Pick a Date Manually</h5>
      <p class="text-muted small mb-3">Tap an available date to pair it with your preferred time later during confirmation.</p>
      <div class="calendar-status-pills d-flex flex-wrap gap-2 mb-3">
        <span class="status-pill available"><i class="bi bi-circle-fill me-1"></i>Available Slot</span>
        <span class="status-pill booked"><i class="bi bi-circle-fill me-1"></i>Reserved / Booked</span>
        <span class="status-pill blocked"><i class="bi bi-circle-fill me-1"></i>Non-working Day</span>
      </div>
      <div class="calendar-widget border rounded-4 bg-light">
        <div class="calendar-header d-flex align-items-center justify-content-between">
          <button type="button" class="btn btn-icon" data-calendar-nav="prev" aria-label="Previous month">
            <i class="bi bi-chevron-left"></i>
          </button>
          <div class="fw-semibold" data-calendar-label></div>
          <button type="button" class="btn btn-icon" data-calendar-nav="next" aria-label="Next month">
            <i class="bi bi-chevron-right"></i>
          </button>
        </div>
        <div class="calendar-body">
          <div class="calendar-weekdays">
            <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
          </div>
          <div class="calendar-grid" id="calendarGrid" role="grid" aria-live="polite"></div>
        </div>

        <!-- Time selection (appears after choosing a date) -->
        <div id="timeSelection" class="mt-3 d-none">
          <h6 class="mb-2 fw-semibold">Available Time Slots</h6>
          <div class="d-flex flex-wrap gap-2" id="timeSlots"></div>
          <div id="timeNotice" class="small text-muted mt-2"></div>
        </div>
      </div>
    </div>

    <!-- Step 5: Location -->
    <div class="mb-4 d-none" id="locationStep">
      <h5 class="fw-semibold mb-2">Step 5: Technician & Your Location</h5>
      <div class="row g-3 align-items-start">
        <div class="col-lg-5">
          <label for="locationInput" class="form-label text-muted">Address or Landmark</label>
          <div class="input-group input-group-lg shadow-sm">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-primary"></i></span>
            <input type="text" class="form-control border-start-0" placeholder="Pin your site or type address" id="locationInput" autocomplete="address-line1"/>
          </div>
          <button type="button" class="btn btn-outline-primary btn-sm mt-3" id="detectLocationBtn">
            <i class="bi bi-crosshair me-1"></i>Use my current location
          </button>
          <p class="location-hint small text-muted mt-2" id="locationStatus">We will never store your location without consent.</p>
        </div>
        <div class="col-lg-7">
          <div class="map-wrapper rounded-4 overflow-hidden shadow-sm">
            <div
              id="technicianMap"
              class="technician-map"
              data-technician-lat="<%= (technicianLocation && technicianLocation.lat) || 14.676049 %>"
              data-technician-lng="<%= (technicianLocation && technicianLocation.lng) || 121.043731 %>"
            ></div>
            <div class="map-overlay">
              <i class="bi bi-info-circle me-1"></i>
              <span>Green pin is our nearest technician. Blue pin is you.</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 6: Estimated Fee -->
    <div class="mb-4 d-none" id="feeStep">
      <h5 class="fw-semibold mb-2">Step 6: Estimated Fee</h5>
      <div class="fs-3 fw-bold text-primary" id="estimatedFee">₱0</div>
    </div>

    <!-- Step 7: Confirm -->
    <div class="mb-4 d-none" id="confirmStep">
      <button class="btn btn-primary btn-lg w-100 shadow-sm" id="confirmBooking">
        <i class="bi bi-check-circle me-2"></i>Confirm Booking
      </button>
    </div>
    
  </div>
  </div>
</section>

<style>
.booking-hero { background: linear-gradient(135deg, #eef6ff 0%, #d8ecff 35%, #f6fbff 100%); }
.booking-container { max-width: 980px; margin:auto; }
.category-btn, .mode-btn { transition: all 0.2s ease; border-width: 2px; }
.category-btn.active, .mode-btn.active { transform: scale(1.03); box-shadow: 0 10px 30px rgba(13,110,253,0.15); }
.service-card { border: 2px solid transparent; border-radius: 1.25rem; transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease; cursor: pointer; }
.service-card:hover { transform: translateY(-6px); }
.service-card.active { border-color: #0d6efd; background: linear-gradient(145deg, rgba(13,110,253,0.08), rgba(13,110,253,0.02)); box-shadow: 0 15px 35px rgba(13,110,253,0.15); }
.service-card small { color: #6c757d; }

.suggested-card { border: 2px dashed rgba(13,110,253,0.25); border-radius: 1.25rem; padding: 1.25rem; cursor: pointer; background: rgba(13,110,253,0.02); transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease; }
.suggested-card:hover { transform: translateY(-4px); border-color: rgba(13,110,253,0.5); }
.suggested-card.active { border-color: #0d6efd; background: rgba(13,110,253,0.08); box-shadow: 0 12px 25px rgba(13,110,253,0.2); }
.suggested-card .badge { font-size: 0.75rem; }

.calendar-widget { padding: 1.5rem; background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(13,110,253,0.05)); }
.calendar-status-pills .status-pill { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.85rem; border-radius: 999px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.2px; border: 1px solid transparent; }
.status-pill.available { color: #198754; background: rgba(25,135,84,0.12); border-color: rgba(25,135,84,0.35); }
.status-pill.booked { color: #c1121f; background: rgba(220,53,69,0.12); border-color: rgba(220,53,69,0.35); }
.status-pill.blocked { color: #6c757d; background: rgba(108,117,125,0.12); border-color: rgba(108,117,125,0.35); }
.calendar-header { margin-bottom: 1rem; }
.calendar-header .btn-icon { width: 38px; height: 38px; border: none; background: rgba(13,110,253,0.1); color: #0d6efd; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: background 0.2s ease; }
.calendar-header .btn-icon:hover { background: rgba(13,110,253,0.2); }
.calendar-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-size: 0.85rem; letter-spacing: 0.5px; color: #6c757d; text-transform: uppercase; margin-bottom: .5rem; }
.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.3rem; }
.calendar-cell { border: none; background: transparent; padding: 0; width: 100%; aspect-ratio: 1; border-radius: 0.95rem; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.95rem; position: relative; transition: transform 0.2s ease, box-shadow 0.2s ease; color: #0d1b2a; }
.calendar-cell:focus-visible { outline: 3px solid rgba(13,110,253,0.35); outline-offset: 2px; }
.calendar-cell[data-status="available"] { background: rgba(25,135,84,0.15); color: #198754; border: 1px solid rgba(25,135,84,0.35); cursor: pointer; }
.calendar-cell[data-status="available"]:hover { background: rgba(13,110,253,0.15); color: #0d6efd; border-color: rgba(13,110,253,0.4); box-shadow: 0 0 0 3px rgba(13,110,253,0.2); }
.calendar-cell[data-status="booked"] { background: rgba(220,53,69,0.15); color: #dc3545; border: 1px solid rgba(220,53,69,0.3); }
.calendar-cell[data-status="blocked"] { background: #f1f3f5; color: #6c757d; border: 1px solid #e2e6ea; }
.calendar-cell.is-selected { background: linear-gradient(135deg, #0d6efd, #4f9dff); color: #fff; border-color: transparent; box-shadow: 0 15px 30px rgba(13,110,253,0.3); transform: scale(0.95); }
.calendar-cell.is-selected:hover { color: #fff; box-shadow: 0 18px 30px rgba(13,110,253,0.35); }
.calendar-cell.disabled { opacity: 0.45; pointer-events: none; }

.calendar-legend { font-size: .95rem; }
.legend-dot { display:inline-block; width:12px; height:12px; border-radius:50%; margin-right:.3rem; box-shadow: 0 2px 6px rgba(0,0,0,0.15); }
.legend-dot.available { background-color:#198754; }
.legend-dot.booked { background-color:#dc3545; }
.legend-dot.blocked { background-color:#6c757d; }

.map-wrapper { min-height: 320px; background: #f8f9fa; position: relative; }
.technician-map { width: 100%; height: 320px; }
.map-overlay { position: absolute; bottom: 0.75rem; left: 0.75rem; background: rgba(255,255,255,0.9); padding: 0.4rem 0.8rem; border-radius: 999px; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.3rem; box-shadow: 0 8px 20px rgba(0,0,0,0.15); }
.location-hint { min-height: 1.5rem; }
.manual-guide ul { padding-left: 1rem; }
.manual-guide li { list-style: disc; }

/* TIME SLOTS */
.time-slot { border-radius: .6rem; padding: .45rem .75rem; min-width: 110px; text-align:center; border:1px solid rgba(13,110,253,0.12); background: #fff; transition: transform .12s, box-shadow .12s, background .12s; }
.time-slot:hover { background: rgba(13,110,253,0.06); transform: translateY(-2px); border-color: rgba(13,110,253,0.28); }
.time-slot.active { background: linear-gradient(90deg,#0d6efd,#4f9dff); color:#fff; border-color: transparent; box-shadow: 0 10px 20px rgba(13,110,253,0.15); }
</style>

<script type="module" src="/js/services.js"></script>
<% if (googleMapsApiKey) { %>
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initServicesMap" async defer></script>
<% } %>
