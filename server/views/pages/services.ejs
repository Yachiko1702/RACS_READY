<script>
  // preload and normalise service data coming from the server
  window.initialCatalog = <%- JSON.stringify(initialServices, null, 2) %>;
  // adaptor to make shape compatible with existing client logic
  ['coreServices','repairs'].forEach((category) => {
    window.initialCatalog[category] = (window.initialCatalog[category] || []).map(svc => ({
      icon: svc.icon || svc.iconClass || (category === 'repairs' ? 'bi-tools' : 'bi-gear-fill'),
      name: svc.name || '',
      duration: svc.duration || svc.durationMinutes || 0,
      price: svc.price || svc.basePrice || (svc.priceRange && svc.priceRange.min) || 0,
      _id: svc._id,
      slug: svc.slug,
      ...svc,
    }));
  });
</script>
<% } %>

<script type="module" src="/js/services.js"></script>
<script>
(function () {
  // Animate booking steps in when they become visible (d-none removed)
  const bookingBody = document.querySelector('.booking-body');
  if (!bookingBody || !window.MutationObserver) return;

  function triggerReveal(el) {
    // only animate actual booking-step blocks (not containers that hide permanently)
    if (!el.classList.contains('booking-step')) return;
    el.classList.remove('step-reveal');
    // force a reflow so the animation restarts from scratch
    void el.offsetWidth;
    el.classList.add('step-reveal');
    // clean up the class after the animation so it can replay next show
    el.addEventListener('animationend', function cleanup() {
      el.classList.remove('step-reveal');
      el.removeEventListener('animationend', cleanup);
    });
  }

  const observer = new MutationObserver(function (mutations) {
    mutations.forEach(function (m) {
      if (m.type !== 'attributes' || m.attributeName !== 'class') return;
      const el = m.target;
      // fire only when d-none is removed (step becomes visible for the first time in this flow)
      const wasHidden = m.oldValue && m.oldValue.split(' ').includes('d-none');
      const nowVisible = !el.classList.contains('d-none');
      if (wasHidden && nowVisible) {
        triggerReveal(el);
      }
    });
  });

  // observe every booking step
  bookingBody.querySelectorAll('.booking-step').forEach(function (step) {
    observer.observe(step, { attributes: true, attributeOldValue: true });
  });

  // Animate newly injected cards/slots in service, suggestion and time-slot containers.
  // calendarGrid is intentionally excluded — it re-renders on every month change and
  // would cause constant tweaking if observed.
  var childTargets = ['serviceCards', 'suggestedCards'];
  var childObserver = new MutationObserver(function (mutations) {
    // collect all added element nodes from this batch (deduplicated per container)
    var added = [];
    mutations.forEach(function (m) {
      if (m.type !== 'childList') return;
      m.addedNodes.forEach(function (node) {
        if (node.nodeType === 1) added.push(node);
      });
    });
    added.forEach(function (node, i) {
      var delay = Math.min(i, 10) * 55;
      node.style.animationDelay = delay + 'ms';
      node.style.animation = 'none';
      void node.offsetWidth;
      node.style.animation = 'fadeUp 320ms cubic-bezier(0.22,1,0.36,1) both';
      node.style.animationDelay = delay + 'ms';
    });
  });
  childTargets.forEach(function (id) {
    var el = document.getElementById(id);
    if (el) childObserver.observe(el, { childList: true });
  });

  // Time slots get a separate observer so they animate as a clean batch
  // each time the slot list is rebuilt (cleared then re-populated).
  var slotContainer = document.getElementById('timeSlots');
  if (slotContainer) {
    var slotBatch = [], slotTimer = null;
    var slotObserver = new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        if (m.type !== 'childList') return;
        m.addedNodes.forEach(function (node) {
          if (node.nodeType === 1) slotBatch.push(node);
        });
      });
      clearTimeout(slotTimer);
      slotTimer = setTimeout(function () {
        // animate the whole batch at once with stagger
        slotBatch.forEach(function (node, i) {
          node.style.animationDelay = (Math.min(i, 10) * 50) + 'ms';
          node.style.animation = 'none';
          void node.offsetWidth;
          node.style.animation = 'fadeUp 300ms cubic-bezier(0.22,1,0.36,1) both';
          node.style.animationDelay = (Math.min(i, 10) * 50) + 'ms';
        });
        slotBatch = [];
      }, 20);
    });
    slotObserver.observe(slotContainer, { childList: true });
  }
})();
</script>