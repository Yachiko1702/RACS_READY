  .selected-check { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 1.05rem; color: #16caa1; background: rgba(255,255,255,0.95); width: 28px; height: 28px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 6px 18px rgba(22,202,161,0.12); z-index: 2; }

