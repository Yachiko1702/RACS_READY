<section class="booking-hero py-5">
  <div class="container">
  <div class="text-center mb-5" data-aos="fade-up" data-aos-duration="1000">
    <h2 class="display-5 fw-bold text-primary">Book a Service</h2>
    <p class="lead text-secondary">Smart scheduling for all services and repairs</p>
  </div>

  <div class="booking-container shadow-sm p-4 rounded-4 bg-white">
    <% if (!user) { %>
      <div class="alert alert-warning" role="alert">
        Please <a href="/login" class="alert-link">log in</a> to book an appointment.
      </div>
    <% } %>
    <% if (typeof initialServices !== 'undefined') { %>
    <script id="initial-services-data">
      // preloaded catalog from CoreService / RepairService collections
      window.initialCatalog = <%- JSON.stringify(initialServices, null, 2) %>;
    </script>
    <% } %>
    <script>
      // make admin's gcash number available to client scripts
      window.adminGcashNumber = "<%= adminGcashNumber %>";
      // admin-configured fare per km (₱/km) used for distance meter calculations
      window._farePerKm = <%= typeof farePerKm !== 'undefined' ? farePerKm : 40 %>;
    </script>
    <!-- Floating left stepper (outside card) -->
    <aside class="booking-stepper floating" id="bookingStepper" aria-label="Booking steps">
      <ol class="stepper-list" role="list">
        <li>
          <button type="button" class="stepper-step" data-step="1" aria-label="Step 1: Category">
            <span class="stepper-icon">1</span>
            <span class="stepper-text">
              <span class="stepper-title">Category</span>
              <span class="stepper-sub">Core vs repair</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="stepper-step" data-step="2" aria-label="Step 2: Service">
            <span class="stepper-icon">2</span>
            <span class="stepper-text">
              <span class="stepper-title">Service</span>
              <span class="stepper-sub">Choose work needed</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="stepper-step" data-step="3" aria-label="Step 3: Technician">
            <span class="stepper-icon">3</span>
            <span class="stepper-text">
              <span class="stepper-title">Technician</span>
              <span class="stepper-sub">Pick a tech</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="stepper-step" data-step="4" aria-label="Step 4: Location">
            <span class="stepper-icon">4</span>
            <span class="stepper-text">
              <span class="stepper-title">Location</span>
              <span class="stepper-sub">Pin your site</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="stepper-step" data-step="5" aria-label="Step 5: Schedule">
            <span class="stepper-icon">5</span>
            <span class="stepper-text">
              <span class="stepper-title">Schedule</span>
              <span class="stepper-sub">Choose date/time</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="stepper-step" data-step="6" aria-label="Step 6: Fee">
            <span class="stepper-icon">6</span>
            <span class="stepper-text">
              <span class="stepper-title">Fee</span>
              <span class="stepper-sub">See estimate</span>
            </span>
          </button>
        </li>
        <li>
          <button type="button" class="stepper-step" data-step="7" aria-label="Step 7: Payment">
            <span class="stepper-icon">7</span>
            <span class="stepper-text">
              <span class="stepper-title">Payment</span>
              <span class="stepper-sub">Pick method</span>
            </span>
          </button>
        </li>
      </ol>
    </aside>

    <div class="booking-layout">
      <div class="booking-body">
        <!-- Step 1: Choose Service Category -->
        <div class="mb-4 booking-step" data-step="1">
          <h5 class="fw-semibold mb-3">Step 1: Choose Service Category</h5>
          <div class="d-flex gap-3 flex-wrap">
            <button type="button" class="btn btn-outline-primary btn-lg category-btn" data-category="services" <%= user ? '' : 'disabled title="Please log in to continue"' %>>
              <i class="bi bi-gear-fill me-2"></i>Core Services
            </button>
            <button type="button" class="btn btn-outline-primary btn-lg category-btn" data-category="repairs" <%= user ? '' : 'disabled title="Please log in to continue"' %>>
              <i class="bi bi-tools me-2"></i>Repair Services
            </button>
          </div>
        </div>

        <!-- Step 2: Select Specific Service -->
        <div class="mb-4 d-none booking-step" id="serviceSelection" data-step="2">
          <h5 class="fw-semibold mb-2">Step 2: Select Service / Repair</h5>
          <div class="row g-3" id="serviceCards"></div>
          <!-- issue description shown only when booking a repair -->
          <div class="mt-3 d-none" id="repairIssueContainer">
            <label for="repairIssue" class="form-label">
              Describe the problem or issue you need fixed
            </label>
            <textarea class="form-control" id="repairIssue" rows="2" placeholder="e.g. " required></textarea>
          </div>
        </div>

        <!-- Step 3: Choose Technician -->
        <div class="mb-4 d-none booking-step" id="technicianStep" data-step="3">
          <h5 class="fw-semibold mb-2">Step 3: Choose Technician</h5>
          <p class="small text-muted mb-2">Select a technician to handle your request.</p>
          <!-- technician picker loaded dynamically -->
          <div class="mb-3">
            <label for="technicianSelect" class="form-label">Choose Technician</label>
            <select id="technicianSelect" class="form-select">
              <option value="">Loading technicians&hellip;</option>
            </select>
          </div>
        </div>

        <!-- Step 4: Location & Schedule -->
        <div class="mb-4 d-none booking-step" id="locationStep" data-step="4">
          <h5 class="fw-semibold mb-2">Step 4: Technician & Your Location</h5>
          <div class="row g-3 align-items-start">
            <div class="col-lg-5">
              <label for="locationInput" class="form-label text-muted">Address or Landmark</label>
              <div class="position-relative">
                <div class="input-group input-group-lg shadow-sm">
                  <span class="input-group-text bg-white border-end-0"><i class="bi bi-geo-alt text-primary"></i></span>
                  <input type="text" class="form-control border-start-0" placeholder="Pin your site or type address" id="locationInput" autocomplete="address-line1"/>
                </div>
                <div id="locationSuggest" class="list-group position-absolute w-100 d-none" style="z-index:1000;"></div>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm mt-3" id="detectLocationBtn">
                <i class="bi bi-crosshair me-1"></i>Use my current location
              </button>
              <p class="location-hint small text-muted mt-2" id="locationStatus">We will never store your location without consent.</p>
            </div>
            <div class="col-lg-7">
              <div class="map-wrapper rounded-4 shadow-sm">
                <div
                  id="technicianMap"
                  class="technician-map"
                  data-technician-lat="<%= (technicianLocation && technicianLocation.lat) || 14.676049 %>"
                  data-technician-lng="<%= (technicianLocation && technicianLocation.lng) || 121.043731 %>"
                ></div>
                <!-- Locate buttons floating on map -->
                <div class="map-locate-btns">
                  <button type="button" class="btn btn-sm btn-light shadow-sm" id="locateTechBtn" title="Go to Technician">
                    <i class="bi bi-car-front-fill text-primary me-1"></i>Technician
                  </button>
                  <button type="button" class="btn btn-sm btn-light shadow-sm" id="locateCustomerBtn" title="Go to Your Location">
                    <i class="bi bi-person-fill text-success me-1"></i>You
                  </button>
                </div>
                <div class="map-overlay">
                <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                <span class="d-flex align-items-center gap-2">
                  <svg class="map-pin map-pin-tech" width="20" height="28" viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                    <path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    <circle cx="12" cy="9" r="2.5" fill="#fff"/>
                  </svg>
                  <span>Blue pin is our nearest technician. Green pin is you.</span>
                  <svg class="map-pin map-pin-you ms-2" width="20" height="28" viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                    <path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                    <circle cx="12" cy="9" r="2.5" fill="#fff"/>
                  </svg>
                </span>
                <div id="mapDistanceInfo" class="mt-2 small text-dark"></div>
                </div>
              </div>
              <!-- Distance & fare description below the map -->
              <div class="map-info-panel mt-3 p-3 rounded-3 bg-light border" id="mapInfoPanel">
                <div class="d-flex align-items-start gap-2 mb-2">
                  <i class="bi bi-signpost-split text-primary fs-5"></i>
                  <div>
                    <h6 class="mb-1 fw-semibold">Distance &amp; Travel Fare</h6>
                    <p class="mb-0 small text-muted" id="mapInfoDistance">Detecting locations&hellip;</p>
                  </div>
                </div>
                <div class="d-flex align-items-center gap-2 mb-1">
                  <i class="bi bi-cash-coin text-success"></i>
                  <span class="small" id="mapInfoFare">&mdash;</span>
                </div>
                <p class="mb-0 text-muted" style="font-size:0.75rem;">
                  <i class="bi bi-info-circle me-1"></i>Distance meter fare is calculated at <strong>₱<span id="fareRateDisplay"><%= typeof farePerKm !== 'undefined' ? farePerKm : 40 %></span> per kilometer</strong> based on the road distance between the technician and your location.
                </p>
              </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 5: Scheduling Mode -->
        <div class="mb-4 d-none booking-step" id="modeSelection" data-step="5">
          <h5 class="fw-semibold mb-2">Step 5: Scheduling Mode</h5>
          <p class="small text-muted mb-2">Pick how you want to choose a slot.</p>
          <div class="d-flex gap-3">
            <button type="button" class="btn btn-outline-primary btn-sm mode-btn" data-mode="suggested">
              <i class="bi bi-stars me-1"></i>Suggested Dates (AI)
            </button>
            <button type="button" class="btn btn-outline-primary btn-sm mode-btn" data-mode="manual">
              <i class="bi bi-calendar3 me-1"></i>Manual Calendar
            </button>
          </div>
        </div>

        <!-- Step 5: Suggested AI Dates -->
        <div class="mb-4 d-none booking-step" id="suggestedDates" data-step="5">
          <h5 class="fw-semibold mb-1">Step 5: Suggested Schedule</h5>
          <p class="text-muted small mb-3">These slots adjust based on technician load, travel time, and the duration of your selected service.</p>
          <div class="row g-3" id="suggestedCards"></div>
        </div>

        <!-- Step 5: Manual Calendar -->
        <div class="mb-4 d-none booking-step" id="manualCalendar" data-step="5">
          <div class="manual-guide alert alert-info border-0 shadow-sm">
            <div class="d-flex align-items-start">
              <i class="bi bi-calendar3-range text-primary fs-4 me-3"></i>
              <div>
                <h6 class="mb-1">Manual scheduling guide</h6>
                <ul class="mb-0 small">
                  <li>Browse dates using the arrows on the calendar.</li>
                  <li>Green means available. Red means reserved. Gray is a technician rest day.</li>
                  <li>Pick any green date and we will confirm your exact time over chat.</li>
                </ul>
              </div>
            </div>
          </div>
          <h5 class="fw-semibold mb-1">Step 5: Pick a Date Manually</h5>
          <p class="text-muted small mb-3">Tap an available date to pair it with your preferred time later during confirmation.</p>
          <div class="calendar-status-pills d-flex flex-wrap gap-2 mb-3">
            <span class="status-pill available"><i class="bi bi-circle-fill me-1"></i>Available Slot</span>
            <span class="status-pill booked"><i class="bi bi-circle-fill me-1"></i>Reserved / Booked</span>
            <span class="status-pill public"><i class="bi bi-circle-fill me-1"></i>Public Holiday</span>
            <span class="status-pill blocked"><i class="bi bi-circle-fill me-1"></i>Non-working Day</span>
          </div>
          <div class="calendar-widget border rounded-4 bg-light">
            <div class="calendar-header d-flex align-items-center justify-content-between">
              <button type="button" class="btn btn-icon" data-calendar-nav="prev" aria-label="Previous month">
                <i class="bi bi-chevron-left"></i>
              </button>
              <div class="fw-semibold" data-calendar-label></div>
              <button type="button" class="btn btn-icon" data-calendar-nav="next" aria-label="Next month">
                <i class="bi bi-chevron-right"></i>
              </button>
            </div>
            <div class="calendar-body">
              <div class="calendar-weekdays">
                <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
              </div>
              <div class="calendar-grid" id="calendarGrid" role="grid" aria-live="polite"></div>
              <div id="timeRangeInfo" class="small text-muted mt-2"></div>
            </div>

            <!-- Time selection (appears after choosing a date) -->
            <div id="timeSelection" class="mt-3 d-none">
              <h6 class="mb-2 fw-semibold">Available Time Slots</h6>
              <div class="d-flex flex-wrap gap-2" id="timeSlots"></div>
              <div id="timeNotice" class="small text-muted mt-2"></div>
            </div>
          </div>
        </div>


        <!-- Step 6: Estimated Fee -->
        <div class="mb-4 d-none booking-step" id="feeStep" data-step="6">
          <h5 class="fw-semibold mb-2">Step 6: Estimated Fee</h5>
          <div class="fs-3 fw-bold text-primary" id="estimatedFee">₱0</div>
        </div>


        <!-- Step 7: Payment Method -->
        <div class="mb-4 d-none booking-step" id="paymentStep" data-step="7">
          <h5 class="fw-semibold mb-3">Step 7: Payment Method</h5>

          <!-- Payment tab selection -->
          <div class="payment-tabs mb-4" role="tablist" aria-label="Payment methods">
            <button type="button" class="payment-tab" data-method="gcash" aria-pressed="false">
              <i class="bi bi-phone"></i>
              <span>GCash</span>
            </button>
            <button type="button" class="payment-tab" data-method="cash" aria-pressed="false">
              <i class="bi bi-cash-stack"></i>
              <span>Cash</span>
            </button>
          </div>

          <!-- Hidden radios for form state -->
          <input class="d-none" type="radio" name="paymentMethod" id="payGcash" value="gcash">
          <input class="d-none" type="radio" name="paymentMethod" id="payCash" value="cash">

          <!-- Manual GCash payment form -->
          <div id="gcashFields" class="d-none">
            <div class="payment-form">
              <h6 class="fw-semibold mb-3">Pay with GCash</h6>

              <div class="card-option-box mb-3" style="background:linear-gradient(135deg,#f0fdf4,#dcfce7);border-color:#16a34a;">
                <div class="card-option-header mb-2">
                  <i class="bi bi-phone text-success fs-4"></i>
                  <span class="fw-semibold">Manual GCash Transfer</span>
                </div>
                <ol class="mb-0 ps-3 small text-muted" style="line-height:1.8;">
                  <li>Scan our GCash QR code below in your GCash app.</li>
                  <li>Send the required payment amount.</li>
                  <li>Enter your payment reference number.</li>
                  <li>Upload your receipt screenshot before confirming the booking.</li>
                </ol>
              </div>

              <div class="text-center mb-3">
                <label class="form-label text-muted d-block fw-semibold">Scan this GCash QR</label>
                <img
                  id="gcashQrImage"
                  src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=RACSREADY-GCASH-PAYMENT"
                  alt="GCash QR Code"
                  class="img-thumbnail"
                  style="max-width:220px;border-radius:12px;"
                />
                <div class="form-text">Replace this QR with your official merchant GCash QR image before go-live.</div>
              </div>

              <div class="mb-3">
                <label class="form-label text-muted">Your GCash mobile number <span class="text-danger">*</span></label>
                <div class="position-relative">
                  <input id="gcashNumber" class="form-control" inputmode="tel" placeholder="+639XXXXXXXXX" />
                  <i class="bi bi-phone gcash-icon-input"></i>
                </div>
                <div class="form-text">Use the sender number used for this payment.</div>
              </div>

              <div class="mb-3">
                <label class="form-label text-muted">GCash Reference Number <span class="text-danger">*</span></label>
                <input id="gcashReference" class="form-control" placeholder="e.g. 123456789012" />
              </div>

              <div class="mb-3">
                <label class="form-label text-muted">Receipt Screenshot <span class="text-danger">*</span></label>
                <input id="gcashProof" type="file" class="form-control" accept="image/*" />
                <div class="form-text">Accepted: image files only (JPG, PNG, WEBP).</div>
                <img id="gcashProofPreview" alt="GCash receipt preview" class="img-thumbnail mt-2 d-none" style="max-height:160px;border-radius:10px;" />
              </div>

              <div class="rounded-3 p-3 mb-3" style="background:#f8fdff;border:1px solid #bee3f8;">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="text-muted small">Amount to send via GCash</span>
                  <span class="fw-bold text-primary fs-5" id="gcashAmountDisplay">—</span>
                </div>
                <div class="text-muted" style="font-size:0.75rem;margin-top:4px;"><i class="bi bi-info-circle me-1"></i>Please send this amount, then upload the receipt screenshot.</div>
              </div>

              <div class="alert alert-success border-0" role="alert" style="background:#f0fdf4;border-left:4px solid #16a34a !important;">
                <div class="d-flex align-items-start gap-2">
                  <i class="bi bi-lock-fill text-success mt-1"></i>
                  <div>
                    <div class="fw-semibold small">Manual verification required</div>
                    <small class="text-muted">Your payment proof and reference number will be reviewed by admin before final confirmation.</small>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Booking result modal -->
          <div class="modal fade" id="bookingResultModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">
                <!-- Green header with reference badge -->
                <div class="modal-header border-0 text-white" style="background:linear-gradient(135deg,#0d6efd,#0a58ca);padding:28px 28px 20px;">
                  <div class="w-100 text-center">
                    <div class="mb-2" style="font-size:2.2rem;">&#128295;</div>
                    <h5 class="modal-title fw-bold mb-1" style="font-size:1.15rem;letter-spacing:.3px;">Booking Request Submitted!</h5>
                    <div class="mt-2 d-inline-block px-3 py-1 rounded"
                         style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);font-size:1rem;font-weight:700;letter-spacing:2px;color:#fff;"
                         id="bookingResultReference"><!-- ref injected by JS --></div>
                  </div>
                  <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body px-4 pt-3 pb-2">
                  <!-- Status pill -->
                  <div class="text-center mb-3">
                    <span class="badge rounded-pill px-3 py-2"
                          style="background:#fff8e1;color:#e65100;border:1px solid #ffd54f;font-size:.78rem;font-weight:700;">
                      &#9203; PENDING CONFIRMATION
                    </span>
                  </div>
                  <!-- Summary message -->
                  <p class="text-muted small text-center mb-3" id="bookingResultMessage">
                    Your booking request has been submitted. We will confirm it shortly.
                  </p>
                  <!-- Details table -->
                  <div class="rounded-3 p-3 mb-3" style="background:#f8f9fa;font-size:.88rem;">
                    <div class="d-flex justify-content-between py-1 border-bottom">
                      <span class="text-muted">Date</span>
                      <span class="fw-semibold" id="bookingResultDate">&mdash;</span>
                    </div>
                    <div class="d-flex justify-content-between py-1 border-bottom">
                      <span class="text-muted">Time</span>
                      <span class="fw-semibold" id="bookingResultTime">&mdash;</span>
                    </div>
                    <div class="d-flex justify-content-between py-1">
                      <span class="text-muted">Estimated Fee</span>
                      <span class="fw-bold text-success" id="bookingResultFee">&mdash;</span>
                    </div>
                  </div>
                  <p class="text-muted" style="font-size:.78rem;">
                    A confirmation email has been sent to your registered address. You can track or manage this booking in your booking history.
                  </p>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-0 gap-2 justify-content-center">
                  <a href="/book-history" class="btn btn-primary px-4">View My Bookings</a>
                  <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Close</button>
                </div>
              </div>
            </div>
          </div>
          <script>
            // move modal to body to avoid z-index/backdrop issues
            document.addEventListener("DOMContentLoaded", () => {
              const m = document.getElementById("bookingResultModal");
              if (m && m.parentElement !== document.body) {
                document.body.appendChild(m);
              }
              const css = document.createElement("style");
              css.textContent = ".modal { z-index: 2000 !important; } .modal-backdrop { z-index: 1500 !important; backdrop-filter: none !important; }";
              document.head.appendChild(css);
            });
          </script>

          <!-- Cash payment form -->
          <div id="cashFields" class="d-none">
            <div class="payment-form">
              <!-- Payment Section Header -->
              <h6 class="fw-semibold mb-3">Cash Payment</h6>

              <!-- Cash option header -->
              <div class="card-option-box mb-3" style="background:linear-gradient(135deg,#fffbeb,#fef9c3);border-color:#ca8a04;">
                <div class="card-option-header mb-1">
                  <i class="bi bi-cash-stack text-warning fs-4"></i>
                  <span class="fw-semibold">Pay Cash on Completion</span>
                </div>
                <p class="mb-0 small text-muted ps-4">Pay the full amount to the technician after the work is done. A <strong>required downpayment</strong> of ₱400 is collected in advance to secure your slot.</p>
              </div>

              <div class="text-center mb-3">
                <label class="form-label text-muted d-block fw-semibold">Scan this Cash QR</label>
                <img
                  id="cashQrImage"
                  src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=RACSREADY-CASH-PAYMENT"
                  alt="Cash QR Code"
                  class="img-thumbnail"
                  style="max-width:220px;border-radius:12px;"
                />
                <div class="form-text">Replace this QR with your official merchant cash QR image before go-live.</div>
              </div>

              <div class="mb-3">
                <label class="form-label text-muted">Your mobile number <span class="text-danger">*</span></label>
                <div class="position-relative">
                  <input id="cashNumber" class="form-control" inputmode="tel" placeholder="+639XXXXXXXXX" />
                  <i class="bi bi-phone gcash-icon-input"></i>
                </div>
                <div class="form-text">Use the sender number used for this payment.</div>
              </div>

              <div class="mb-3">
                <label class="form-label text-muted">Cash Reference Number <span class="text-danger">*</span></label>
                <input id="cashReference" class="form-control" placeholder="e.g. 123456789012" />
              </div>

              <div class="mb-3">
                <label class="form-label text-muted">Receipt Screenshot <span class="text-danger">*</span></label>
                <input id="cashProof" type="file" class="form-control" accept="image/*" />
                <div class="form-text">Accepted: image files only (JPG, PNG, WEBP).</div>
                <img id="cashProofPreview" alt="Cash receipt preview" class="img-thumbnail mt-2 d-none" style="max-height:160px;border-radius:10px;" />
              </div>

