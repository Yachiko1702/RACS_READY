<div class="auth-inner py-4">
  <div class="text-center mb-4">
    <h1 class="h3 fw-bold mb-1">Welcome back</h1>
    <p class="text-muted small mb-0">Sign in to manage appointments and services securely.</p>
  </div>

  <% if (registered) { %>
    <div class="alert alert-success" role="alert">Account created successfully. Please log in.</div>
  <% } %>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger" role="alert">Invalid email or password. Please try again.</div>
  <% } %>

  <form action="/api/auth/login" method="POST" autocomplete="on" novalidate>
    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

    <div class="mb-3">
      <label for="email" class="form-label small">Email</label>
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
        <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required autocomplete="email">
      </div>
    </div>

    <div class="mb-3">
      <label for="password" class="form-label small">Password</label>
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-lock"></i></span>
        <input id="password" name="password" type="password" class="form-control" placeholder="••••••••" required autocomplete="current-password" aria-describedby="togglePassword">
        <button class="btn btn-toggle" type="button" id="togglePassword" aria-label="Toggle password visibility"><i class="bi bi-eye"></i></button>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <div class="form-check">
        <input class="form-check-input" type="checkbox" value="" id="remember" name="remember">
        <label class="form-check-label small text-muted" for="remember">Remember me</label>
      </div>
      <a href="/forgot-password" class="small">Forgot password?</a>
    </div>

    <div class="d-grid">
      <button class="button" type="submit">Sign In</button>
    </div>

    <div class="mt-3 text-center small text-muted">Don't have an account? <a href="/register">Create one</a></div>
  </form>
</div>
