<div class="auth-inner py-4">
  <div class="text-center mb-4">
    <h1 class="h4 fw-bold mb-1">Reset your password</h1>
    <p class="text-muted small mb-0">We'll send a secure link to reset your password. We won’t reveal whether the email exists.</p>
  </div>

  <div id="forgotAlert" class="alert d-none" role="alert"></div>

  <form id="forgotForm" action="/api/auth/forgot-password" method="POST" autocomplete="on" novalidate>
    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

    <div class="mb-3">
      <label for="email" class="form-label small">Email</label>
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
        <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required autocomplete="email" maxlength="254">
      </div>
    </div>

    <% if (recaptchaSiteKey) { %>
      <div class="mb-3">
        <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
      </div>
    <% } %>

    <div class="d-grid">
      <button id="forgotBtn" class="button" type="submit">Send Reset Link</button>
    </div>

    <div class="mt-3 text-center small text-muted">Remembered your password? <a href="/login">Login</a></div>

    <hr>
    <p class="small text-muted">This system uses encrypted authentication and role-based access control.</p>
  </form>
</div>