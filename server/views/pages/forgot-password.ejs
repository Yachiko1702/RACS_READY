<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
      <div class="card shadow-sm border-0 auth-card-wide">
        <div class="card-body p-5">
          <div class="forgot-auth-content">
            <div class="forgot-card-header text-center mb-4">
              <h1 class="h4 fw-bold mb-1">Forgot password</h1>
              <p class="text-muted small mb-0">
                We'll send a secure link to reset your password. We won’t reveal
                whether the email exists.
              </p>
            </div>

            <div id="forgotAlert" class="alert d-none" role="alert"></div>

            <form
              id="forgotForm"
              action="/api/auth/forgot-password"
              method="POST"
              autocomplete="on"
              novalidate
            >
              <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />

              <div class="mb-3">
                <div class="input-group">
                  <span class="input-group-text"
                    ><i class="bi bi-envelope"></i
                  ></span>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    class="form-control"
                    placeholder="Email"
                    required
                    autocomplete="email"
                    maxlength="50"
                  />
                </div>
              </div>

              <div class="mb-3 math-captcha">
                <label
                  for="forgot-math"
                  class="form-label small d-flex align-items-center"
                >
                  <span class="captcha-question"><%= mathQuestion %></span>
                  <button
                    type="button"
                    class="btn btn-link btn-sm p-0 ms-2 refresh-captcha"
                    title="Reload question"
                  >
                    <i class="bi bi-arrow-clockwise"></i>
                  </button>
                </label>
                <div class="input-group">
                  <span class="input-group-text"
                    ><i class="bi bi-calculator"></i
                  ></span>
                  <input
                    id="forgot-math"
                    name="mathCaptcha"
                    type="text"
                    inputmode="numeric"
                    pattern="[0-9]{1,2}"
                    maxlength="2"
                    title="Enter the numeric answer (1–2 digits)"
                    class="form-control"
                    placeholder="Enter the answer"
                    required
                  />
                </div>
                <input
                  type="hidden"
                  name="mathAnswer"
                  value="<%= mathAnswer %>"
                />
              </div>

              <div class="d-grid">
                <button
                  id="forgotBtn"
                  class="button accent-slide"
                  type="submit"
                >
                  Send Reset Link
                </button>
              </div>

              <div class="mt-3 text-center small text-muted">
                Remembered your password?
                <a href="/login" class="text-decoration-none">Login</a>
              </div>

              <hr />
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
