<div class="admin-dashboard container-fluid py-4">
  <%- include('../../partials/dashboard-styles') %>

  <div class="dashboard-hero mb-4">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="page-title">
          <i class="bi bi-tools me-2"></i>Tool Usage Management
        </h1>
        <p class="hero-sub">
          Track materials and costs; materials added here are shared to the technician tool catalog.
        </p>
      </div>
      <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <button class="btn btn-light btn-sm" id="toolUsageRefreshBtn">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="kpi-card"><div class="kpi-label">Entries</div><div class="kpi-value" id="kpiEntries">—</div></div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card"><div class="kpi-label">Total Qty</div><div class="kpi-value" id="kpiQty">—</div></div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card"><div class="kpi-label">Fuel Cost</div><div class="kpi-value" id="kpiFuel">—</div></div>
    </div>
    <div class="col-6 col-md-3">
      <div class="kpi-card"><div class="kpi-label">Tool Cost</div><div class="kpi-value" id="kpiCost">—</div></div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-bold">Filters</div>
    <div class="card-body">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold">From</label>
          <input type="date" id="filterStart" class="form-control form-control-sm" />
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold">To</label>
          <input type="date" id="filterEnd" class="form-control form-control-sm" />
        </div>
        <div class="col-md-3">
          <label class="form-label small text-uppercase text-muted fw-bold">Technician</label>
          <select id="filterTech" class="form-select form-select-sm">
            <option value="">All technicians</option>
          </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
          <button class="btn btn-sm btn-primary w-100" id="applyFilterBtn">Apply</button>
          <button class="btn btn-sm btn-outline-secondary w-100" id="clearFilterBtn">Clear</button>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-bold">Add Usage Entry</div>
    <div class="card-body">
      <form id="addToolUsageForm" class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label small fw-semibold">Material Name</label>
          <input id="newItemName" type="text" class="form-control form-control-sm" placeholder="e.g. Copper Pipe 1/2" required />
        </div>
        <div class="col-md-1">
          <label class="form-label small fw-semibold">Unit</label>
          <input id="newUnit" type="text" class="form-control form-control-sm" placeholder="pcs" value="pcs" />
        </div>
        <div class="col-md-1">
          <label class="form-label small fw-semibold">Unit Price</label>
          <input id="newUnitPrice" type="number" min="0" step="0.01" class="form-control form-control-sm" required />
        </div>
        <div class="col-md-1">
          <label class="form-label small fw-semibold">Qty</label>
          <input id="newQty" type="number" min="0.01" step="0.01" class="form-control form-control-sm" required />
        </div>
        <div class="col-md-9">
          <label class="form-label small fw-semibold">Notes</label>
          <input id="newNotes" type="text" maxlength="500" class="form-control form-control-sm" placeholder="Optional note" />
        </div>
        <div class="col-md-2 d-grid">
          <button type="submit" class="btn btn-sm btn-dark" id="saveToolUsageBtn">
            <i class="bi bi-plus-circle me-1"></i>Add Entry
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
      <span>Usage Records</span>
      <span class="small text-muted" id="toolUsageCount">—</span>
    </div>
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Booking</th>
            <th>Technician</th>
            <th>Item</th>
            <th>Unit Price</th>
            <th>Qty</th>
            <th>Fuel Cost</th>
            <th>Cost</th>
            <th>Notes</th>
            <th style="width:180px">Actions</th>
          </tr>
        </thead>
        <tbody id="toolUsageBody">
          <tr><td colspan="10" class="text-center text-muted py-4">Loading tool usage…</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  window.TOOL_USAGE_CONTEXT = {
    apiBase: "<%= apiBase %>",
    roleLabel: "<%= roleLabel %>",
  };
</script>
<script src="/js/tool-usage-management.js"></script>
