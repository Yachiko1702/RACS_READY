<div class="auth-inner py-4">
  <div class="text-center mb-4">
    <h1 class="h3 fw-bold mb-1">Create an account</h1>
    <p class="text-muted small mb-0">Register to manage appointments and track service requests securely.</p>
  </div>

  <div id="registerAlert" class="alert d-none" role="alert"></div>

  <form id="auth-register-form" action="/api/auth/register" method="POST" autocomplete="on" novalidate>
    <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

    <div class="mb-3">
      <label for="email" class="form-label small">Email</label>
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
        <input id="email" name="email" type="email" class="form-control" placeholder="you@example.com" required autocomplete="email" maxlength="254">
      </div>
    </div>

    <div class="mb-3">
      <label for="password" class="form-label small">Password</label>
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-lock"></i></span>
        <input id="password" name="password" type="password" class="form-control" placeholder="Create a password" required autocomplete="new-password" aria-describedby="togglePasswordReg">
        <button class="btn btn-toggle" type="button" id="togglePasswordReg" aria-label="Toggle password visibility"><i class="bi bi-eye"></i></button>
      </div>
    </div>

    <div class="mb-3">
      <label for="confirmPassword" class="form-label small">Confirm password</label>
      <div class="input-group">
        <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
        <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" placeholder="Re-enter your password" required autocomplete="new-password" aria-describedby="toggleConfirmPasswordReg">
        <button class="btn btn-toggle" type="button" id="toggleConfirmPasswordReg" aria-label="Toggle confirm password visibility"><i class="bi bi-eye"></i></button>
      </div>
    </div>

    <% if (recaptchaSiteKey) { %>
      <div class="mb-3">
        <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
        <noscript>
          <div class="small text-danger mt-2">Please enable JavaScript to complete the CAPTCHA.</div>
        </noscript>
      </div>
    <% } %>

    <div class="d-grid">
      <button id="registerBtn" class="button" type="submit">Create Account</button>
    </div>

    <div class="mt-3 text-center small text-muted">Already have an account? <a href="/login">Login</a></div>

    <hr>
    <p class="small text-muted">This system uses encrypted authentication and role-based access control.</p>
  </form>
</div>